        emit_byte(0x48)
        emit_byte(0x83)
        emit_byte(0xEF)
        emit_byte(0x08)
        // rsi = *(rdi) + 8 (total length)
        // mov rsi, [rdi]
        emit_byte(0x48)
        emit_byte(0x8B)
        emit_byte(0x37)
        // add rsi, 8
        emit_byte(0x48)
        emit_byte(0x83)
        emit_byte(0xC6)
        emit_byte(0x08)
        // mov rax, 11 (munmap syscall) — OS-aware
        uint64 munmap_nr = ir_x86_syscall_nr(11)
        ir_emit_mov_r64_imm64(0, munmap_nr)
