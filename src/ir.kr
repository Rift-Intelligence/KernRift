        if op == 121 { emit_byte(0x9E) }  // setle (signed <=)
        if op == 122 { emit_byte(0x9F) }  // setg  (signed >)
        if op == 123 { emit_byte(0x9D) }  // setge (signed >=)
        emit_byte(0xC0)
        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)
