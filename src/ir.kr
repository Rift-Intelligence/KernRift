        // xor rcx, rcx (digit count)
        emit_byte(0x48); emit_byte(0x31); emit_byte(0xC9)
        // mov r9, 10 (divisor) [use r9 as divisor since r10 is buf]
        ir_emit_mov_r64_imm64(9, 10)
        // Handle zero case: test rax, rax; jnz .ff_nonzero
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
        emit_byte(0x75)  // jnz rel8
        uint64 ff_fnz_patch = out_len
        emit_byte(0)
        // zero: write '0', inc rdi (to account for 1 digit written), jmp .ff_ui_done
        emit_byte(0xC6); emit_byte(0x07); emit_byte(0x30)   // mov byte [rdi], '0'
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC7)   // inc rdi
        emit_byte(0xEB)  // jmp .ff_ui_done
        uint64 ff_fuiz_patch = out_len
        emit_byte(0)

        // .ff_nonzero:
        uint64 ff_fnz = out_len
        uint8 ff_fnz_disp = ff_fnz - ff_fnz_patch - 1
        uint64 ff_fnz_p = out_buf + ff_fnz_patch
        unsafe { *(ff_fnz_p as uint8) = ff_fnz_disp }

        // digit_loop: xor rdx, rdx; div r9
        uint64 ff_ui_loop = out_len
        emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)
        emit_byte(0x49); emit_byte(0xF7); emit_byte(0xF1)   // div r9
        // add dl, '0'
        emit_byte(0x80); emit_byte(0xC2); emit_byte(0x30)
        // push rdx
        emit_byte(0x52)
        // inc rcx
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC1)
        // test rax, rax
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
        // jnz digit_loop
        emit_byte(0x75)
        uint64 ff_ui_jnz = out_len
        uint8 ff_ui_disp = ff_ui_loop - ff_ui_jnz - 1
        uint64 ff_ui_jnz_p = out_buf + ff_ui_jnz
        emit_byte(0)
        unsafe { *(ff_ui_jnz_p as uint8) = ff_ui_disp }
        // pop digits in order: inc rdi; pop digit; dec rdi; store
        // Actually: we pushed digits LSB first, so pop MSB first → correct order
        // pop_loop: pop rdx; mov [rdi], dl; inc rdi; dec rcx; jnz pop_loop
        uint64 ff_pop_loop = out_len
        emit_byte(0x5A)  // pop rdx
        emit_byte(0x88); emit_byte(0x17)   // mov [rdi], dl
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC7)   // inc rdi
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC9)   // dec rcx
        emit_byte(0x75)  // jnz pop_loop
        uint64 ff_pop_jnz = out_len
        uint8 ff_pop_disp = ff_pop_loop - ff_pop_jnz - 1
        uint64 ff_pop_p = out_buf + ff_pop_jnz
        emit_byte(0)
        unsafe { *(ff_pop_p as uint8) = ff_pop_disp }

        // .ff_ui_done:
        uint64 ff_ui_done = out_len
        uint8 ff_fuiz_disp = ff_ui_done - ff_fuiz_patch - 1
        uint64 ff_fuiz_p = out_buf + ff_fuiz_patch
        unsafe { *(ff_fuiz_p as uint8) = ff_fuiz_disp }

        // rdi now points past integer digits; rcx = digit count
        // Update r10 and r11: r10 = rdi; r11 += rcx from int_len + 1 (for dot)
        // Actually: rdi - r10 = int_len (number of integer digits written)
        // r11 += rdi - old_r10; but we started rdi=old_r10 for int fmt
        // So int_len = rdi - old_r10
        // Save int_len as rcx (already have digit count in rcx for non-zero case)
        // Wait: for zero case, rcx=1 (but we jumped to ff_ui_done)
        // For non-zero: rcx=0 after pop_loop... no, after pop_loop rcx IS 0.
        // So we need int_len = new_rdi - old_rdi_start
        // Let's compute: sub rdi, r10; mov rcx, rdi; add r10, rcx; add r11, rcx
        // Wait: sub rdi, r10 = int_len (rdi moved forward by int_len)
        // Then: r10 = r10 + int_len = rdi; r11 = r11 + int_len
        // 49 29 FF (sub r15... no)
        // rdi - r10 = int_len; but we modified r11 based on start position
        // Let me recompute: rdi was set to r10 (old write pointer)
        // After fmt_uint, rdi = buf_start + int_len
        // r10 (old buf start for int fmt) = r10 (which we set from ir_resolve_src)
        // But r10 might have changed in the meantime... Actually we set r10 = ff_buf at start
        // and haven't changed it since. So r10 = buf_start.
        // int_len = rdi - r10
        // sub rdi, r10: 4C 29 D7 (REX.R=1 for r10=10, sub rdi,r10... let me think)
        // rdi=7, r10=10. sub rdi, r10: REX = 0x4C (REX.W=1, REX.R=1 for r10), 0x29, ModRM
        // ModRM for /r form: reg=r10 (10→001, extended by REX.R), r/m=rdi (7)
        // ModRM = 11 001 111 = 0xCF
        // Actually: SUB r/m64, r64 = 0x29 /r. Destination is rdi (r/m), source is r10 (reg).
        // REX.W + REX.R (for r10 being reg): 0x4C 0x29 0xCF? Let me check:
        // REX.W=1(bit3), REX.R=1(bit2 for reg extension), REX.B=0: REX = 0100 1100 = 0x4C
        // ModRM: mod=11, reg=r10&7=2, rm=rdi&7=7: 11 010 111 = 0xD7
        // So: 4C 29 D7 = sub rdi, r10. But wait, this overwrites rdi!
        // After this: rdi = int_len (we want this as rcx for updating r11)
        // mov rcx, rdi; add r11, rcx; add r10, rcx
        // Or: use separate approach
        // Let's save r10_start in r8 first
        // Hmm, this is getting messy. Let me simplify: use rdx for int_len

        // Rewrite approach: save old r10 in r8 before the fmt_uint section
        // ... This was already done when we set rdi=r10. So rdi at start of fmt = r10.
        // After fmt, rdi = r10 + int_len.
        // int_len = rdi - r10 = new_rdi - r10
        // But we've been using r10 as the "current write pointer" which we haven't updated yet.
        // After fmt_uint section, rdi points to buf + sign + int_len.
        // int_len = rdi - ff_buf - sign_offset. Complex.
        // Simplest: just update r10 = rdi after fmt, compute int_len = rcx for zero case,
        // or use rdi-r10 for non-zero.

        // Since we're writing, let's track: r10 was set to ff_buf at start (before sign).
        // After sign char write: r10 += sign_inc.
        // Then we set rdi = r10. After fmt_uint: rdi = r10 + int_len.
        // r11 = sign_offset. We need to add int_len to r11.
        // int_len = rdi - r10 = new_rdi - r10.
        // 4C 29 D7: sub rdi, r10 → rdi = int_len
        emit_byte(0x4C); emit_byte(0x29); emit_byte(0xD7)
        // Now rdi = int_len.
        // r11 += rdi: add r11, rdi = 49 01 FB (REX.B=1 for r11 as r/m, REX.R=0 for rdi)
        emit_byte(0x49); emit_byte(0x01); emit_byte(0xFB)
        // Restore rdi: add rdi, r10 → rdi = r10 + int_len (new write ptr)
        emit_byte(0x4C); emit_byte(0x01); emit_byte(0xD7)
        // r10 = rdi: mov r10, rdi = 49 89 FA
        emit_byte(0x49); emit_byte(0x89); emit_byte(0xFA)

        // Write '.': mov byte [r10], '.'  (0x2E); inc r10; inc r11
        emit_byte(0x41); emit_byte(0xC6); emit_byte(0x02); emit_byte(0x2E)
        emit_byte(0x49); emit_byte(0xFF); emit_byte(0xC2)   // inc r10
        emit_byte(0x49); emit_byte(0xFF); emit_byte(0xC3)   // inc r11

        // Restore xmm0 (abs val): pop rax; movq xmm0, rax
        emit_byte(0x58)  // pop rax (abs val that we pushed earlier)
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)

        // cvttsd2si rax, xmm0 (integer part again, to reconstruct int_f)
        emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2C); emit_byte(0xC0)
        // cvtsi2sd xmm1, rax (int_f): F2 48 0F 2A C8 (rax→xmm1)
        emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC8)
        // subsd xmm0, xmm1 (frac = abs_val - int_f): F2 0F 5C C1
        emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1)

        // Multiply by 1e6: load 1e6 = 0x412E848000000000 into xmm1 via push
        emit_byte(0x48); emit_byte(0xB8)
        // 1e6 LE bytes: 00 00 00 00 80 84 2E 41
        emit_byte(0x00); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)
        emit_byte(0x80); emit_byte(0x84); emit_byte(0x2E); emit_byte(0x41)
        emit_byte(0x50)  // push rax
        emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0x0C); emit_byte(0x24)  // movq xmm1, [rsp]
        emit_byte(0x58)  // pop rax
        // mulsd xmm0, xmm1: F2 0F 59 C1
        emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1)

        // cvttsd2si rax, xmm0 (frac_int): F2 48 0F 2C C0
        emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2C); emit_byte(0xC0)
        // rax = frac_int (0..999999)

        // Count digits of frac_int to determine zero-padding needed
        // We want: digits = number of decimal digits in rax
        // Then pad = max(0, 6 - digits)
        // For frac_int=0: digits=1 (special case), pad=5
        // Strategy: use r8 as digit count, rax for working value, rcx saves frac_int
        // Save frac_int in rcx (reg #1)
        emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)   // mov rcx, rax (frac_int)
        // xor r8, r8 (digit count = 0): 4D 31 C0
        emit_byte(0x4D); emit_byte(0x31); emit_byte(0xC0)
        // test rax, rax; jz .ff_frac_zero
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
        emit_byte(0x74)  // jz rel8
        uint64 ff_fz_patch = out_len
        emit_byte(0)
        // digit count loop: rax already holds frac_int; r9 = 10 (set earlier, still valid)
        // (r9 was set before integer formatting; reset it here to be safe)
        ir_emit_mov_r64_imm64(9, 10)   // r9 = 10
        uint64 ff_cnt_loop = out_len
        emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)  // xor rdx, rdx (clear for div)
        emit_byte(0x49); emit_byte(0xF7); emit_byte(0xF1)  // div r9 (rax=quot, rdx=rem)
        // inc r8 (digit count): 49 FF C0
        emit_byte(0x49); emit_byte(0xFF); emit_byte(0xC0)
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)  // test rax, rax
        emit_byte(0x75)  // jnz cnt_loop
        uint64 ff_cnt_jnz = out_len
        uint8 ff_cnt_disp = ff_cnt_loop - ff_cnt_jnz - 1
        uint64 ff_cnt_p = out_buf + ff_cnt_jnz
        emit_byte(0)
        unsafe { *(ff_cnt_p as uint8) = ff_cnt_disp }
        // r8 = digit count of frac_int
        emit_byte(0xEB)  // jmp .ff_have_digits
        uint64 ff_hd_patch = out_len
        emit_byte(0)

        // .ff_frac_zero: r8 = 1 (frac_int=0 still has 1 "digit")
        uint64 ff_fz = out_len
        uint8 ff_fz_disp = ff_fz - ff_fz_patch - 1
        uint64 ff_fz_p = out_buf + ff_fz_patch
        unsafe { *(ff_fz_p as uint8) = ff_fz_disp }
        // mov r8, 1: 49 C7 C0 01 00 00 00
        emit_byte(0x49); emit_byte(0xC7); emit_byte(0xC0); emit_byte(0x01); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)

        // .ff_have_digits:
        uint64 ff_hd = out_len
        uint8 ff_hd_disp = ff_hd - ff_hd_patch - 1
        uint64 ff_hd_p = out_buf + ff_hd_patch
        unsafe { *(ff_hd_p as uint8) = ff_hd_disp }

        // r8 = digit count. pad = 6 - r8 (if r8 < 6, else 0)
        // mov rax, 6; sub rax, r8
        emit_byte(0x48); emit_byte(0xC7); emit_byte(0xC0); emit_byte(0x06); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)
        // sub rax, r8: SUB r/m64, r64 = 0x29 /r; r8=reg(8&7=0,REX.R=1), rax=r/m(0,REX.B=0)
        // REX: W=1, R=1, X=0, B=0 = 0x4C; ModRM: mod=11, reg=r8&7=0, rm=rax&7=0 = 0xC0
        emit_byte(0x4C); emit_byte(0x29); emit_byte(0xC0)  // sub rax, r8
        // if rax < 0, set to 0 (cmp rax, 0; cmovl to 0)
        // Simpler: test rax, rax; jns have_pad; xor rax, rax
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
        emit_byte(0x79)  // jns rel8
        uint64 ff_pns_patch = out_len
        emit_byte(0)
        emit_byte(0x48); emit_byte(0x31); emit_byte(0xC0)  // xor rax, rax
        uint64 ff_pns = out_len
        uint8 ff_pns_disp = ff_pns - ff_pns_patch - 1
        uint64 ff_pns_p = out_buf + ff_pns_patch
        unsafe { *(ff_pns_p as uint8) = ff_pns_disp }

        // rax = pad. Write pad zeros to [r10]:
        // test rax, rax; jz .ff_no_pad
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
        emit_byte(0x74)  // jz rel8
        uint64 ff_np_patch = out_len
        emit_byte(0)
        // pad_loop: mov byte [r10], '0'; inc r10; inc r11; dec rax; jnz pad_loop
        uint64 ff_pad_loop = out_len
        emit_byte(0x41); emit_byte(0xC6); emit_byte(0x02); emit_byte(0x30)  // mov byte [r10], '0'
        emit_byte(0x49); emit_byte(0xFF); emit_byte(0xC2)   // inc r10
        emit_byte(0x49); emit_byte(0xFF); emit_byte(0xC3)   // inc r11
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC8)   // dec rax
        emit_byte(0x75)  // jnz pad_loop
        uint64 ff_pad_jnz = out_len
        uint8 ff_pad_disp = ff_pad_loop - ff_pad_jnz - 1
        uint64 ff_pad_p = out_buf + ff_pad_jnz
        emit_byte(0)
        unsafe { *(ff_pad_p as uint8) = ff_pad_disp }

        // .ff_no_pad:
        uint64 ff_np = out_len
        uint8 ff_np_disp = ff_np - ff_np_patch - 1
        uint64 ff_np_p = out_buf + ff_np_patch
        unsafe { *(ff_np_p as uint8) = ff_np_disp }

        // Now format frac_int (still in rcx) via divide-by-10 loop into [r10]
        ir_emit_mov_r64_r64(7, 10)   // rdi = r10
        ir_emit_mov_r64_r64(0, 1)    // rax = rcx (frac_int)
        // Handle zero: test rax, rax; jnz .ff_fi_nonzero
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
        emit_byte(0x75)  // jnz rel8
        uint64 ff_finz_patch = out_len
        emit_byte(0)
        // zero: mov byte [rdi], '0'; inc rdi; jmp .ff_fi_done
        emit_byte(0xC6); emit_byte(0x07); emit_byte(0x30)
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC7)
        emit_byte(0xEB)
        uint64 ff_fiz_patch = out_len
        emit_byte(0)

        // .ff_fi_nonzero:
        uint64 ff_finz = out_len
        uint8 ff_finz_disp = ff_finz - ff_finz_patch - 1
        uint64 ff_finz_p = out_buf + ff_finz_patch
        unsafe { *(ff_finz_p as uint8) = ff_finz_disp }

        // xor rcx2, rcx2 (digit count for frac)
        emit_byte(0x48); emit_byte(0x31); emit_byte(0xC9)
        ir_emit_mov_r64_imm64(9, 10)   // r9 = 10
        uint64 ff_fi_loop = out_len
        emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)
        emit_byte(0x49); emit_byte(0xF7); emit_byte(0xF1)   // div r9
        emit_byte(0x80); emit_byte(0xC2); emit_byte(0x30)   // add dl, '0'
        emit_byte(0x52)  // push rdx
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC1)   // inc rcx
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)   // test rax, rax
        emit_byte(0x75)  // jnz ff_fi_loop
        uint64 ff_fi_jnz = out_len
        uint8 ff_fi_jnz_disp = ff_fi_loop - ff_fi_jnz - 1
        uint64 ff_fi_jnz_p = out_buf + ff_fi_jnz
        emit_byte(0)
        unsafe { *(ff_fi_jnz_p as uint8) = ff_fi_jnz_disp }

        // pop and write digits
        uint64 ff_fi_pop_loop = out_len
        emit_byte(0x5A)  // pop rdx
        emit_byte(0x88); emit_byte(0x17)   // mov [rdi], dl
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC7)   // inc rdi
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC9)   // dec rcx
        emit_byte(0x75)  // jnz pop
        uint64 ff_fi_pop_jnz = out_len
        uint8 ff_fi_pop_disp = ff_fi_pop_loop - ff_fi_pop_jnz - 1
        uint64 ff_fi_pop_p = out_buf + ff_fi_pop_jnz
        emit_byte(0)
        unsafe { *(ff_fi_pop_p as uint8) = ff_fi_pop_disp }

        // .ff_fi_done:
        uint64 ff_fi_done = out_len
        uint8 ff_fiz_disp = ff_fi_done - ff_fiz_patch - 1
        uint64 ff_fiz_p = out_buf + ff_fiz_patch
        unsafe { *(ff_fiz_p as uint8) = ff_fiz_disp }

        // Update r11 with frac digits: frac_len = rdi - r10
        emit_byte(0x4C); emit_byte(0x29); emit_byte(0xD7)  // sub rdi, r10
        emit_byte(0x49); emit_byte(0x01); emit_byte(0xFB)  // add r11, rdi (REX.B=1 for r11)
        // Update r10 = old_r10 + frac_len = original write ptr no longer needed

        // Final length: r11 holds total length
        // mov rax, r11: 4C 89 D8
        emit_byte(0x4C); emit_byte(0x89); emit_byte(0xD8)

        // Jump over big/error path (if we reach here normally):
        emit_byte(0xEB)
        uint64 ff_end_patch = out_len
        emit_byte(0)

        // .ff_big: write "big"
        uint64 ff_big = out_len
        // Patch jae rel32: 4-byte displacement from end of instruction
        uint64 ff_jae_disp32 = ff_big - ff_jae_patch - 4
        uint64 ff_jae_p = out_buf + ff_jae_patch
        uint8 ff_jae_b0 = ff_jae_disp32
        uint64 ff_jae_p1 = out_buf + ff_jae_patch + 1
        uint8 ff_jae_b1 = ff_jae_disp32 / 256
        uint64 ff_jae_p2 = out_buf + ff_jae_patch + 2
        uint8 ff_jae_b2 = ff_jae_disp32 / 65536
        uint64 ff_jae_p3 = out_buf + ff_jae_patch + 3
        uint8 ff_jae_b3 = ff_jae_disp32 / 16777216
        unsafe { *(ff_jae_p as uint8) = ff_jae_b0 }
        unsafe { *(ff_jae_p1 as uint8) = ff_jae_b1 }
        unsafe { *(ff_jae_p2 as uint8) = ff_jae_b2 }
        unsafe { *(ff_jae_p3 as uint8) = ff_jae_b3 }

        // mov byte [r10], 'b' (0x62)
        emit_byte(0x41); emit_byte(0xC6); emit_byte(0x02); emit_byte(0x62)
        // mov byte [r10+1], 'i' (0x69)
        emit_byte(0x41); emit_byte(0xC6); emit_byte(0x42); emit_byte(0x01); emit_byte(0x69)
        // mov byte [r10+2], 'g' (0x67)
        emit_byte(0x41); emit_byte(0xC6); emit_byte(0x42); emit_byte(0x02); emit_byte(0x67)
        // r11 += 3: add r11, 3 (49 83 C3 03)
        emit_byte(0x49); emit_byte(0x83); emit_byte(0xC3); emit_byte(0x03)
        // mov rax, r11
        emit_byte(0x4C); emit_byte(0x89); emit_byte(0xD8)

        // .ff_end:
        uint64 ff_end = out_len
        uint8 ff_end_disp = ff_end - ff_end_patch - 1
        uint64 ff_end_p = out_buf + ff_end_patch
        unsafe { *(ff_end_p as uint8) = ff_end_disp }

        // rax = total length
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 40 {
        // IR_BR: handled in block emission
        return
    }
    if op == 41 {
        // IR_BR_COND: handled in block emission
        return
    }
}

// ---------------------------------------------------------------------------
// Block and function emitters
// ---------------------------------------------------------------------------

// Block start offsets for branch patching
static uint64 ir_block_offsets = 0
static uint64 ir_block_offsets_cap = 0

// Branch fixup list: [patch_offset(4), target_bb(4)] x 1024
static uint64 ir_br_fixups = 0
static uint64 ir_br_fixups_cap = 0
static uint64 ir_br_fixup_count = 0

// Return fixup list: patch offsets for jmp-to-epilogue, patched after all blocks
static uint64 ir_ret_fixups = 0
static uint64 ir_ret_fixups_cap = 0
static uint64 ir_ret_fixup_count = 0

// Overflow argument buffer for calls with 7+ args (SysV ABI)
static uint64 ir_overflow_args = 0
static uint64 ir_overflow_arg_count = 0

// Frame size for current function (used by overflow param loads)
static uint64 ir_frame_size = 0

// Fixed-size local arrays (`uint64[N] x` inside a fn body) get stack
// storage instead of a per-call IR_ALLOC (which is a heap / mmap call
// and ran ~2 µs per invocation when used in hot scratch patterns).
// Each array bumps `ir_stack_array_bytes` during lowering and records
// a relative offset inside the function's stack-array region; the
// region sits above the spill slots in the prologue's frame.
static uint64 ir_stack_array_bytes = 0

// ---------------------------------------------------------------------------
// IR optimization passes
// ---------------------------------------------------------------------------

@export
static uint64 ir_opt_level = 1

static uint64 ir_const_values = 0    // vreg -> constant value
static uint64 ir_const_known = 0     // vreg -> 1 if constant is known

// Per-vreg flag: is this vreg's value provably ≤ 0xFFFFFFFF (i.e., upper
// 32 bits known zero)? Set conservatively forward through the IR by
// ir_opt_const_fold based on the operation that produced the vreg.
// Used to elide `& 0xFFFFFFFF` masks whose source is already 32-bit
// clean — common in SHA-256 and similar 32-bit-style code that runs on
// the 64-bit IR.
static uint64 ir_w32_clean = 0

fn ir_opt_const_fold() {
    uint64 ii = 0
    uint64 cur_bb = 0xFFFFFFFF
    while ii < ir_insn_count {
        uint64 op = ir_insn_opcode(ii)
        if op == 0 { ii = ii + 1; continue }

        // Flow-insensitive: clear constant tracking at every BB boundary.
        // A vreg defined in one BB cannot be safely treated as constant at
        // uses in another BB (loop-carried values, merge points, etc.).
        uint64 bb = ir_insn_bb(ii)
        if bb != cur_bb {
            memset(ir_const_known, 0, 65536)
            cur_bb = bb
        }

        uint64 dest = ir_insn_dest(ii)
        uint64 s1 = ir_insn_src1(ii)
        uint64 s2 = ir_insn_src2(ii)
        uint64 imm = ir_insn_imm(ii)

        // IR_CONST: record dest as a known constant
        if op == 1 {
            if dest > 0 && dest < 65536 {
                uint64 p = ir_const_values + dest * 8
                unsafe { *(p as uint64) = imm }
                uint64 k = ir_const_known + dest
                uint8 one = 1
                unsafe { *(k as uint8) = one }
                // Constants with imm ≤ 0xFFFFFFFF are w32-clean.
                if imm <= 0xFFFFFFFF {
                    uint64 wp = ir_w32_clean + dest
                    uint8 wone = 1
                    unsafe { *(wp as uint8) = wone }
                }
            }
            ii = ii + 1
            continue
        }

        // Load known-ness of each source
        uint64 s1_known = 0
        uint64 s2_known = 0
        uint64 v1 = 0
        uint64 v2 = 0
        if s1 > 0 && s1 < 65536 {
            uint64 k1 = ir_const_known + s1
            uint8 kv1 = 0
            unsafe { *(k1 as uint8) -> kv1 }
            s1_known = kv1
            if s1_known != 0 {
                uint64 p1 = ir_const_values + s1 * 8
                unsafe { *(p1 as uint64) -> v1 }
            }
        }
        if s2 > 0 && s2 < 65536 {
            uint64 k2 = ir_const_known + s2
            uint8 kv2 = 0
            unsafe { *(k2 as uint8) -> kv2 }
            s2_known = kv2
            if s2_known != 0 {
                uint64 p2 = ir_const_values + s2 * 8
                unsafe { *(p2 as uint64) -> v2 }
            }
        }

        // COPY propagation: if src is constant, mark dest as known too
        if op == 61 {
            if s1_known != 0 && dest > 0 && dest < 65536 {
                uint64 p = ir_const_values + dest * 8
                unsafe { *(p as uint64) = v1 }
                uint64 k = ir_const_known + dest
                uint8 one = 1
                unsafe { *(k as uint8) = one }
            }
            // w32-clean propagates through copy.
            if dest > 0 && dest < 65536 && s1 > 0 && s1 < 65536 {
                uint64 sp = ir_w32_clean + s1
                uint8 sv = 0
                unsafe { *(sp as uint8) -> sv }
                if sv != 0 {
                    uint64 dp = ir_w32_clean + dest
                    uint8 one2 = 1
                    unsafe { *(dp as uint8) = one2 }
                }
            }
            ii = ii + 1
            continue
        }

        // Read source w32-clean flags. A source is also "effectively
        // w32-clean" if it's a known constant ≤ 0xFFFFFFFF.
        uint64 s1_w32 = 0
        uint64 s2_w32 = 0
        if s1 > 0 && s1 < 65536 {
            uint64 sp = ir_w32_clean + s1
            uint8 sv = 0
            unsafe { *(sp as uint8) -> sv }
            s1_w32 = sv
        }
        if s1_known != 0 && v1 <= 0xFFFFFFFF { s1_w32 = 1 }
        if s2 > 0 && s2 < 65536 {
            uint64 sp = ir_w32_clean + s2
            uint8 sv = 0
            unsafe { *(sp as uint8) -> sv }
            s2_w32 = sv
        }
        if s2_known != 0 && v2 <= 0xFFFFFFFF { s2_w32 = 1 }

        // Mask elimination: AND(x, 0xFFFFFFFF) where x is w32-clean is a
        // no-op — replace with COPY. Each per-iteration AND in sha-256
        // is 7 bytes (REX.W + 0x21 + ModRM, or REX.W + 0x81 /4 imm32),
        // so eliminating one per round across millions of rounds is
        // measurable. The mask must be exactly 0xFFFFFFFF (or wider but
        // with all-ones in the low 32 bits — only 0xFFFFFFFF appears in
        // practice, so be conservative).
        if op == 7 && s2_known != 0 && v2 == 0xFFFFFFFF && s1_w32 != 0 {
            ir_insn_set_opcode(ii, 61)        // → IR_COPY
            ir_insn_set_src2(ii, 0)
            ir_insn_set_imm(ii, 0)
            // Result is w32-clean (it's a copy of a w32-clean source).
            if dest > 0 && dest < 65536 {
                uint64 dp = ir_w32_clean + dest
                uint8 one3 = 1
                unsafe { *(dp as uint8) = one3 }
            }
            ii = ii + 1
            continue
        }

        // Branch simplification: if the condition of a BR_COND is a known
        // constant, one side is unreachable. Rewrite to an unconditional BR.
        // BR_COND encodes its true target in imm and its false target in the
        // block's succ0 (the emitter reads it that way), so we pick the
        // surviving target accordingly. The block's CFG successors remain
        // as set by lowering; liveness over-approximates but stays correct.
        if op == 41 && s1_known != 0 {
            if v1 != 0 {
                // True path survives: target is already in imm
                ir_insn_set_opcode(ii, 40)
                ir_insn_set_src1(ii, 0)
            } else {
                // False path survives: target is succ0 of the owning BB
                uint64 owning_bb = ir_insn_bb(ii)
                uint64 false_target = ir_bb_succ0(owning_bb)
                ir_insn_set_opcode(ii, 40)
                ir_insn_set_src1(ii, 0)
                ir_insn_set_imm(ii, false_target)
            }
            ii = ii + 1
            continue
        }

        // Fold binary op when both sources are known
        uint64 folded = 0
        uint64 result = 0
        if s1_known != 0 && s2_known != 0 {
            if op == 2 { result = v1 + v2; folded = 1 }
            if op == 3 { result = v1 - v2; folded = 1 }
            if op == 4 { result = v1 * v2; folded = 1 }
            if op == 5 {
                if v2 != 0 { result = v1 / v2; folded = 1 }
            }
            if op == 6 {
                if v2 != 0 { result = v1 % v2; folded = 1 }
            }
            if op == 7 { result = v1 & v2; folded = 1 }
            if op == 8 { result = v1 | v2; folded = 1 }
            if op == 9 { result = v1 ^ v2; folded = 1 }
            if op == 10 { result = v1 << v2; folded = 1 }
            if op == 11 { result = v1 >> v2; folded = 1 }
            if op == 14 {
                if v1 == v2 { result = 1 } else { result = 0 }
                folded = 1
            }
            if op == 15 {
                if v1 != v2 { result = 1 } else { result = 0 }
                folded = 1
            }
            if op == 16 {
                if v1 < v2 { result = 1 } else { result = 0 }
                folded = 1
            }
            if op == 17 {
                if v1 <= v2 { result = 1 } else { result = 0 }
                folded = 1
            }
            if op == 18 {
                if v1 > v2 { result = 1 } else { result = 0 }
                folded = 1
            }
            if op == 19 {
                if v1 >= v2 { result = 1 } else { result = 0 }
                folded = 1
            }
        }

        if folded != 0 {
            ir_insn_set_opcode(ii, 1)
            ir_insn_set_src1(ii, 0)
            ir_insn_set_src2(ii, 0)
            ir_insn_set_imm(ii, result)
            if dest > 0 && dest < 65536 {
                uint64 p = ir_const_values + dest * 8
                unsafe { *(p as uint64) = result }
                uint64 k = ir_const_known + dest
                uint8 one = 1
                unsafe { *(k as uint8) = one }
            }
            ii = ii + 1
            continue
        }

        // CMP/SCMP with constant src2 → encode the immediate in the
        // insn's imm field and zero src2 (sentinel for imm-mode at
        // codegen). x86-only: ARM64 codegen still expects src2 to be a
        // vreg. x86 has `cmp r/m64, imm8` (4 bytes) and
        // `cmp r/m64, imm32` (7 bytes), both shorter than the current
        // `mov r12d, imm; cmp rbx, r12` (6 + 3 = 9 bytes). For imm == 0
        // the codegen swaps to the even shorter `test r, r` (3 bytes).
        if target_arch == 0 && ((op >= 14 && op <= 19) || (op >= 120 && op <= 123)) {
            if s2_known != 0 {
                uint64 fits = 0
                if v2 <= 0x7FFFFFFF { fits = 1 }
                if v2 >= 0xFFFFFFFF80000000 { fits = 1 }
                if fits != 0 {
                    ir_insn_set_src2(ii, 0)
                    ir_insn_set_imm(ii, v2)
                    // Don't `continue` — fall through so dest's w32-clean
                    // and other propagation still happens.
                }
            }
        }

        // IMUL-by-immediate fusion: `t = a * c` where c is a known
        // constant fitting in signed 32-bit → IR_MUL_IMM. x86's
        // three-operand `imul r64, r/m64, imm32` doesn't need the
        // constant in a register, eliminating one IR_CONST + a likely
        // spill round-trip per scaled-address computation. The matmul
        // inner loop alone has 4+ such scalings per iteration. Skip
        // c == 0 (already turned into CONST 0 by the zero-rule
        // earlier) and c == 1 (turned into COPY).
        if target_arch == 0 && op == 4 && s2_known != 0 && v2 != 0 && v2 != 1 {
            uint64 fits = 0
            if v2 <= 0x7FFFFFFF { fits = 1 }
            if v2 >= 0xFFFFFFFF80000000 { fits = 1 }
            if fits != 0 {
                ir_insn_set_opcode(ii, 138)   // IR_MUL_IMM
                ir_insn_set_src2(ii, 0)
                ir_insn_set_imm(ii, v2)
                ii = ii + 1
                continue
            }
        }

        // LEA fusion: ADD/SUB with a constant src2 → IR_ADD_IMM/IR_SUB_IMM.
        // x86-only — ARM64 already lowers small-imm arithmetic efficiently
        // via emit_a64_add (reg-reg) after the IR_CONST loads into a reg,
        // and `add Xd, Xn, #imm` doesn't shorten the same way LEA does on
        // x86. The constant must fit in signed 32-bit because LEA's
        // displacement is sign-extended from 32 bits. v2 is uint64; check
        // both representations (positive ≤ 0x7FFFFFFF or negative ≥
        // 0xFFFFFFFF80000000). Skip v2==0 since `x ± 0` should be a copy,
        // and our LEA emitter assumes disp != 0 (to avoid the
        // RIP-relative encoding collision when src is rbp/r13).
        if target_arch == 0 && (op == 2 || op == 3) && s2_known != 0 && v2 != 0 {
            uint64 fits = 0
            if v2 <= 0x7FFFFFFF { fits = 1 }
            if v2 >= 0xFFFFFFFF80000000 { fits = 1 }
            if fits != 0 {
                uint64 new_op = 135      // IR_ADD_IMM
                if op == 3 { new_op = 136 }  // IR_SUB_IMM
                ir_insn_set_opcode(ii, new_op)
                ir_insn_set_src2(ii, 0)
                ir_insn_set_imm(ii, v2)
                ii = ii + 1
                continue
            }
        }

        // Fold unary NEG (op 12)
        if op == 12 && s1_known != 0 {
            uint64 nresult = 0 - v1
            ir_insn_set_opcode(ii, 1)
            ir_insn_set_src1(ii, 0)
            ir_insn_set_imm(ii, nresult)
            if dest > 0 && dest < 65536 {
                uint64 p = ir_const_values + dest * 8
                unsafe { *(p as uint64) = nresult }
                uint64 k = ir_const_known + dest
                uint8 one = 1
                unsafe { *(k as uint8) = one }
            }
            ii = ii + 1
            continue
        }

        // Fold unary NOT (op 13) — two's complement ~x = x XOR ~0
        if op == 13 && s1_known != 0 {
            uint64 all_ones = 0 - 1
            uint64 nresult = v1 ^ all_ones
            ir_insn_set_opcode(ii, 1)
            ir_insn_set_src1(ii, 0)
            ir_insn_set_imm(ii, nresult)
            if dest > 0 && dest < 65536 {
                uint64 p = ir_const_values + dest * 8
                unsafe { *(p as uint64) = nresult }
                uint64 k = ir_const_known + dest
                uint8 one = 1
                unsafe { *(k as uint8) = one }
            }
            ii = ii + 1
            continue
        }

        // MUL(x, 0) or AND(x, 0) -> CONST 0
        if s2_known != 0 && v2 == 0 {
            if op == 4 || op == 7 {
                ir_insn_set_opcode(ii, 1)
                ir_insn_set_src1(ii, 0)
                ir_insn_set_src2(ii, 0)
                ir_insn_set_imm(ii, 0)
                if dest > 0 && dest < 65536 {
                    uint64 p = ir_const_values + dest * 8
                    unsafe { *(p as uint64) = 0 }
                    uint64 k = ir_const_known + dest
                    uint8 one = 1
                    unsafe { *(k as uint8) = one }
                }
                ii = ii + 1
                continue
            }
        }
        // MUL(0, x) or AND(0, x) -> CONST 0 (commutative)
        if s1_known != 0 && v1 == 0 {
            if op == 4 || op == 7 {
                ir_insn_set_opcode(ii, 1)
                ir_insn_set_src1(ii, 0)
                ir_insn_set_src2(ii, 0)
                ir_insn_set_imm(ii, 0)
                if dest > 0 && dest < 65536 {
                    uint64 p = ir_const_values + dest * 8
                    unsafe { *(p as uint64) = 0 }
                    uint64 k = ir_const_known + dest
                    uint8 one = 1
                    unsafe { *(k as uint8) = one }
                }
                ii = ii + 1
                continue
            }
        }

        // Identities that simplify to COPY of src1:
        //   ADD(x, 0), SUB(x, 0), OR(x, 0), XOR(x, 0), SHL(x, 0), SHR(x, 0)
        if s2_known != 0 && v2 == 0 {
            if op == 2 || op == 3 || op == 8 || op == 9 || op == 10 || op == 11 {
                ir_insn_set_opcode(ii, 61)
                ir_insn_set_src2(ii, 0)
                ii = ii + 1
                continue
            }
        }
        // MUL(x, 1) or DIV(x, 1) -> COPY x
        if s2_known != 0 && v2 == 1 {
            if op == 4 || op == 5 {
                ir_insn_set_opcode(ii, 61)
                ir_insn_set_src2(ii, 0)
                ii = ii + 1
                continue
            }
        }
        // AND(x, ~0) -> COPY x
        if op == 7 && s2_known != 0 {
            uint64 all_ones = 0 - 1
            if v2 == all_ones {
                ir_insn_set_opcode(ii, 61)
                ir_insn_set_src2(ii, 0)
                ii = ii + 1
                continue
            }
        }

        // Commutative forms where the constant is on the left:
        //   ADD(0, x), OR(0, x), XOR(0, x) -> COPY x  (set src1<-src2, drop src2)
        //   MUL(1, x), AND(~0, x)          -> COPY x
        if s1_known != 0 {
            uint64 as_copy = 0
            if v1 == 0 && (op == 2 || op == 8 || op == 9) { as_copy = 1 }
            if v1 == 1 && op == 4 { as_copy = 1 }
            if op == 7 {
                uint64 all_ones1 = 0 - 1
                if v1 == all_ones1 { as_copy = 1 }
            }
            if as_copy != 0 {
                ir_insn_set_opcode(ii, 61)
                ir_insn_set_src1(ii, s2)
                ir_insn_set_src2(ii, 0)
                ii = ii + 1
                continue
            }
        }

        // Propagate w32-clean to dest based on the surviving op. Only
        // operations that provably keep the result ≤ 0xFFFFFFFF mark
        // their dest. Conservative defaults (ADD/SUB/MUL/SHL) leave the
        // dest as not-clean since carry/overflow can spill.
        if dest > 0 && dest < 65536 {
            uint64 mark = 0
            // AND: result ≤ min(s1, s2). Either side being w32-clean
            // clamps the result to fit in 32 bits.
            if op == 7 && (s1_w32 != 0 || s2_w32 != 0) { mark = 1 }
            // OR/XOR: result has bits only where either operand has bits.
            // Both must be w32-clean.
            if (op == 8 || op == 9) && s1_w32 != 0 && s2_w32 != 0 { mark = 1 }
            // Logical right shift: zero-fills the top, so SHR of a
            // w32-clean source stays w32-clean. Also, SHR by ≥ 32 of
            // any 64-bit value fits in 32 bits.
            if op == 11 {
                if s1_w32 != 0 { mark = 1 }
                if s2_known != 0 && v2 >= 32 { mark = 1 }
            }
            // 1/2/4-byte LOAD zero-extends. imm carries the load width
            // for simple loads (struct-field loads put the size in src2
            // and leave imm=0, which we conservatively skip).
            if op == 30 {
                if imm == 1 || imm == 2 || imm == 4 { mark = 1 }
            }
            // IR_ROR with width=32 emits a 32-bit ROR which auto-zeros
            // the upper 32 bits.
            if op == 137 && imm == 32 { mark = 1 }
            if mark != 0 {
                uint64 dp = ir_w32_clean + dest
                uint8 one4 = 1
                unsafe { *(dp as uint8) = one4 }
            }
        }

        ii = ii + 1
    }
}

static uint64 ir_dce_live = 0

// Returns 1 if the instruction must be kept regardless of whether its dest is
// live — side effects, control flow, memory writes, volatile/atomic reads, and
// anything externally observable.
fn ir_opt_is_side_effect(uint64 op) -> uint64 {
    if op == 31 { return 1 }   // STORE
    if op == 40 { return 1 }   // BR
    if op == 41 { return 1 }   // BR_COND
    if op == 42 { return 1 }   // RET
    if op == 43 { return 1 }   // RET_VOID
    if op == 50 { return 1 }   // CALL
    if op == 51 { return 1 }   // ARG
    if op == 52 { return 1 }   // SYSCALL
    if op == 70 { return 1 }   // ALLOC
    if op == 71 { return 1 }   // DEALLOC
    if op == 72 { return 1 }   // MEMCPY
    if op == 76 { return 1 }   // MEMSET
    if op == 78 { return 1 }   // STATIC_STORE
    if op == 80 { return 1 }   // EXTRACT_RDX (must stay adjacent to CALL)
    if op == 81 { return 1 }   // EXTRACT_R8
    if op == 82 { return 1 }   // RET2
    if op == 83 { return 1 }   // RET3
    if op == 85 { return 1 }   // SYSCALL_RAW
    if op == 87 { return 1 }   // CALL_IND
    if op >= 90 && op <= 96 { return 1 }    // atomics, vstore/vload, asm
    if op >= 109 && op <= 115 { return 1 }  // atomic RMW, exec, set_exec
    if op == 119 { return 1 }  // TIME_NS (reads clock, not pure)
    if op == 126 { return 1 }  // ISB (synchronization barrier)
    if op == 127 { return 1 }  // DCACHE_FLUSH (cache maintenance)
    if op == 128 { return 1 }  // ICACHE_INV (cache maintenance)
    if op == 129 { return 1 }  // DSB (synchronization barrier)
    if op == 130 { return 1 }  // DMB (synchronization barrier)
    if op == 131 { return 1 }  // ARR_CHECK (traps, must not be DCE'd)
    return 0
}

fn ir_opt_dce_mark(uint64 vreg, uint64 changed_ptr) -> uint64 {
    uint64 c = 0
    uint64 cp = changed_ptr
    unsafe { *(cp as uint64) -> c }
    if vreg > 0 && vreg < 65536 {
        uint64 lp = ir_dce_live + vreg
        uint8 old = 0
        unsafe { *(lp as uint8) -> old }
        if old == 0 {
            uint8 one = 1
            unsafe { *(lp as uint8) = one }
            c = 1
            unsafe { *(cp as uint64) = c }
        }
    }
    return c
}

fn ir_opt_dce() {
    if ir_dce_live == 0 { ir_dce_live = alloc(65536) }
    memset(ir_dce_live, 0, 65536)

    // Mark phase: iterate forward over instructions, marking live vregs.
    // Because marks only propagate from dest-is-live to src-must-be-live, and
    // a use may come before its def in linear order inside a loop, we iterate
    // to a fixed point. Live set only grows — terminates in O(vregs) rounds.
    uint64 changed = 1
    uint64 changed_ptr = alloc(8)
    while changed != 0 {
        changed = 0
        unsafe { *(changed_ptr as uint64) = changed }

        uint64 ii = 0
        while ii < ir_insn_count {
            uint64 op = ir_insn_opcode(ii)
            if op == 0 { ii = ii + 1; continue }

            uint64 dest = ir_insn_dest(ii)
            uint64 s1 = ir_insn_src1(ii)
            uint64 s2 = ir_insn_src2(ii)
            uint64 imm = ir_insn_imm(ii)

            uint64 keep = ir_opt_is_side_effect(op)
            if keep == 0 && dest > 0 && dest < 65536 {
                uint64 lp = ir_dce_live + dest
                uint8 lv = 0
                unsafe { *(lp as uint8) -> lv }
                if lv != 0 { keep = 1 }
            }

            if keep != 0 {
                ir_opt_dce_mark(s1, changed_ptr)
                // src2 is a vreg for all ops EXCEPT the ones below.
                // Add IR_ADD_IMM(135) / IR_SUB_IMM(136) — they encode the
                // displacement in imm and don't use src2.
                if op != 1 && op != 12 && op != 13 && op != 30 && op != 42 && op != 61 && op != 135 && op != 136 && op != 138 {
                    ir_opt_dce_mark(s2, changed_ptr)
                }
                // imm-as-vreg for MEMCPY, MEMSET, RET3, ATOMIC_CAS, FFMA
                if op == 72 || op == 76 || op == 83 || op == 93 || op == 98 {
                    ir_opt_dce_mark(imm, changed_ptr)
                }
            }

            ii = ii + 1
        }

        unsafe { *(changed_ptr as uint64) -> changed }
    }
    dealloc(changed_ptr)

    // Sweep phase: NOP-out instructions whose dest is not live and which have
    // no side effects. We leave the BB linked list intact; the emitters treat
    // opcode==0 as a no-op (no bytes emitted). Terminators are always kept
    // via ir_opt_is_side_effect, so BB structure is preserved.
    uint64 si = 0
    while si < ir_insn_count {
        uint64 op = ir_insn_opcode(si)
        if op == 0 { si = si + 1; continue }
        if ir_opt_is_side_effect(op) == 0 {
            uint64 dest = ir_insn_dest(si)
            uint64 is_live = 0
            if dest > 0 && dest < 65536 {
                uint64 lp = ir_dce_live + dest
                uint8 lv = 0
                unsafe { *(lp as uint8) -> lv }
                is_live = lv
            }
            if is_live == 0 {
                ir_insn_set_opcode(si, 0)
            }
        }
        si = si + 1
    }
}

// ---------------------------------------------------------------------------
// Pass 3: common subexpression elimination (intra-basic-block, hash-based)
//
// Each entry in ir_cse_table is 40 bytes: op(8), s1(8), s2(8), imm(8), dest(8).
// When we encounter a pure instruction whose (op,s1,s2,imm) tuple matches an
// earlier entry in the same BB, we rewrite the instruction into
// IR_COPY<earlier_dest>. The table is cleared at BB boundaries and on any op
// that could change memory or mutate an existing vreg's meaning (including
// COPY itself — COPY overwrites its destination vreg, so cached expressions
// whose operands reference that vreg may no longer be valid).
// ---------------------------------------------------------------------------

static uint64 ir_cse_table = 0
static uint64 ir_cse_canon = 0   // per-BB canon[vreg] → canonical source vreg

fn ir_cse_hash(uint64 op, uint64 s1, uint64 s2, uint64 imm) -> uint64 {
    uint64 h = op * 2654435761
    h = h ^ (s1 * 2246822519)
    h = h ^ (s2 * 3266489917)
    h = h ^ (imm * 668265263)
    return h & 4095
}

// Canon map: canon[v] = the canonical vreg v aliases to. A cell of 0 means
// the entry is uninitialised, in which case v is its own canonical form. This
// lets IR_COPY be handled cleanly (it updates canon but no longer needs to
// invalidate the hash table), and lets chained copies collapse to one source
// so redundant expressions over aliased vregs still match.
fn ir_cse_canon_of(uint64 v) -> uint64 {
    if v == 0 { return 0 }
    if v >= 65536 { return v }
    uint64 p = ir_cse_canon + v * 4
    uint32 c = 0
    unsafe { *(p as uint32) -> c }
    if c == 0 { return v }
    return c
}

fn ir_cse_canon_set(uint64 dest, uint64 canonical) {
    if dest == 0 { return }
    if dest >= 65536 { return }
    uint64 p = ir_cse_canon + dest * 4
    uint32 c = canonical
    unsafe { *(p as uint32) = c }
}

fn ir_opt_cse_invalidates(uint64 op) -> uint64 {
    if op == 31 { return 1 }  // STORE
    if op == 50 { return 1 }  // CALL
    if op == 52 { return 1 }  // SYSCALL
    if op == 72 { return 1 }  // MEMCPY
    if op == 76 { return 1 }  // MEMSET
    if op == 78 { return 1 }  // STATIC_STORE
    if op == 85 { return 1 }  // SYSCALL_RAW
    if op == 87 { return 1 }  // CALL_IND
    if op >= 90 && op <= 96 { return 1 }    // atomics, vstore/vload, asm
    if op >= 109 && op <= 115 { return 1 }  // atomic RMW, exec, set_exec
    return 0
}

fn ir_opt_cse_is_pure(uint64 op) -> uint64 {
    if op >= 1 && op <= 19 { return 1 }    // const, arith, logic, cmp
    if op >= 20 && op <= 27 { return 1 }   // float arith + conv
    if op >= 97 && op <= 108 { return 1 }  // float ops
    if op >= 120 && op <= 123 { return 1 } // signed cmp
    if op == 77 { return 1 }  // static_load
    if op == 79 { return 1 }  // str_const
    if op == 84 { return 1 }  // static_addr
    if op == 86 { return 1 }  // fn_addr
    return 0
}

fn ir_opt_cse() {
    if ir_cse_table == 0 { ir_cse_table = alloc(4096 * 40) }
    if ir_cse_canon == 0 { ir_cse_canon = alloc(65536 * 4) }
    memset(ir_cse_table, 0, 4096 * 40)
    memset(ir_cse_canon, 0, 65536 * 4)

    uint64 cur_bb = 0xFFFFFFFF

    uint64 ii = 0
    while ii < ir_insn_count {
        uint64 op = ir_insn_opcode(ii)
        if op == 0 { ii = ii + 1; continue }

        uint64 bb = ir_insn_bb(ii)
        if bb != cur_bb {
            memset(ir_cse_table, 0, 4096 * 40)
            memset(ir_cse_canon, 0, 65536 * 4)
            cur_bb = bb
        }

        // IR_COPY: update canon, don't touch the hash table.
        if op == 61 {
            uint64 cd = ir_insn_dest(ii)
            uint64 cs = ir_cse_canon_of(ir_insn_src1(ii))
            ir_cse_canon_set(cd, cs)
            ii = ii + 1
            continue
        }

        if ir_opt_cse_invalidates(op) != 0 {
            memset(ir_cse_table, 0, 4096 * 40)
            memset(ir_cse_canon, 0, 65536 * 4)
            ii = ii + 1
            continue
        }

        if ir_opt_cse_is_pure(op) == 0 {
            ii = ii + 1
            continue
        }

        uint64 dest = ir_insn_dest(ii)
        uint64 s1 = ir_cse_canon_of(ir_insn_src1(ii))
        uint64 s2 = ir_cse_canon_of(ir_insn_src2(ii))
        uint64 raw_imm = ir_insn_imm(ii)
        // For ops whose imm field holds a vreg, canonicalise it too.
        uint64 imm = raw_imm
        if op == 72 || op == 76 || op == 83 || op == 93 || op == 98 {
            imm = ir_cse_canon_of(raw_imm)
        }

        uint64 h = ir_cse_hash(op, s1, s2, imm)
        uint64 entry = ir_cse_table + h * 40

        uint64 e_op = 0
        unsafe { *(entry as uint64) -> e_op }

        if e_op == op {
            uint64 e_s1 = 0
            uint64 e_s2 = 0
            uint64 e_imm = 0
            uint64 p_s1 = entry + 8
            uint64 p_s2 = entry + 16
            uint64 p_imm = entry + 24
            unsafe { *(p_s1 as uint64) -> e_s1 }
            unsafe { *(p_s2 as uint64) -> e_s2 }
            unsafe { *(p_imm as uint64) -> e_imm }

            if e_s1 == s1 && e_s2 == s2 && e_imm == imm {
                uint64 e_result = 0
                uint64 p_r = entry + 32
                unsafe { *(p_r as uint64) -> e_result }
                ir_insn_set_opcode(ii, 61)
                ir_insn_set_src1(ii, e_result)
                ir_insn_set_src2(ii, 0)
                ir_insn_set_imm(ii, 0)
                // dest now aliases to the earlier result's canonical form
                ir_cse_canon_set(dest, ir_cse_canon_of(e_result))
                ii = ii + 1
                continue
            }
        }

        // No match — record this expression
        uint64 p_s1w = entry + 8
        uint64 p_s2w = entry + 16
        uint64 p_immw = entry + 24
        uint64 p_rw = entry + 32
        unsafe { *(entry as uint64) = op }
        unsafe { *(p_s1w as uint64) = s1 }
        unsafe { *(p_s2w as uint64) = s2 }
        unsafe { *(p_immw as uint64) = imm }
        unsafe { *(p_rw as uint64) = dest }

        ii = ii + 1
    }
}

@export
// ---------------------------------------------------------------------------
// LICM (loop-invariant code motion)
//
// For each `while` loop recorded in ir_loops, walk every instruction in
// the body BB range. An instruction is loop-invariant if (1) it's pure
// (`ir_opt_cse_is_pure`) and (2) every source vreg is defined OUTSIDE
// the body range (or undefined / 0). Invariant instructions are moved
// to the preheader's terminator: we change the original slot to IR_NOP
// (op 0) and append the same instruction with the preheader's BB tag.
//
// We iterate to fixpoint: hoisted insns sit in the preheader, which may
// itself be inside an outer loop's body. The next pass invocation then
// recognises them as invariant in the outer loop and hoists further out.
// matmul's `i*N` flows from j-body → k-body → i-body's predecessor in
// at most 3 iterations.
//
// The "is_invariant" check only requires knowing where each vreg is
// defined. We build a per-vreg "defining BB" map up front; a vreg is
// loop-invariant iff its defining BB is outside the loop's body range.
// ---------------------------------------------------------------------------

static uint64 ir_def_bb_buf = 0
static uint64 ir_def_bb_cap = 0

// Reusable BB-walk scratch — used by liveness and the interference-graph
// builder. Walking the linked list forward into a stack and unwinding it
// gives reverse order without requiring consecutive insn indices (which
// LICM violates). Sized for the largest BB; we only need one buffer at a
// time so the static lasts the entire compile.
static uint64 ir_walk_stack = 0

// Stricter than ir_opt_cse_is_pure: hoisting an op out of a loop is only
// safe AND profitable if (a) its result depends solely on its source
// vregs and on values that don't change inside the loop and (b) the
// hoist actually saves work. CSE can treat memory-reads as pure because
// intervening writes invalidate its hash table; LICM cannot, because
// the hoisted op runs *before* the loop ever observes those writes. So
// static_load (op 77) is excluded here even though CSE allows it. (See
// dce_scan miscompile: hoisting `load dce_count` made the loop see a
// stale count and run forever.) IR_CONST (op 1) is also excluded — a
// `mov reg, imm32` is 5 bytes and 1 cycle, so hoisting trades nothing
// for extra register pressure across the whole loop, and the spill
// reload is strictly worse than rematerializing. (See sort: hoisting
// the loop-body constants 1, 0xFF, 8 dropped sort 30% — they all
// hoisted, mutually interfered, and spilled to stack slots.)
fn ir_licm_is_hoistable(uint64 op) -> uint64 {
    if op == 1 { return 0 }                // IR_CONST — rematerialize
    if op >= 2 && op <= 19 { return 1 }    // arith, logic, cmp
    if op >= 20 && op <= 27 { return 1 }   // float arith + conv
    if op >= 97 && op <= 108 { return 1 }  // float ops
    if op >= 120 && op <= 123 { return 1 } // signed cmp
    if op == 79 { return 1 }  // str_const
    if op == 84 { return 1 }  // static_addr
    if op == 86 { return 1 }  // fn_addr
    return 0
}

fn ir_licm_build_def_bb_map() {
    if ir_def_bb_buf == 0 {
        ir_def_bb_cap = 65536
        ir_def_bb_buf = alloc(ir_def_bb_cap * 4)
    }
    if ir_vreg_next > ir_def_bb_cap {
        // Quietly skip — out of capacity
        return
    }
    // Sentinels:
    //   0xFFFFFFFF = "undefined / external" (param or never assigned)
    //   0xFFFFFFFE = "multi-def" (assigned in two or more BBs — must be
    //                treated as non-invariant since one of those BBs may
    //                be inside the loop region we're hoisting from)
    uint64 i = 0
    while i < ir_vreg_next {
        uint64 p = ir_def_bb_buf + i * 4
        uint32 v = 0xFFFFFFFF
        unsafe { *(p as uint32) = v }
        i = i + 1
    }
    i = 0
    while i < ir_insn_count {
        uint64 op = ir_insn_opcode(i)
        if op != 0 {
            uint64 dest = ir_insn_dest(i)
            if dest != 0 && dest < ir_def_bb_cap {
                uint64 bb = ir_insn_bb(i)
                uint64 p = ir_def_bb_buf + dest * 4
                uint32 prev = 0
                unsafe { *(p as uint32) -> prev }
                uint64 prev_w = prev
                if prev_w == 0xFFFFFFFF {
                    uint32 b32 = bb
                    unsafe { *(p as uint32) = b32 }
                } else if prev_w != bb {
                    // A different BB already defines this vreg — multi-def.
                    uint32 multi = 0xFFFFFFFE
                    unsafe { *(p as uint32) = multi }
                }
                // Same-BB redef: keep the current single-BB tag (it's
                // still safe to call invariant if that BB is outside
                // the loop region).
            }
        }
        i = i + 1
    }
}

// Returns 1 iff vreg's defining BB is outside [body_first .. body_last]
// inclusive, or vreg is undefined (treated as "external constant").
// Multi-def vregs are conservatively NOT invariant. The agent-flagged
// matmul case (back-edge COPY in outer loop wrongly blocks hoisting
// from inner loop) is left for a future bitmap pass — preliminary
// per-loop bitmap implementation hung the bootstrap on krc itself.
fn ir_licm_is_invariant_vreg(uint64 vreg, uint64 body_first, uint64 body_last) -> uint64 {
    if vreg == 0 { return 1 }
    if vreg >= ir_def_bb_cap { return 0 }
    uint64 p = ir_def_bb_buf + vreg * 4
    uint32 b = 0
    unsafe { *(p as uint32) -> b }
    uint64 wb = b
    if wb == 0xFFFFFFFF { return 1 }
    if wb == 0xFFFFFFFE { return 0 }
    if wb >= body_first && wb <= body_last { return 0 }
    return 1
}

fn ir_opt_licm_one_pass() -> uint64 {
    uint64 changed = 0
    ir_licm_build_def_bb_map()
    uint64 li = 0
    while li < ir_loop_count {
        uint64 le = ir_loops + li * 16
        uint32 ph32 = 0
        uint32 hd32 = 0
        uint32 fb32 = 0
        uint32 lb32 = 0
        unsafe { *(le as uint32) -> ph32 }
        uint64 le4 = le + 4
        unsafe { *(le4 as uint32) -> hd32 }
        uint64 le8 = le + 8
        uint64 le12 = le + 12
        unsafe { *(le8 as uint32) -> fb32 }
        unsafe { *(le12 as uint32) -> lb32 }
        uint64 preheader = ph32
        uint64 header = hd32
        uint64 body_first = fb32
        uint64 body_last = lb32
        // The "loop region" for invariance includes the header BB —
        // vregs defined there receive back-edge COPYs each iteration.
        uint64 region_first = header
        if body_first < region_first { region_first = body_first }
        uint64 region_last = body_last

        // Walk insns by BB linked list, body BBs only — replaces the
        // original "walk all insns, filter by BB tag" loop which was
        // O(loops × all_insns) and prohibitive at self-host scale.
        uint64 cur_bb = body_first
        while cur_bb <= body_last {
            uint64 ii = ir_bb_first_insn(cur_bb)
            while ii != 0xFFFFFFFF {
                uint64 next_ii = ir_insn_next(ii)
                uint64 op = ir_insn_opcode(ii)
                if op == 0 { ii = next_ii; continue }
                if ir_licm_is_hoistable(op) == 0 { ii = next_ii; continue }

                // ops whose imm field actually holds a vreg
                uint64 imm_is_vreg = 0
                if op == 72 || op == 76 || op == 83 || op == 93 || op == 98 {
                    imm_is_vreg = 1
                }

                uint64 s1 = ir_insn_src1(ii)
                uint64 s2 = ir_insn_src2(ii)
                uint64 imm = ir_insn_imm(ii)

                if ir_licm_is_invariant_vreg(s1, region_first, region_last) == 0 { ii = next_ii; continue }
                if ir_licm_is_invariant_vreg(s2, region_first, region_last) == 0 { ii = next_ii; continue }
                if imm_is_vreg != 0 {
                    if ir_licm_is_invariant_vreg(imm, region_first, region_last) == 0 { ii = next_ii; continue }
                }

                // The dest must be SINGLE-def — if some other BB also
                // assigns this vreg (typically via a back-edge COPY),
                // hoisting changes the value seen on the first iteration
                // and breaks the loop.
                uint64 dest = ir_insn_dest(ii)
                if dest != 0 && dest < ir_def_bb_cap {
                    uint64 dchk_p = ir_def_bb_buf + dest * 4
                    uint32 dchk_v = 0
                    unsafe { *(dchk_p as uint32) -> dchk_v }
                    if dchk_v == 0xFFFFFFFE { ii = next_ii; continue }
                }

                // Hoist: clone the insn into the preheader, just before
                // its terminator. The original slot is NOPed.
                uint64 new_idx = ir_emit(op, dest, s1, s2, imm, preheader)
                ir_bb_remove_last(preheader)
                ir_bb_insert_before_terminator(preheader, new_idx)
                // Update def-bb map. The original def site's BB tag (the
                // body BB) was the only entry for this vreg before the
                // hoist (we filtered to single-BB-defined vregs). After
                // hoist, the only live def is in preheader.
                if dest != 0 && dest < ir_def_bb_cap {
                    uint64 dp = ir_def_bb_buf + dest * 4
                    uint32 ph32_w = preheader
                    unsafe { *(dp as uint32) = ph32_w }
                }
                ir_insn_set_opcode(ii, 0)
                changed = 1
                ii = next_ii
            }
            cur_bb = cur_bb + 1
        }

        li = li + 1
    }
    return changed
}

static uint64 ir_licm_enabled = 1

fn ir_opt_licm() {
    if ir_licm_enabled == 0 { return }
    if ir_loop_count == 0 { return }
    uint64 iter = 0
    while iter < 8 {
        uint64 changed = ir_opt_licm_one_pass()
        if changed == 0 { return }
        iter = iter + 1
    }
}

fn ir_optimize() {
    if ir_const_values == 0 { ir_const_values = alloc(65536 * 8) }
    if ir_const_known == 0 { ir_const_known = alloc(65536) }
    if ir_w32_clean == 0 { ir_w32_clean = alloc(65536) }
    memset(ir_const_known, 0, 65536)
    memset(ir_w32_clean, 0, 65536)
    ir_opt_const_fold()
    ir_opt_dce()
    ir_opt_cse()
    // CSE can leave the original computation alive only to feed a COPY that
    // then produces the same dest. If nothing else references the original
    // dest, a second DCE pass cleans it up.
    ir_opt_dce()
    // LICM after CSE: redundant computations are already merged, so LICM
    // sees one canonical instance per invariant expression to hoist.
    // Hoisted insns get appended to the global insn array (high indices)
    // but are spliced into the preheader's linked list before its
    // terminator. ir_compute_liveness and ir_graph_color walk the linked
    // list (not consecutive index ranges) so the new defs/uses are seen
    // and the interference graph is correct.
    //
    ir_opt_licm()
    ir_opt_dce()
    // ROR pattern recognition: collapse the canonical 32-bit rotation
    // idiom (`OR(AND(SHR(x,n), 0xFFFFFFFF), AND(SHL(x, 32-n), 0xFFFFFFFF))`)
    // into a single IR_ROR. After this pass, the inner ANDs / SHL / SHR /
    // CONST(0xFFFFFFFF) feed nothing live and DCE can clean them up. A
    // second const-fold pass sees the new IR_ROR (which is w32-clean) and
    // elides any consumer `& 0xFFFFFFFF` that the first pass left in.
    ir_opt_recognize_rotate()
    ir_opt_const_fold()
    ir_opt_dce()
    // LEA-base-index-scale: collapse `add(base, mul_imm(idx, K))` for
    // K ∈ {1,2,4,8} into a single x86 LEA. Runs after const-fold has
    // produced IR_MUL_IMM. Cleans up array-indexing patterns that
    // matmul/sort beat the IR allocator with.
    ir_opt_recognize_lea_bis()
    ir_opt_dce()
    // FMA pattern recognition: collapse `FADD(FMUL(a,b), c)` into a
    // single IR_FFMA. The current FFMA emit isn't actually a hardware
    // FMA instruction — it just inlines mulsd+addsd back-to-back —
    // but skipping the GPR round-trip between the FMUL and FADD saves
    // 4 mov instructions per fused pair, which adds up in
    // mandelbrot's `two * x * y + y0` and similar.
    ir_compute_use_count()
    ir_opt_recognize_ffma()
    ir_opt_dce()
}

// ---------------------------------------------------------------------------
// FMA pattern recognition: FADD(FMUL(a,b), c) → FFMA(a, b, c).
// Requires the FMUL's dest to have exactly one use (this FADD).
//
// IR_FFMA's emitter is f64-only (mulsd+addsd) and has no float-kind slot —
// the opcode was originally only emitted by fma_f64() builtins. The FADD/FMUL
// imm slot encodes fk (1=f64, 2=f32); this peephole drops the FADD/FMUL imms
// and stores c_v in IR_FFMA's imm. Firing on f32 ops would emit mulsd/addsd
// on f32 bit patterns → garbage output (e.g. f32 dot-product reductions
// returning meaningless values that compound across long accumulations).
// Gate to fk==1 (f64) on both FADD and the matched FMUL.
// ---------------------------------------------------------------------------

fn ir_opt_recognize_ffma() {
    ir_build_def_idx()
    uint64 ii = 0
    while ii < ir_insn_count {
        uint64 op = ir_insn_opcode(ii)
        if op != 20 { ii = ii + 1; continue }     // not FADD
        uint64 add_fk = ir_insn_imm(ii)
        if add_fk != 1 { ii = ii + 1; continue }  // not f64 — skip
        uint64 dest = ir_insn_dest(ii)
        uint64 s1 = ir_insn_src1(ii)
        uint64 s2 = ir_insn_src2(ii)

        // Try src1's def as FMUL.
        uint64 a_v = 0
        uint64 b_v = 0
        uint64 c_v = 0
        uint64 mul_idx = 0xFFFFFFFF
        uint64 d1 = ir_def_idx(s1)
        if d1 != 0xFFFFFFFF && ir_insn_opcode(d1) == 22 && ir_insn_imm(d1) == 1 && ir_use_count_get(s1) == 1 {
            a_v = ir_insn_src1(d1)
            b_v = ir_insn_src2(d1)
            c_v = s2
            mul_idx = d1
        } else {
            // Try src2's def as FMUL (commutative).
            uint64 d2 = ir_def_idx(s2)
            if d2 != 0xFFFFFFFF && ir_insn_opcode(d2) == 22 && ir_insn_imm(d2) == 1 && ir_use_count_get(s2) == 1 {
                a_v = ir_insn_src1(d2)
                b_v = ir_insn_src2(d2)
                c_v = s1
                mul_idx = d2
            }
        }
        if mul_idx != 0xFFFFFFFF {
            ir_insn_set_opcode(ii, 98)            // IR_FFMA
            ir_insn_set_src1(ii, a_v)
            ir_insn_set_src2(ii, b_v)
            ir_insn_set_imm(ii, c_v)
            // Mark the FMUL as dead — DCE will remove it.
            ir_insn_set_opcode(mul_idx, 0)
        }
        ii = ii + 1
    }
}

// ---------------------------------------------------------------------------
// LEA[base + index * scale] pattern recognition.
// ---------------------------------------------------------------------------

fn ir_opt_recognize_lea_bis() {
    ir_build_def_idx()
    uint64 ii = 0
    while ii < ir_insn_count {
        uint64 op = ir_insn_opcode(ii)
        if op != 2 { ii = ii + 1; continue }      // not ADD
        uint64 s1 = ir_insn_src1(ii)
        uint64 s2 = ir_insn_src2(ii)

        // Try src2's def as MUL_IMM with scale ∈ {1,2,4,8}.
        uint64 base_v = 0
        uint64 idx_v = 0
        uint64 scale = 0
        uint64 d2 = ir_def_idx(s2)
        if d2 != 0xFFFFFFFF && ir_insn_opcode(d2) == 138 {
            uint64 m_imm = ir_insn_imm(d2)
            if m_imm == 1 || m_imm == 2 || m_imm == 4 || m_imm == 8 {
                base_v = s1
                idx_v = ir_insn_src1(d2)
                scale = m_imm
            }
        }
        // Try src1 if src2 didn't match (commutative).
        if scale == 0 {
            uint64 d1 = ir_def_idx(s1)
            if d1 != 0xFFFFFFFF && ir_insn_opcode(d1) == 138 {
                uint64 m_imm = ir_insn_imm(d1)
                if m_imm == 1 || m_imm == 2 || m_imm == 4 || m_imm == 8 {
                    base_v = s2
                    idx_v = ir_insn_src1(d1)
                    scale = m_imm
                }
            }
        }
        if scale != 0 {
            ir_insn_set_opcode(ii, 139)        // IR_LEA_BIS
            ir_insn_set_src1(ii, base_v)
            ir_insn_set_src2(ii, idx_v)
            ir_insn_set_imm(ii, scale)
        }
        ii = ii + 1
    }
}

// ---------------------------------------------------------------------------
// Vreg-defining-instruction map. Built linearly by ir_build_def_idx so the
// rotate-pattern matcher can walk back from a use to its definition. Map
// is invalidated after any IR rewrite that changes def sites — callers
// should rebuild before each use, or at least not assume staleness is OK.
// ---------------------------------------------------------------------------

static uint64 ir_def_idx_buf = 0
static uint64 ir_def_idx_cap = 0

fn ir_build_def_idx() {
    if ir_def_idx_buf == 0 {
        ir_def_idx_cap = 65536
        ir_def_idx_buf = alloc(ir_def_idx_cap * 4)
    }
    // 0xFFFFFFFF sentinel = no def found.
    uint64 i = 0
    while i < ir_def_idx_cap {
        uint64 p = ir_def_idx_buf + i * 4
        uint32 fff = 0xFFFFFFFF
        unsafe { *(p as uint32) = fff }
        i = i + 1
    }
    uint64 ii = 0
    while ii < ir_insn_count {
        uint64 op = ir_insn_opcode(ii)
        if op != 0 {
            uint64 dest = ir_insn_dest(ii)
            if dest > 0 && dest < ir_def_idx_cap {
                uint64 p = ir_def_idx_buf + dest * 4
                uint32 ii32 = ii
                unsafe { *(p as uint32) = ii32 }
            }
        }
        ii = ii + 1
    }
}

// Returns the index of the instruction defining `vreg`, or 0xFFFFFFFF if
// none was recorded.
fn ir_def_idx(uint64 vreg) -> uint64 {
    if vreg == 0 || vreg >= ir_def_idx_cap { return 0xFFFFFFFF }
    uint64 p = ir_def_idx_buf + vreg * 4
    uint32 v = 0
    unsafe { *(p as uint32) -> v }
    if v == 0xFFFFFFFF { return 0xFFFFFFFF }
    return v
}

// Walks COPY chains from `vreg` and returns the index of the first
// non-COPY defining instruction. Returns 0xFFFFFFFF if not found.
fn ir_def_skip_copy(uint64 vreg) -> uint64 {
    uint64 cur = vreg
    uint64 guard = 0
    while guard < 64 {
        uint64 d = ir_def_idx(cur)
        if d == 0xFFFFFFFF { return 0xFFFFFFFF }
        uint64 op = ir_insn_opcode(d)
        if op != 61 { return d }
        cur = ir_insn_src1(d)
        if cur == 0 { return 0xFFFFFFFF }
        guard = guard + 1
    }
    return 0xFFFFFFFF
}

// ROR pattern matcher. Called once per ir_optimize invocation, after
// LICM + DCE so the IR is in canonical SSA form. For each OR
// instruction whose operands trace through copies to AND-with-0xFFFFFFFF
// of SHR/SHL of the same source vreg with complementary shift amounts
// (n and 32-n), rewrite the OR to an IR_ROR and let DCE drop the dead
// SHR/SHL/AND chain.
fn ir_opt_recognize_rotate() {
    ir_build_def_idx()
    uint64 ii = 0
    while ii < ir_insn_count {
        uint64 op = ir_insn_opcode(ii)
        if op != 8 { ii = ii + 1; continue }      // not OR
        uint64 or_s1 = ir_insn_src1(ii)
        uint64 or_s2 = ir_insn_src2(ii)
        uint64 d1 = ir_def_skip_copy(or_s1)
        uint64 d2 = ir_def_skip_copy(or_s2)
        if d1 == 0xFFFFFFFF || d2 == 0xFFFFFFFF { ii = ii + 1; continue }
        // Both must be AND.
        if ir_insn_opcode(d1) != 7 { ii = ii + 1; continue }
        if ir_insn_opcode(d2) != 7 { ii = ii + 1; continue }
        // Each AND's src2 must be (after copy-skipping) a CONST whose
        // imm equals 0xFFFFFFFF. CSE folds the three 0xFFFFFFFF
        // constants in the rotr32 idiom into a single canonical CONST
        // and rewrites the inner ANDs' src2 to COPY-of-canonical, so we
        // need to skip COPYs to find the underlying CONST.
        uint64 m1_def = ir_def_skip_copy(ir_insn_src2(d1))
        uint64 m2_def = ir_def_skip_copy(ir_insn_src2(d2))
        if m1_def == 0xFFFFFFFF || m2_def == 0xFFFFFFFF { ii = ii + 1; continue }
        if ir_insn_opcode(m1_def) != 1 { ii = ii + 1; continue }
        if ir_insn_opcode(m2_def) != 1 { ii = ii + 1; continue }
        if ir_insn_imm(m1_def) != 0xFFFFFFFF { ii = ii + 1; continue }
        if ir_insn_imm(m2_def) != 0xFFFFFFFF { ii = ii + 1; continue }
        // Each AND's src1 must trace to an SHR (one) and an SHL (the other).
        uint64 sh1_def = ir_def_skip_copy(ir_insn_src1(d1))
        uint64 sh2_def = ir_def_skip_copy(ir_insn_src1(d2))
        if sh1_def == 0xFFFFFFFF || sh2_def == 0xFFFFFFFF { ii = ii + 1; continue }
        uint64 sh1_op = ir_insn_opcode(sh1_def)
        uint64 sh2_op = ir_insn_opcode(sh2_def)
        uint64 shr_def = 0xFFFFFFFF
        uint64 shl_def = 0xFFFFFFFF
        if sh1_op == 11 && sh2_op == 10 {
            shr_def = sh1_def
            shl_def = sh2_def
        } else {
            if sh1_op == 10 && sh2_op == 11 {
                shr_def = sh2_def
                shl_def = sh1_def
            } else {
                ii = ii + 1
                continue
            }
        }
        // Same x vreg in both shifts.
        uint64 x = ir_insn_src1(shr_def)
        if ir_insn_src1(shl_def) != x { ii = ii + 1; continue }
        uint64 n = ir_insn_src2(shr_def)
        uint64 m = ir_insn_src2(shl_def)
        // Two acceptable shapes for the SHL amount `m`:
        //   (a) m is defined as `SUB(const_32, n)` — the variable form
        //       inside rotr32 itself, where n is the rotation amount param.
        //   (b) m and n are both constants and `m + n == 32` — the
        //       inlined / constant-folded form, e.g., `rotr32(w15, 7)`
        //       expanded inline becomes shr(w15, 7) and shl(w15, 25).
        uint64 ok = 0
        uint64 m_def = ir_def_skip_copy(m)
        if m_def != 0xFFFFFFFF {
            if ir_insn_opcode(m_def) == 3 && ir_insn_src2(m_def) == n {
                uint64 wc_def = ir_def_skip_copy(ir_insn_src1(m_def))
                if wc_def != 0xFFFFFFFF && ir_insn_opcode(wc_def) == 1 && ir_insn_imm(wc_def) == 32 {
                    ok = 1
                }
            }
            if ok == 0 && ir_insn_opcode(m_def) == 1 {
                uint64 n_def = ir_def_skip_copy(n)
                if n_def != 0xFFFFFFFF && ir_insn_opcode(n_def) == 1 {
                    if ir_insn_imm(m_def) + ir_insn_imm(n_def) == 32 {
                        ok = 1
                    }
                }
            }
        }
        if ok == 0 { ii = ii + 1; continue }
        // All conditions satisfied. Rewrite the OR in place to IR_ROR.
        // The intermediate AND/SHR/SHL/SUB/CONST chain becomes dead and
        // the trailing DCE pass removes it.
        ir_insn_set_opcode(ii, 137)
        ir_insn_set_src1(ii, x)
        ir_insn_set_src2(ii, n)
        ir_insn_set_imm(ii, 32)
        ii = ii + 1
    }
}

@export
fn ir_emit_x86_function(uint64 fn_node) {
    // Check for @naked attribute: bit 1 of annotation flags
    uint32 ann_flags = ast_data4(fn_node)
    uint64 is_naked = ann_flags & 2

    // Record the function's float return kind so later callers can
    // tag their IR_CALL result vreg with the right fkind. Without
    // this `f64_fn() * local_f64` picks IR_MUL instead of IR_FMUL
    // inside the BinOp lowering (silent wrong math).
    uint32 ir_fn_name_tok = ast_data1(fn_node)
    uint32 ir_ret_type_tok = ast_data2(fn_node)
    uint64 wirt = ir_ret_type_tok
    if wirt != 0 {
        uint64 ir_ret_kind = tok_kind_at_raw(wirt)
        if ir_ret_kind == 96 { fn_ret_float_register(ir_fn_name_tok, 1) }
        if ir_ret_kind == 95 { fn_ret_float_register(ir_fn_name_tok, 2) }
    }

    // 1. Lower AST to IR
    ir_lower_function(fn_node)

    // 1a. Optimize
    if ir_opt_level > 0 {
        ir_optimize()
    }

    // 2. Compute liveness
    ir_compute_liveness()

    // 3. Register allocation
    ir_regalloc_init()
    ir_graph_color()


    // 4. Compute spill count
    ir_spill_count = 0
    if ir_vreg_next > IR_NUM_REGS + 1 {
        ir_spill_count = ir_vreg_next - IR_NUM_REGS - 1
    }

    // 4a. Snapshot the function's var map for DWARF (if -g)
    ir_snapshot_debug_vars()

    // 4b. Per-vreg use count — consumed by the CMP+JCC fusion peephole.
    ir_compute_use_count()

    // 5a. For main(): set up argc/argv BEFORE prologue modifies RSP
    uint32 fn_name_tok = ast_data1(fn_node)
    if tok_matches(fn_name_tok, "main", 4) != 0 && freestanding == 0 && target_os == 2 {
        // Windows: call GetCommandLineA -> rax = raw command line string
        // PE entry: loader calls us, RSP = 8 mod 16.
        // Use 0x28 shadow (0x20 + 8 alignment) so RSP is 16-aligned before CALL.
        emit_win_alloc_stack(0x28)
        emit_win_call_iat(7)          // GetCommandLineA (IAT slot 7) -> rax = cmdline
        emit_win_free_stack(0x28)
        // Store raw cmdline pointer as cli_argv (will be parsed by win_init_args)
        uint64 argv_off_w = static_lookup_by_name("cli_argv", 8)
        if argv_off_w != 0xFFFFFFFF {
            emit_static_store(argv_off_w)
        }
        // Set cli_argc = 0xFFFFFFFF as "needs parsing" sentinel
        ir_emit_mov_r64_imm64(0, 0xFFFFFFFF)
        uint64 argc_off_w = static_lookup_by_name("cli_argc", 8)
        if argc_off_w != 0xFFFFFFFF {
            emit_static_store(argc_off_w)
        }
    }
    if tok_matches(fn_name_tok, "main", 4) != 0 && freestanding == 0 && target_os != 2 {
        // Linux/macOS/Android: argc/argv on stack. [RSP]=argc, [RSP+8]=&argv[0]
        // mov rax, [rsp]  ; rax = argc
        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x04); emit_byte(0x24)
        uint64 argc_off = static_lookup_by_name("cli_argc", 8)
        if argc_off != 0xFFFFFFFF {
            emit_static_store(argc_off)
        }
        // lea rax, [rsp+8]  ; rax = &argv[0]
        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44); emit_byte(0x24); emit_byte(0x08)
        uint64 argv_off = static_lookup_by_name("cli_argv", 8)
        if argv_off != 0xFFFFFFFF {
            emit_static_store(argv_off)
        }
        // envp = rsp + 8 + (argc+1)*8 — matches legacy codegen. Previously the
        // IR path silently left cli_envp=0, forwarding NULL envp through
        // exec_process(). Harmless on plain Linux, breaks Android's fat-binary
        // runner spawn path where bionic expects a real envp vector.
        uint64 envp_off_main = static_lookup_by_name("cli_envp", 8)
        if envp_off_main != 0xFFFFFFFF {
            // mov rcx, [rsp]
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x0C); emit_byte(0x24)
            // inc rcx
            emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC1)
            // lea rax, [rsp + rcx*8 + 8]
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44); emit_byte(0xCC); emit_byte(0x08)
            emit_static_store(envp_off_main)
        }
    }

    // 5. Emit prologue (skip for @naked functions). Push only the
    // callee-saved colours regalloc actually assigned — leaf-ish hot
    // paths like fib end up with 3 live colours instead of 5.
    uint64 used_mask = 0
    uint64 push_count = 0
    if is_naked == 0 {
        used_mask = ir_used_color_mask()
        // Color → physical reg encoding:
        //   color 0 → rbx (0x53)
        //   color 1 → r12 (0x41 0x54)
        //   color 2 → r13 (0x41 0x55)
        //   color 3 → r14 (0x41 0x56)
        //   color 4 → r15 (0x41 0x57)
        if (used_mask & 1) != 0 {
            emit_byte(0x53)                       // push rbx
            push_count = push_count + 1
        }
        if (used_mask & 2) != 0 {
            emit_byte(0x41); emit_byte(0x54)      // push r12
            push_count = push_count + 1
        }
        if (used_mask & 4) != 0 {
            emit_byte(0x41); emit_byte(0x55)      // push r13
            push_count = push_count + 1
        }
        if (used_mask & 8) != 0 {
            emit_byte(0x41); emit_byte(0x56)      // push r14
            push_count = push_count + 1
        }
        if (used_mask & 16) != 0 {
            emit_byte(0x41); emit_byte(0x57)      // push r15
            push_count = push_count + 1
        }
        if (used_mask & 32) != 0 {
            emit_byte(0x55)                       // push rbp
            push_count = push_count + 1
        }
    }
    // Stash for the epilogue (which is emitted later but needs to mirror
    // the same set of registers in reverse) and for stack-arg loads.
    ir_used_callee_mask = used_mask
    ir_callee_save_bytes = push_count * 8

    // sub rsp, frame_size
    // Layout (from RSP up): [spill slots | stack arrays]
    // IR_STACK_ADDR offsets are relative to the start of the stack-array
    // region, so the x86 emitter adds ir_spill_count*8 to resolve them.
    uint64 frame_size = ir_spill_count * 8 + ir_stack_array_bytes
    // SysV: SP is 8 mod 16 at function entry (CALL pushed RET_ADDR).
    // After N pushes SP is (N+1)*8 mod 16. Want frame_size + (N+1)*8
    // ≡ 0 mod 16. So if push_count is odd we want frame_size 16-aligned;
    // if even we want it ≡ 8 mod 16.
    if (push_count & 1) != 0 {
        if frame_size > 0 && (frame_size & 15) != 0 { frame_size = frame_size + 8 }
    } else {
        if (frame_size & 15) == 0 { frame_size = frame_size + 8 }
    }
    if is_naked != 0 { frame_size = 0 }
    ir_spill_base = 0
    ir_frame_size = frame_size

    if frame_size > 0 {
        emit_byte(0x48)
        emit_byte(0x81)
        emit_byte(0xEC)
        emit_u32_le(frame_size)
    }

    // 6. Allocate block offset tracking and branch/return fixup lists
    //    Size based on ir_bb_count to support very large functions.
    //    Buffers are reused across functions — only re-alloc if a function
    //    needs more capacity than previously allocated. Without this guard
    //    every emitted function leaked ~52 KB; over ~700 functions in the
    //    self-host that was ~36 MB per single-arch compile.
    uint64 bo_need = ir_bb_count
    if bo_need < 4096 { bo_need = 4096 }
    if bo_need > ir_block_offsets_cap {
        if ir_block_offsets != 0 { dealloc(ir_block_offsets) }
        ir_block_offsets = alloc(bo_need * 8)
        ir_block_offsets_cap = bo_need
    }
    uint64 br_need = ir_bb_count * 4
    if br_need < 2048 { br_need = 2048 }
    if br_need > ir_br_fixups_cap {
        if ir_br_fixups != 0 { dealloc(ir_br_fixups) }
        ir_br_fixups = alloc(br_need * 8)
        ir_br_fixups_cap = br_need
    }
    uint64 ret_need = ir_bb_count
    if ret_need < 1024 { ret_need = 1024 }
    if ret_need > ir_ret_fixups_cap {
        if ir_ret_fixups != 0 { dealloc(ir_ret_fixups) }
        ir_ret_fixups = alloc(ret_need * 4)
        ir_ret_fixups_cap = ret_need
    }
    ir_br_fixup_count = 0
    ir_ret_fixup_count = 0

    // 7. Emit all blocks
    uint64 bi = 0
    while bi < ir_bb_count {
        // Record this block's code offset
        uint64 bop = ir_block_offsets + bi * 8
        unsafe { *(bop as uint64) = out_len }

        // Every basic-block boundary is a potential branch target, so
        // the spill-reload peephole's "nothing happened between" check
        // must restart from this point.
        ir_peephole_reset()
        // Fusion handoff is strictly intra-BB: a cmp in BB A must not
        // bleed a stale jcc code into BB B's terminator. Reset here so
        // each block's terminator independently decides fused vs. plain.
        ir_fused_jcc_code = 0

        // Emit non-terminator instructions
        uint64 ii = ir_bb_first_insn(bi)
        while ii != 0xFFFFFFFF {
            uint64 iop = ir_insn_opcode(ii)
            // Skip terminators — we handle them after all instructions
            if iop != 40 && iop != 41 {
                ir_emit_x86_insn(ii)
            }
            ii = ir_insn_next(ii)
        }

        // Emit block terminator
        uint64 last = ir_bb_last_insn(bi)
        if last != 0xFFFFFFFF {
            uint64 last_op = ir_insn_opcode(last)
            if last_op == 40 {
                // Unconditional branch: jmp target_bb
                uint64 target = ir_insn_imm(last)
                if target != bi + 1 {
                    emit_byte(0xE9)
                    // Record fixup
                    uint64 fp = ir_br_fixups + ir_br_fixup_count * 8
                    uint32 po = out_len
                    unsafe { *(fp as uint32) = po }
                    uint64 fp4 = fp + 4
                    uint32 tb = target
                    unsafe { *(fp4 as uint32) = tb }
                    ir_br_fixup_count = ir_br_fixup_count + 1
                    emit_u32_le(0)
                }
            }
            if last_op == 41 {
                // Conditional branch emission. Four BB-layout cases for the
                // (target_true, target_false) pair and the next emitted BB:
                //   A: both == bi+1 → neither branch needed, plain fallthrough
                //   B: true == bi+1, false elsewhere → invert condition, one jcc
                //   C: true elsewhere, false == bi+1 → jcc, no trailing jmp
                //   D: both elsewhere → jcc + jmp (worst case)
                // Case B saves one 5-byte jmp compared to the naive C/D pattern
                // the emitter used before, which is a very common shape for
                // `if (!cond) else_path` / `while (cond) body` layouts.
                uint64 target_true  = ir_insn_imm(last)
                uint64 target_false = ir_bb_succ0(bi)
                uint64 true_next  = 0
                if target_true  == bi + 1 { true_next  = 1 }
                uint64 false_next = 0
                if target_false == bi + 1 { false_next = 1 }

                if true_next != 0 && false_next != 0 {
                    // Case A: plain fallthrough; emit nothing. The cmp flags
                    // (fused) or the cond register (plain) are simply unused.
                    // We still need to consume the fused jcc token so a later
                    // BB doesn't inherit it.
                    ir_fused_jcc_code = 0
                } else {
                    uint64 invert = 0
                    if true_next != 0 { invert = 1 }
                    // Emit the single jcc (inverted when invert != 0).
                    if ir_fused_jcc_code != 0 {
                        emit_byte(0x0F)
                        uint8 jcc = ir_fused_jcc_code
                        if invert != 0 { jcc = jcc ^ 1 }
                        emit_byte(jcc)
                        ir_fused_jcc_code = 0
                    } else {
                        uint64 cond_v = ir_insn_src1(last)
                        uint64 cond_r = ir_resolve_src(cond_v, 0)
                        ir_emit_test_r64_r64(cond_r, cond_r)
                        emit_byte(0x0F)
                        if invert != 0 { emit_byte(0x84) }    // je  (cond == 0)
                        else           { emit_byte(0x85) }    // jne (cond != 0)
                    }
                    uint64 branch_target = target_true
                    if invert != 0 { branch_target = target_false }
                    uint64 fp = ir_br_fixups + ir_br_fixup_count * 8
                    uint32 po = out_len
                    unsafe { *(fp as uint32) = po }
                    uint64 fp4 = fp + 4
                    uint32 tb = branch_target
                    unsafe { *(fp4 as uint32) = tb }
                    ir_br_fixup_count = ir_br_fixup_count + 1
                    emit_u32_le(0)
                    // Trailing unconditional jmp is only needed when NEITHER
                    // target fell through (case D). Case B (invert) already
                    // falls through to true_target; case C falls through to
                    // false_target.
                    if invert == 0 && false_next == 0 && target_false != 0xFFFFFFFF {
                        emit_byte(0xE9)
                        uint64 fp2 = ir_br_fixups + ir_br_fixup_count * 8
                        uint32 po2 = out_len
                        unsafe { *(fp2 as uint32) = po2 }
                        uint64 fp24 = fp2 + 4
                        uint32 tb2 = target_false
                        unsafe { *(fp24 as uint32) = tb2 }
                        ir_br_fixup_count = ir_br_fixup_count + 1
                        emit_u32_le(0)
                    }
                }
            }
        }

        bi = bi + 1
    }

    // 8. Patch branch targets
    uint64 fi = 0
    while fi < ir_br_fixup_count {
        uint64 fp = ir_br_fixups + fi * 8
        uint32 patch_off = 0
        unsafe { *(fp as uint32) -> patch_off }
        uint64 fp4 = fp + 4
        uint32 target_bb = 0
        unsafe { *(fp4 as uint32) -> target_bb }
        uint64 wtb = target_bb
        // Get target block offset
        uint64 tbp = ir_block_offsets + wtb * 8
        uint64 target_off = 0
        unsafe { *(tbp as uint64) -> target_off }
        // Displacement = target - (patch_off + 4)
        uint64 wpo = patch_off
        uint64 disp = target_off - wpo - 4
        patch_u32(wpo, disp)
        fi = fi + 1
    }

    // 9. Patch return fixups — all IR_RET jmp targets point to the epilogue
    uint64 epilogue_off = out_len
    uint64 ri2 = 0
    while ri2 < ir_ret_fixup_count {
        uint64 rfp = ir_ret_fixups + ri2 * 4
        uint32 rpatch = 0
        unsafe { *(rfp as uint32) -> rpatch }
        uint64 wrp = rpatch
        uint64 rdisp = epilogue_off - wrp - 4
        patch_u32(wrp, rdisp)
        ri2 = ri2 + 1
    }

    // 10. Epilogue (skip for @naked functions)
    if is_naked == 0 {
        // For main(): auto-insert exit syscall so programs without
        // explicit exit() don't segfault on return. The exit status
        // comes from rax — IR_RET writes the return value there,
        // IR_RET_VOID zeros it — so `fn main() -> int32 { return N }`
        // produces exit status N as expected.
        if tok_matches(fn_name_tok, "main", 4) != 0 && freestanding == 0 {
            if target_os == 2 {
                // Windows: ExitProcess(rax) via IAT slot 0
                // mov ecx, eax (32-bit DWORD ABI argument is in ecx)
                emit_byte(0x89); emit_byte(0xC1)
                emit_win_alloc_stack(0x20)
                emit_win_call_iat(0)
            } else {
                // Linux/macOS/Android: exit(rax) syscall — copy rax→rdi
                // mov rdi, rax: 48 89 C7
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC7)
                if target_os == 1 { emit_byte(0xB8); emit_u32_le(0x2000001) }
                else { emit_byte(0xB8); emit_u32_le(231) }
                emit_byte(0x0F); emit_byte(0x05)
            }
        }
        if frame_size > 0 {
            emit_byte(0x48)
            emit_byte(0x81)
            emit_byte(0xC4)
            emit_u32_le(frame_size)
        }
        // Pop callee-saves in reverse of the prologue's push order.
        if (ir_used_callee_mask & 32) != 0 {
            emit_byte(0x5D)                       // pop rbp
        }
        if (ir_used_callee_mask & 16) != 0 {
            emit_byte(0x41); emit_byte(0x5F)      // pop r15
        }
        if (ir_used_callee_mask & 8) != 0 {
            emit_byte(0x41); emit_byte(0x5E)      // pop r14
        }
        if (ir_used_callee_mask & 4) != 0 {
            emit_byte(0x41); emit_byte(0x5D)      // pop r13
        }
        if (ir_used_callee_mask & 2) != 0 {
            emit_byte(0x41); emit_byte(0x5C)      // pop r12
        }
        if (ir_used_callee_mask & 1) != 0 {
            emit_byte(0x5B)                       // pop rbx
        }
        emit_byte(0xC3)
    }
}
