            uint64 st_modrm = ((val_reg & 7) << 3) | (addr_reg & 7)
            if (addr_reg & 7) == 4 {
                uint8 stm = st_modrm
                emit_byte(stm)
                emit_byte(0x24)
            } else if (addr_reg & 7) == 5 {
