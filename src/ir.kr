        // SHR but ModRM /7 (base 0xF8) instead of /5 (base 0xE8).
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if b_reg != 1 { ir_emit_mov_r64_r64(1, b_reg) }
        if dst_r != 0xFFFFFFFF {
            if dst_r == 1 && a_reg != 1 {
                ir_emit_mov_r64_r64(0, a_reg)
                emit_byte(0x48)
                emit_byte(0xD3)
                emit_byte(0xF8)
                ir_emit_mov_r64_r64(dst_r, 0)
            } else {
                ir_emit_mov_r64_r64(dst_r, a_reg)
                uint8 sar_rex = 0x48
                if dst_r >= 8 { sar_rex = sar_rex | 1 }
                emit_byte(sar_rex)
                emit_byte(0xD3)
                uint64 sar_modrm = 0xF8 | (dst_r & 7)
                uint8 sar_m = sar_modrm
                emit_byte(sar_m)
            }
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            emit_byte(0x48)
            emit_byte(0xD3)
            emit_byte(0xF8)
            ir_emit_store_spill(0, dest_v)
