                // mov tgt, [rsp + overflow_off]
                uint8 ov_rex = 0x48
                if tgt >= 8 { ov_rex = ov_rex | 4 }
                emit_byte(ov_rex)
                emit_byte(0x8B)
                if overflow_off < 128 {
                    uint8 ovm = 0x44 | ((tgt & 7) << 3)
                    emit_byte(ovm)
                    emit_byte(0x24)
                    uint8 ovo = overflow_off
                    emit_byte(ovo)
                } else {
                    uint8 ovm = 0x84 | ((tgt & 7) << 3)
                    emit_byte(ovm)
                    emit_byte(0x24)
                    emit_u32_le(overflow_off)
                }
                if dst_r == 0xFFFFFFFF {
                    ir_emit_store_spill(0, dest_v)
                }
            }
        }
        return
    }

    if op == 51 {
        // IR_ARG: move src to the correct argument register
        // SysV ABI: rdi(7), rsi(6), rdx(2), rcx(1), r8(8), r9(9)
        uint64 target = 7
        if imm == 1 { target = 6 }
        if imm == 2 { target = 2 }
        if imm == 3 { target = 1 }
        if imm == 4 { target = 8 }
        if imm == 5 { target = 9 }
        if imm < 6 {
            uint64 src_reg = ir_resolve_src(s1_v, 0)
            ir_emit_mov_r64_r64(target, src_reg)
        }
        if imm >= 100 {
            // ASM input constraint: `in(var -> reg)`. A contiguous run of these
            // needs a shuffle-safe emission order — a naive sequential
            // `mov target, src_reg` clobbers a source register before a later
            // move reads it (e.g. `in(a -> rdi), in(b -> rsi)` where b's vreg
            // was allocated to rdi). Emit the whole group via push/pop so the
            // ordering is bulletproof regardless of what regalloc chose.
            ir_emit_asm_in_group(ii)
            return
        } else if imm >= 6 {
            // Overflow arg: save vreg to overflow buffer for IR_CALL to handle
            uint64 oi = imm - 6
            if oi < 32 {
                uint64 op_ptr = ir_overflow_args + oi * 8
                uint64 sv = s1_v
                unsafe { *(op_ptr as uint64) = sv }
                if oi >= ir_overflow_arg_count { ir_overflow_arg_count = oi + 1 }
            }
        }
        return
    }

    if op == 52 {
        // IR_SYSCALL: dispatch by target_os
        if target_os == 2 {
            ir_emit_x86_win_syscall(imm, dest_v, dst_r)
            return
        }
        // Linux (0), macOS (1), Android (3): raw syscall with OS-specific numbers
        uint64 real_nr = ir_x86_syscall_nr(imm)
        ir_emit_mov_r64_imm64(0, real_nr)
        emit_byte(0x0F)
        emit_byte(0x05)
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 50 {
        // IR_CALL: call rel32 (will be resolved by fixup system)
        // src1 = arg_count (0 for old-style calls with <=6 args)
        uint64 call_arg_count = s1_v
        uint64 stack_args = 0
        if call_arg_count > 6 {
            stack_args = call_arg_count - 6
            // Resolve all overflow arg values BEFORE modifying rsp
            // Use sub rsp + mov [rsp+N] approach instead of push to avoid
            // spill offset issues (push changes rsp, making subsequent resolves wrong)
            uint64 aligned_stack = stack_args
            if (aligned_stack & 1) != 0 { aligned_stack = aligned_stack + 1 }
            uint64 stack_bytes = aligned_stack * 8
            // First, resolve all overflow args into a temp buffer (physical values)
            uint64[16] ov_vals
            uint64 oi = 0
            while oi < ir_overflow_arg_count {
                uint64 op_ptr = ir_overflow_args + oi * 8
                uint64 arg_vreg = 0
                unsafe { *(op_ptr as uint64) -> arg_vreg }
                uint64 arg_r = ir_resolve_src(arg_vreg, 0)
                ir_emit_mov_r64_r64(0, arg_r)
                // Store rax value to the temp buf position on the current (unmodified) stack
                // Actually we can't use a temp buffer easily. Use a different approach:
                // resolve to rax and push immediately. The key insight: spill offsets are
                // relative to current rsp. After each push, rsp decreases by 8, so subsequent
                // resolves need adjusted offsets. Instead, let's just resolve all to rax and
                // push in one pass, going from LAST to FIRST. But each push changes rsp...

                // Better approach: sub rsp first, then use mov [rsp+N] with adjusted offsets
                oi = oi + 1
            }
            // Simpler approach: sub rsp, then store. Adjust resolve offsets manually.
            // sub rsp, stack_bytes — imm8 form fits up to 127; switch to
            // imm32 for larger allocations so calls with >16 stack args
            // don't wrap the signed-byte immediate silently.
            if stack_bytes < 128 {
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xEC)
                uint8 sb8 = stack_bytes
                emit_byte(sb8)
            } else {
                emit_byte(0x48); emit_byte(0x81); emit_byte(0xEC)
                emit_u32_le(stack_bytes)
            }
            // Now rsp has shifted down. Spill slots are now at rsp + stack_bytes + original_offset
            // We need to re-resolve each overflow arg with the shifted rsp
            oi = 0
            while oi < ir_overflow_arg_count {
                uint64 op_ptr = ir_overflow_args + oi * 8
                uint64 arg_vreg = 0
                unsafe { *(op_ptr as uint64) -> arg_vreg }
                // The vreg might be in a register (fine) or spilled.
                // If spilled, the spill is at [old_rsp + spill_off] = [new_rsp + stack_bytes + spill_off]
                // We need to adjust the spill load. Let's just check the physical reg:
                uint64 arg_r = ir_get_phys_reg(arg_vreg)
                if arg_r != 0xFFFFFFFF {
                    // Value is in a register — just mov to [rsp + oi*8]
                    uint64 soff = oi * 8
                    uint8 st_rex = 0x48
                    if arg_r >= 8 { st_rex = st_rex | 4 }
                    emit_byte(st_rex); emit_byte(0x89)
                    if soff == 0 {
                        uint8 stm = ((arg_r & 7) << 3) | 4
                        emit_byte(stm); emit_byte(0x24)
                    } else if soff < 128 {
                        uint8 stm = 0x44 | ((arg_r & 7) << 3)
                        emit_byte(stm); emit_byte(0x24)
                        uint8 so8 = soff
                        emit_byte(so8)
                    } else {
                        uint8 stm = 0x84 | ((arg_r & 7) << 3)
                        emit_byte(stm); emit_byte(0x24)
                        emit_u32_le(soff)
                    }
                } else {
                    // Value is spilled — need to load from adjusted offset
                    // Original spill at [rsp + spill_off], now at [rsp + stack_bytes + spill_off]
                    uint64 spill_off = (arg_vreg - IR_NUM_REGS - 1) * 8
                    uint64 adj_off = stack_bytes + spill_off
                    // mov rax, [rsp + adj_off]
                    emit_byte(0x48); emit_byte(0x8B)
                    if adj_off < 128 {
                        emit_byte(0x44); emit_byte(0x24)
                        uint8 ao8 = adj_off
                        emit_byte(ao8)
                    } else {
                        emit_byte(0x84); emit_byte(0x24)
                        emit_u32_le(adj_off)
                    }
                    // mov [rsp + oi*8], rax
                    uint64 soff = oi * 8
                    emit_byte(0x48); emit_byte(0x89)
                    if soff == 0 {
                        emit_byte(0x04); emit_byte(0x24)
                    } else if soff < 128 {
                        emit_byte(0x44); emit_byte(0x24)
                        uint8 so8 = soff
                        emit_byte(so8)
                    } else {
                        emit_byte(0x84); emit_byte(0x24)
                        emit_u32_le(soff)
                    }
                }
                oi = oi + 1
            }
        }
        emit_byte(0xE8)
        uint64 call_patch = out_len
        emit_u32_le(0)
        // Record fixup: imm holds the callee token
        uint64 fentry = fixup_table + fixup_count * 8
        uint32 fo = call_patch
        unsafe { *(fentry as uint32) = fo }
        uint64 fe4 = fentry + 4
        uint32 ct = imm
        unsafe { *(fe4 as uint32) = ct }
        fixup_count = fixup_count + 1
        // Clean up overflow args from stack
        if stack_args > 0 {
            uint64 aligned_stack = stack_args
            if (aligned_stack & 1) != 0 { aligned_stack = aligned_stack + 1 }
            uint64 cleanup = aligned_stack * 8
            if cleanup < 128 {
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xC4)
                uint8 cl8 = cleanup
                emit_byte(cl8)
            } else {
                emit_byte(0x48); emit_byte(0x81); emit_byte(0xC4)
                emit_u32_le(cleanup)
            }
        }
        // Reset overflow arg count
        ir_overflow_arg_count = 0
        // Result in rax
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 85 {
