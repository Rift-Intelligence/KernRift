        //   Linux/Android x86_64: clock_gettime(CLOCK_MONOTONIC, &ts) syscall 228
        //   macOS         x86_64: clock_gettime → syscall 0x20000E4 (same layout)
        //   Windows       x86_64: QueryPerformanceCounter + QueryPerformanceFrequency
        //                         via IAT, combined as counter*1e9/freq using a
        //                         64-bit-overflow-safe split-and-recombine.
        // On Windows, the raw `syscall` instruction must never execute — issuing
        // a Linux-style syscall number on Windows used to silently land in the
        // NT dispatcher and return arbitrary stack garbage, which happened to be
        // zero often enough that the bug went unnoticed for a while.
        if target_os == 2 {
            // sub rsp, 0x30  (shadow 0x20 + freq@0x20 + counter@0x28)
