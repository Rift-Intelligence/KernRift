        // Syscall uses r10 for arg3 (not rcx), so move rcx -> r10
        // mov r10, rcx (49 89 CA)
        emit_byte(0x49); emit_byte(0x89); emit_byte(0xCA)
        // Move nr to rax
        uint64 nr_r = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, nr_r)
        // syscall
        emit_byte(0x0F); emit_byte(0x05)
        // Result in rax
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 86 {
        // IR_FN_ADDR: lea rax, [rip + disp32] — disp resolved by fnaddr fixup
        // Emit: 48 8D 05 disp32
        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x05)
        uint64 fnaddr_patch = out_len
        emit_u32_le(0)
        // Record in fnaddr fixup table
        if fnaddr_fixup_count < 1024 {
            uint64 fentry_fa = fnaddr_fixup_table + fnaddr_fixup_count * 8
            uint32 fa_off = fnaddr_patch
            unsafe { *(fentry_fa as uint32) = fa_off }
            uint64 fe4_fa = fentry_fa + 4
            uint32 fa_tok = imm
            unsafe { *(fe4_fa as uint32) = fa_tok }
            fnaddr_fixup_count = fnaddr_fixup_count + 1
        }
        // Result in rax
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 87 {
        // IR_CALL_IND: call through function pointer in src1.
        // imm == 1 means the callee returns f64 in xmm0; we move the
        // xmm0 bits into the dest GPR via `movq r64, xmm0`
        // (66 REX.W 0F 7E /r) so BinOp/StoreF64 downstream see the
        // right bit pattern. imm == 0 is the integer-return path.
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, ptr_r)
        // call rax: FF D0
        emit_byte(0xFF); emit_byte(0xD0)
        uint64 result_reg = 0   // rax for int return
        if imm == 1 {
            // movq dst_r (or rax if spilled), xmm0
            uint64 target = dst_r
            if target == 0xFFFFFFFF { target = 0 }
            uint8 mq_rex = 0x48
            if target >= 8 { mq_rex = mq_rex | 0x01 }
            emit_byte(0x66); emit_byte(mq_rex)
            emit_byte(0x0F); emit_byte(0x7E)
            uint8 mq_mod = 0xC0 | ((0 & 7) << 3) | (target & 7)
            emit_byte(mq_mod)
            result_reg = target
        }
        // For int return, the result is already in rax. For f64 we
        // just moved xmm0 → (dst_r or rax). Either way, if the dest
        // vreg got a physical reg and it's not the result_reg, copy.
        if dst_r != 0xFFFFFFFF && dst_r != result_reg {
            ir_emit_mov_r64_r64(dst_r, result_reg)
        }
        if dst_r == 0xFFFFFFFF {
            // result is in result_reg; spill to dest_v's slot. For
            // the f64 path we already wrote to rax (result_reg=0);
            // for int path it was always rax.
            ir_emit_store_spill(result_reg, dest_v)
        }
        return
    }

    if op == 88 {
        // IR_MEMCMP: compare imm bytes at [src1] vs [src2], result 1 if equal, 0 if not
        uint64 mc_a = ir_resolve_src(s1_v, 0)
        uint64 mc_b = ir_resolve_src(s2_v, 1)
        ir_emit_mov_r64_r64(6, mc_a)    // rsi = ptr_a
        ir_emit_mov_r64_r64(7, mc_b)    // rdi = ptr_b
        // Load byte count
        ir_emit_mov_r64_imm64(1, imm)   // rcx = count in bytes
        // Compare qword-by-qword, then remaining bytes
        // Start with result = 1 (assume equal)
        // xor eax, eax (31 C0)
        emit_byte(0x31); emit_byte(0xC0)
        // mov eax, 1 (B8 01 00 00 00)
        emit_byte(0xB8); emit_byte(0x01); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)
        // .loop: test rcx, rcx
        uint64 mc_loop = out_len
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC9)
        // jz .done
        emit_byte(0x74)
        uint64 mc_jz_off = out_len
        emit_byte(0)
        // cmp rcx, 8
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xF9); emit_byte(0x08)
        // jb .byte_cmp
        emit_byte(0x72)
        uint64 mc_jb_off = out_len
        emit_byte(0)
        // qword compare: mov r10, [rsi]
        emit_byte(0x4C); emit_byte(0x8B); emit_byte(0x16)
        // cmp r10, [rdi]
        emit_byte(0x4C); emit_byte(0x3B); emit_byte(0x17)
        // jne .not_equal
        emit_byte(0x75)
        uint64 mc_jne1_off = out_len
        emit_byte(0)
        // add rsi, 8; add rdi, 8; sub rcx, 8
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xC6); emit_byte(0x08)
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xC7); emit_byte(0x08)
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xE9); emit_byte(0x08)
        // jmp .loop
        emit_byte(0xEB)
        uint64 mc_jmp_back = mc_loop - out_len - 1
        uint8 mc_jb8 = mc_jmp_back
        emit_byte(mc_jb8)
        // .byte_cmp:
        uint64 mc_byte = out_len
        uint64 mc_byte_disp = mc_byte - mc_jb_off - 1
        uint8 mc_bd = mc_byte_disp
        uint64 mc_patch_jb = out_buf + mc_jb_off
        unsafe { *(mc_patch_jb as uint8) = mc_bd }
        // movzx r10d, byte [rsi]
        emit_byte(0x44); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x16)
        // movzx r11d, byte [rdi]  (44 0F B6 1F)
        emit_byte(0x44); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x1F)
        // cmp r10d, r11d (45 39 DA)
        emit_byte(0x45); emit_byte(0x39); emit_byte(0xDA)
        // jne .not_equal
        emit_byte(0x75)
        uint64 mc_jne2_off = out_len
        emit_byte(0)
        // inc rsi; inc rdi; dec rcx
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC6)
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC7)
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC9)
        // jmp .loop
        emit_byte(0xEB)
        uint64 mc_jmp_back2 = mc_loop - out_len - 1
        uint8 mc_jb82 = mc_jmp_back2
        emit_byte(mc_jb82)
        // .not_equal: xor eax, eax (result = 0)
        uint64 mc_ne = out_len
        // Patch jne1 and jne2
        uint64 mc_ne1_disp = mc_ne - mc_jne1_off - 1
        uint8 mc_ned1 = mc_ne1_disp
        uint64 mc_p1 = out_buf + mc_jne1_off
        unsafe { *(mc_p1 as uint8) = mc_ned1 }
        uint64 mc_ne2_disp = mc_ne - mc_jne2_off - 1
        uint8 mc_ned2 = mc_ne2_disp
        uint64 mc_p2 = out_buf + mc_jne2_off
        unsafe { *(mc_p2 as uint8) = mc_ned2 }
        emit_byte(0x31); emit_byte(0xC0)
        // jmp .done (skip the equal path)
        emit_byte(0xEB); emit_byte(0x00)
        // .done:
        uint64 mc_done = out_len
        // Patch jz to .done
        uint64 mc_done_disp = mc_done - mc_jz_off - 1
        uint8 mc_dd = mc_done_disp
        uint64 mc_p3 = out_buf + mc_jz_off
        unsafe { *(mc_p3 as uint8) = mc_dd }
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 96 {
        // IR_ASM_BLOCK: emit inline assembly from AST node
        // src1 = AST node index
        uint64 asm_node = s1_v
        uint32 single_tok = ast_data1(asm_node)
        uint64 ws = single_tok
        if ws != 0 {
            asm_emit_x86(ws)
        }
        uint32 child_str = ast_child(asm_node)
        uint64 wcs = child_str
        while wcs != 0 {
            uint32 stk = ast_data1(wcs)
            uint64 wstk = stk
            asm_emit_x86(wstk)
            uint32 nxt = ast_next(wcs)
            wcs = nxt
        }
        return
    }

    if op == 90 {
        // IR_ATOMIC_STORE: lock xchg [ptr], val
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        uint64 val_r = ir_resolve_src(s2_v, 1)
        // lock xchg [ptr_r], val_r: F0 REX.W 87 modrm
        emit_byte(0xF0)
        uint8 as_rex = 0x48
        if val_r >= 8 { as_rex = as_rex | 4 }
        if ptr_r >= 8 { as_rex = as_rex | 1 }
        emit_byte(as_rex)
        emit_byte(0x87)
        uint8 as_modrm = ((val_r & 7) << 3) | (ptr_r & 7)
        if (ptr_r & 7) == 4 {
            emit_byte(as_modrm); emit_byte(0x24)
        } else if (ptr_r & 7) == 5 {
            uint8 asm5 = as_modrm | 0x40
            emit_byte(asm5); emit_byte(0)
        } else {
            emit_byte(as_modrm)
        }
        return
    }

    if op == 91 {
        // IR_ATOMIC_LOAD: mov dest, [ptr] + mfence
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        uint64 dr = dst_r
        if dr == 0xFFFFFFFF { dr = 0 }
        // mov dr, [ptr_r]
        uint8 al_rex = 0x48
        if dr >= 8 { al_rex = al_rex | 4 }
        if ptr_r >= 8 { al_rex = al_rex | 1 }
        emit_byte(al_rex)
        emit_byte(0x8B)
        uint8 al_modrm = ((dr & 7) << 3) | (ptr_r & 7)
        if (ptr_r & 7) == 4 {
            emit_byte(al_modrm); emit_byte(0x24)
        } else if (ptr_r & 7) == 5 {
            uint8 alm5 = al_modrm | 0x40
            emit_byte(alm5); emit_byte(0)
        } else {
            emit_byte(al_modrm)
        }
        // mfence: 0F AE F0
        emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 92 {
        // IR_ATOMIC_ADD: lock xadd [ptr], val → old value in val_r
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        uint64 val_r = ir_resolve_src(s2_v, 1)
        // lock xadd [ptr_r], val_r: F0 REX.W 0F C1 modrm
        emit_byte(0xF0)
        uint8 aa_rex = 0x48
        if val_r >= 8 { aa_rex = aa_rex | 4 }
        if ptr_r >= 8 { aa_rex = aa_rex | 1 }
        emit_byte(aa_rex)
        emit_byte(0x0F); emit_byte(0xC1)
        uint8 aa_modrm = ((val_r & 7) << 3) | (ptr_r & 7)
        if (ptr_r & 7) == 4 {
            emit_byte(aa_modrm); emit_byte(0x24)
        } else if (ptr_r & 7) == 5 {
            uint8 aam5 = aa_modrm | 0x40
            emit_byte(aam5); emit_byte(0)
        } else {
            emit_byte(aa_modrm)
        }
