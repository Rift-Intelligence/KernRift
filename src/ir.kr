            if addr_reg >= 8 { st_rex = st_rex | 1 }
            emit_byte(st_rex)
            emit_byte(0x89)
            uint64 st_modrm = ((val_reg & 7) << 3) | (addr_reg & 7)
            if (addr_reg & 7) == 4 {
                uint8 stm = st_modrm
                emit_byte(stm)
