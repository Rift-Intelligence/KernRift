        emit_byte(0x59)  // pop rcx
        // Store size at [rax]: mov [rax], rcx
        emit_byte(0x48)
        emit_byte(0x89)
        emit_byte(0x08)
        // lea rax, [rax+8] — return ptr past header
        emit_byte(0x48)
        emit_byte(0x8D)
        emit_byte(0x40)
        emit_byte(0x08)
