    }

    if op == 118 {
        // IR_FSQRT32: movd xmm0, eax; sqrtss xmm0, xmm0; movd eax, xmm0
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, a_reg)
        // movd xmm0, eax: 66 0F 6E C0
        emit_byte(0x66); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)
        // sqrtss xmm0, xmm0: F3 0F 51 C0
        emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x51); emit_byte(0xC0)
        // movd eax, xmm0: 66 0F 7E C0
        emit_byte(0x66); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0xC0)
