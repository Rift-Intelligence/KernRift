        if op == 15 { emit_byte(0x95) }  // setne
        if op == 16 { emit_byte(0x92) }  // setb  (unsigned <)
        if op == 17 { emit_byte(0x96) }  // setbe (unsigned <=)
        if op == 18 { emit_byte(0x97) }  // seta  (unsigned >)
        if op == 19 { emit_byte(0x93) }  // setae (unsigned >=)
        emit_byte(0xC0)
