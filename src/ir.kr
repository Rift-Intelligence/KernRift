        // push rdi; push rsi (save caller-saved if needed)
        ir_emit_mov_r64_r64(7, mc_dst)   // rdi = dst
        ir_emit_mov_r64_r64(6, mc_src)   // rsi = src
        ir_emit_mov_r64_r64(1, mc_len)   // rcx = len
