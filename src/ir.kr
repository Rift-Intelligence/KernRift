            // is — syscall 228 on macOS dispatches to some unrelated BSD
            // entry point that silently returns 0 in rax, which is what
            // made time_ns() come back zero on every arm64 and x86_64
            // macOS build until today.
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xEC); emit_byte(16)       // sub rsp, 16
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xE7)                      // mov rdi, rsp
            emit_byte(0x31); emit_byte(0xF6)                                       // xor esi, esi
            ir_emit_mov_r64_imm64(0, 0x2000074)                                    // mov rax, gettimeofday
            emit_byte(0x0F); emit_byte(0x05)                                       // syscall
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x04); emit_byte(0x24)     // mov rax, [rsp]
            emit_byte(0x48); emit_byte(0x69); emit_byte(0xC0)                      // imul rax, rax, 1e9
