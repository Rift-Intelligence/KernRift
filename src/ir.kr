        } else {
            // Constant size in imm — load into rax
            ir_emit_mov_r64_imm64(0, imm)
            size_reg = 0
        }
        // push original size onto stack for later
        if size_reg >= 8 {
            // push r8..r15: 41 5x
            emit_byte(0x41)
            uint64 push_opc = 0x50 | (size_reg & 7)
            uint8 po = push_opc
            emit_byte(po)
        } else {
            uint64 push_opc = 0x50 | size_reg
            uint8 po = push_opc
            emit_byte(po)
        }
        if target_os == 2 {
            // Windows: VirtualAlloc(NULL, size+8, MEM_COMMIT|MEM_RESERVE, PAGE_READWRITE)
            // xor rcx, rcx (NULL)
            emit_byte(0x48); emit_byte(0x31); emit_byte(0xC9)
            ir_emit_mov_r64_r64(2, size_reg)    // rdx = size
            // add rdx, 8
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xC2); emit_byte(0x08)
            ir_emit_mov_r64_imm64(8, 0x3000)    // r8 = MEM_COMMIT|MEM_RESERVE
            ir_emit_mov_r64_imm64(9, 4)          // r9 = PAGE_READWRITE
            emit_win_alloc_stack(0x20)
            emit_win_call_iat(6)                  // VirtualAlloc (IAT slot 6)
            emit_win_free_stack(0x20)
            // pop original size into rcx
            emit_byte(0x59)  // pop rcx
            // Store header: mov [rax], rcx
            emit_byte(0x48); emit_byte(0x89); emit_byte(0x08)
            // lea rax, [rax+8]
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x40); emit_byte(0x08)
            if dst_r != 0xFFFFFFFF && dst_r != 0 {
                ir_emit_mov_r64_r64(dst_r, 0)
