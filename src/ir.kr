        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 115 {
        // IR_SET_EXEC: chmod(path, 0755) via syscall 90
        uint64 path_r = ir_resolve_src(s1_v, 0)
        // rdi = path
        ir_emit_mov_r64_r64(7, path_r)
        // rsi = 0x1ED (0755 octal)
        ir_emit_mov_r64_imm64(6, 0x1ED)
        // rax = 90 (chmod) — OS-aware
        uint64 chmod_nr = ir_x86_syscall_nr(90)
        ir_emit_mov_r64_imm64(0, chmod_nr)
