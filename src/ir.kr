        // rsi = size + 8 (length)
        ir_emit_mov_r64_r64(6, size_reg)  // rsi = size
        // add rsi, 8
        emit_byte(0x48)
        emit_byte(0x83)
        emit_byte(0xC6)
        emit_byte(0x08)
        // xor rdi, rdi (addr = 0)
        emit_byte(0x48)
        emit_byte(0x31)
        emit_byte(0xFF)
        // mov rdx, 3 (PROT_READ|PROT_WRITE)
