        // IR_MEMCPY: dst in src1, src in src2, len vreg in imm
        // Use rep movsb: rdi=dst, rsi=src, rcx=len
        uint64 mc_dst = ir_resolve_src(s1_v, 0)
        uint64 mc_src = ir_resolve_src(s2_v, 1)
        // Resolve len from imm (stored as vreg index)
        uint64 mc_len_vreg = imm
        uint64 mc_len = 0
        if mc_len_vreg > 0 && mc_len_vreg < ir_vreg_next {
            mc_len = ir_get_phys_reg(mc_len_vreg)
            if mc_len == 0xFFFFFFFF {
