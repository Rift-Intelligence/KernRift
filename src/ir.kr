            // lea rcx, [rsp+0x20]
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x4C); emit_byte(0x24); emit_byte(0x20)
            emit_win_call_iat(15)                                               // QueryPerformanceFrequency
            // lea rcx, [rsp+0x28]
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x4C); emit_byte(0x24); emit_byte(0x28)
            emit_win_call_iat(14)                                               // QueryPerformanceCounter
            // mov rax, [rsp+0x28]   ; counter
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x44); emit_byte(0x24); emit_byte(0x28)
            // mov r11, [rsp+0x20]   ; freq
            emit_byte(0x4C); emit_byte(0x8B); emit_byte(0x5C); emit_byte(0x24); emit_byte(0x20)
            // xor edx, edx
            emit_byte(0x31); emit_byte(0xD2)
            // div r11               ; rax = counter/freq, rdx = counter%freq
            emit_byte(0x49); emit_byte(0xF7); emit_byte(0xF3)
            // mov r10, rax          ; r10 = seconds
            emit_byte(0x49); emit_byte(0x89); emit_byte(0xC2)
            // mov rax, rdx          ; rax = fractional ticks
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xD0)
            // mov r9, 1000000000
            emit_byte(0x49); emit_byte(0xC7); emit_byte(0xC1); emit_u32_le(1000000000)
            // mul r9                ; rdx:rax = fractional * 1e9
            emit_byte(0x49); emit_byte(0xF7); emit_byte(0xE1)
            // div r11               ; rax = fractional * 1e9 / freq
            emit_byte(0x49); emit_byte(0xF7); emit_byte(0xF3)
            // imul r10, r9          ; r10 = seconds * 1e9
            emit_byte(0x4D); emit_byte(0x0F); emit_byte(0xAF); emit_byte(0xD1)
            // add rax, r10
            emit_byte(0x4C); emit_byte(0x01); emit_byte(0xD0)
            // add rsp, 0x30
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xC4); emit_byte(0x30)
