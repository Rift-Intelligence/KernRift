            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 105 {
        // IR_F32TOF16: software conversion f32 bits -> f16 bits (integer result)
        // Input: f32 bit pattern in GPR (only lower 32 bits meaningful)
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, a_reg)
        // movq xmm0, rax
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)
        // movd eax, xmm0: 66 0F 7E C0
        emit_byte(0x66); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0xC0)
        // mov ecx, eax (save f32 bits)
        emit_byte(0x89); emit_byte(0xC1)
        // sign: shr eax, 16; and eax, 0x8000
        emit_byte(0xC1); emit_byte(0xE8); emit_byte(16)
        emit_byte(0x25); emit_u32_le(0x8000)
        // mov edx, eax (save sign)
        emit_byte(0x89); emit_byte(0xC2)
        // exp: mov eax, ecx; shr eax, 23; and eax, 0xFF; sub eax, 112
        emit_byte(0x89); emit_byte(0xC8)
        emit_byte(0xC1); emit_byte(0xE8); emit_byte(23)
        emit_byte(0x25); emit_u32_le(0xFF)
        emit_byte(0x2D); emit_u32_le(112)
        // clamp exp: and eax, 0x1F
        emit_byte(0x25); emit_u32_le(0x1F)
        // shl eax, 10; or edx, eax
        emit_byte(0xC1); emit_byte(0xE0); emit_byte(10)
        emit_byte(0x09); emit_byte(0xC2)
        // mantissa: mov eax, ecx; shr eax, 13; and eax, 0x3FF
        emit_byte(0x89); emit_byte(0xC8)
        emit_byte(0xC1); emit_byte(0xE8); emit_byte(13)
        emit_byte(0x25); emit_u32_le(0x3FF)
        // or eax, edx
        emit_byte(0x09); emit_byte(0xD0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 106 {
        // IR_F16TOF32: software conversion f16 bits -> f32 bits (f32 result)
        // Input: f16 bit pattern in GPR (lower 16 bits)
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, a_reg)
        // mov ecx, eax (save f16 bits)
        emit_byte(0x89); emit_byte(0xC1)
        // sign: shl eax, 16; and eax, 0x80000000
        emit_byte(0xC1); emit_byte(0xE0); emit_byte(16)
        emit_byte(0x25); emit_u32_le(0x80000000)
        // mov edx, eax (save sign)
        emit_byte(0x89); emit_byte(0xC2)
        // exp: mov eax, ecx; shr eax, 10; and eax, 0x1F; add eax, 112
        emit_byte(0x89); emit_byte(0xC8)
        emit_byte(0xC1); emit_byte(0xE8); emit_byte(10)
        emit_byte(0x25); emit_u32_le(0x1F)
        emit_byte(0x05); emit_u32_le(112)
        // shl eax, 23; or edx, eax
        emit_byte(0xC1); emit_byte(0xE0); emit_byte(23)
        emit_byte(0x09); emit_byte(0xC2)
        // mantissa: mov eax, ecx; and eax, 0x3FF; shl eax, 13
        emit_byte(0x89); emit_byte(0xC8)
        emit_byte(0x25); emit_u32_le(0x3FF)
        emit_byte(0xC1); emit_byte(0xE0); emit_byte(13)
        // or eax, edx
        emit_byte(0x09); emit_byte(0xD0)
        // Result is f32 bit pattern in eax (as uint64 in rax)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 124 {
        // IR_FMT_BOOL: buf in src1, val in src2, dest = length
        // Emits "true" (4 bytes) or "false" (5 bytes) into buf.
        uint64 fb_buf = ir_resolve_src(s1_v, 0)
        uint64 fb_val = ir_resolve_src(s2_v, 1)
        // mov r10, buf (use r10 as buffer write ptr; caller-saved)
        ir_emit_mov_r64_r64(10, fb_buf)
        // mov rax, val
        ir_emit_mov_r64_r64(0, fb_val)
        // test rax, rax
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
        // jz .false_path  (jz rel8)
        emit_byte(0x74)
        uint64 fb_jz_patch = out_len
        emit_byte(0)   // placeholder
        // .true_path:
        // mov dword [r10], 0x65757274   ('true' LE = t=74,r=72,u=75,e=65)
        // REX.B needed for r10: 41 C7 02 74 72 75 65
        emit_byte(0x41); emit_byte(0xC7); emit_byte(0x02)
        emit_byte(0x74); emit_byte(0x72); emit_byte(0x75); emit_byte(0x65)
        // mov eax, 4
        emit_byte(0xB8); emit_byte(0x04); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)
        // jmp .done (rel8)
        emit_byte(0xEB)
        uint64 fb_jmp_patch = out_len
        emit_byte(0)   // placeholder
        // .false_path:
        uint64 fb_false = out_len
        uint8 fb_jz_disp = fb_false - fb_jz_patch - 1
        uint64 fb_jz_p = out_buf + fb_jz_patch
        unsafe { *(fb_jz_p as uint8) = fb_jz_disp }
        // mov dword [r10], 0x736C6166  ('fals' LE = f=66,a=61,l=6C,s=73)
        emit_byte(0x41); emit_byte(0xC7); emit_byte(0x02)
        emit_byte(0x66); emit_byte(0x61); emit_byte(0x6C); emit_byte(0x73)
        // mov byte [r10+4], 0x65  ('e')
        // REX.B: 41 C6 42 04 65
        emit_byte(0x41); emit_byte(0xC6); emit_byte(0x42); emit_byte(0x04); emit_byte(0x65)
        // mov eax, 5
        emit_byte(0xB8); emit_byte(0x05); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)
        // .done:
        uint64 fb_done = out_len
        uint8 fb_jmp_disp = fb_done - fb_jmp_patch - 1
        uint64 fb_jmp_p = out_buf + fb_jmp_patch
        unsafe { *(fb_jmp_p as uint8) = fb_jmp_disp }
        // rax = result length
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 125 {
        // IR_FMT_F64: buf in src1, f64 bit-pattern in src2, dest = length
        // Formats as [sign][integer].[6 decimal digits] into buf.
        // Special: |x| >= 1e18 => "big"; -0.0 handled via sign check.
        uint64 ff_buf = ir_resolve_src(s1_v, 0)
        uint64 ff_val = ir_resolve_src(s2_v, 1)

        // r10 = buf (write pointer), r11 = length
        ir_emit_mov_r64_r64(10, ff_buf)   // r10 = buf
        // xor r11, r11 (length = 0): 4D 31 DB
        emit_byte(0x4D); emit_byte(0x31); emit_byte(0xDB)

        // Move val into rax, then load into xmm0
        ir_emit_mov_r64_r64(0, ff_val)   // rax = val (IEEE bits)
        // movq xmm0, rax: 66 48 0F 6E C0
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)

        // Sign check: test rax, rax; jns .ff_pos
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
        emit_byte(0x79)  // jns rel8
        uint64 ff_jns_patch = out_len
        emit_byte(0)

        // Negative: write '-', negate xmm0
        // mov byte [r10], 0x2D ('-')
        emit_byte(0x41); emit_byte(0xC6); emit_byte(0x02); emit_byte(0x2D)
        // inc r10: 49 FF C2
        emit_byte(0x49); emit_byte(0xFF); emit_byte(0xC2)
        // inc r11: 49 FF C3
        emit_byte(0x49); emit_byte(0xFF); emit_byte(0xC3)
        // Negate xmm0 via push sign-mask trick
        // push sign mask = 0x8000000000000000
        // mov rax, 0x8000000000000000; push rax
        emit_byte(0x48); emit_byte(0xB8)
        // 0x8000000000000000 little-endian:
        emit_byte(0x00); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)
        emit_byte(0x00); emit_byte(0x00); emit_byte(0x00); emit_byte(0x80)
        emit_byte(0x50)  // push rax
        // movq xmm1, [rsp]: F3 0F 7E 0C 24
        emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0x0C); emit_byte(0x24)
        // pop rax: 58
        emit_byte(0x58)
        // xorpd xmm0, xmm1: 66 0F 57 C1
        emit_byte(0x66); emit_byte(0x0F); emit_byte(0x57); emit_byte(0xC1)

        // .ff_pos:
        uint64 ff_pos = out_len
        uint8 ff_jns_disp = ff_pos - ff_jns_patch - 1
        uint64 ff_jns_p = out_buf + ff_jns_patch
        unsafe { *(ff_jns_p as uint8) = ff_jns_disp }

        // Check big: load 1e18 = 0x43ABC16D674EC800 into xmm1 via push/pop
        emit_byte(0x48); emit_byte(0xB8)
        // 1e18 LE bytes: 00 C8 4E 67 6D C1 AB 43
        emit_byte(0x00); emit_byte(0xC8); emit_byte(0x4E); emit_byte(0x67)
        emit_byte(0x6D); emit_byte(0xC1); emit_byte(0xAB); emit_byte(0x43)
        emit_byte(0x50)  // push rax
        // movq xmm1, [rsp]
        emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0x0C); emit_byte(0x24)
        emit_byte(0x58)  // pop rax
        // ucomisd xmm0, xmm1: 66 0F 2E C1
        emit_byte(0x66); emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
        // jae .ff_big (unsigned above-or-equal = >= 1e18 or NaN) — rel32 to reach far target
        emit_byte(0x0F); emit_byte(0x83)  // jae rel32
        uint64 ff_jae_patch = out_len
        emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)  // 4-byte placeholder

        // Integer part: cvttsd2si rax, xmm0: F2 48 0F 2C C0
        emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2C); emit_byte(0xC0)
        // rax = int_part. Save int_part in rcx.
        // mov rcx, rax: 48 89 C1
        emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)

        // Save xmm0 (abs val) and int_part to stack for later fraction use
        // Push xmm0 bits: movq rax, xmm0; push rax
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0xC0)
        emit_byte(0x50)  // push rax (abs val bits)

        // Format int_part (in rcx) into r10 using divide-by-10 loop
        // rdi = r10 (current write pos); rax = int_part
        ir_emit_mov_r64_r64(7, 10)   // rdi = r10
        ir_emit_mov_r64_r64(0, 1)    // rax = rcx (int_part)

