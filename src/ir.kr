        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, val_r)
        } else {
            ir_emit_mov_r64_r64(0, val_r)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 93 {
        // IR_ATOMIC_CAS: lock cmpxchg [ptr], desired
        // ptr = s1_v, expected = s2_v, desired = imm (vreg)
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        uint64 exp_r = ir_resolve_src(s2_v, 1)
        uint64 des_r = ir_resolve_src(imm, 2)
        // rax = expected (cmpxchg compares [ptr] with rax)
        ir_emit_mov_r64_r64(0, exp_r)
        // lock cmpxchg [ptr_r], des_r: F0 REX.W 0F B1 modrm
        emit_byte(0xF0)
        uint8 ac_rex = 0x48
        if des_r >= 8 { ac_rex = ac_rex | 4 }
        if ptr_r >= 8 { ac_rex = ac_rex | 1 }
        emit_byte(ac_rex)
        emit_byte(0x0F); emit_byte(0xB1)
        uint8 ac_modrm = ((des_r & 7) << 3) | (ptr_r & 7)
        if (ptr_r & 7) == 4 {
            emit_byte(ac_modrm); emit_byte(0x24)
        } else if (ptr_r & 7) == 5 {
            uint8 acm5 = ac_modrm | 0x40
            emit_byte(acm5); emit_byte(0)
        } else {
            emit_byte(ac_modrm)
        }
        // sete al; movzx eax, al → rax = 1 if swapped, 0 if not
        emit_byte(0x0F); emit_byte(0x94); emit_byte(0xC0)
        emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 94 {
        // IR_VSTORE: mfence + store (volatile), width in dest_v
        uint64 addr_reg = ir_resolve_src(s1_v, 0)
        uint64 val_reg = ir_resolve_src(s2_v, 1)
        uint64 width = dest_v
        // mfence
        emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
        if width == 8 {
            uint8 st_rex = 0x48
            if val_reg >= 8 { st_rex = st_rex | 4 }
            if addr_reg >= 8 { st_rex = st_rex | 1 }
            emit_byte(st_rex); emit_byte(0x89)
            uint64 st_modrm = ((val_reg & 7) << 3) | (addr_reg & 7)
