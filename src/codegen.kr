                uint64 mc_loop = out_len
                emit_byte(0x48); emit_byte(0x85); emit_byte(0xC9)
                // jz done (near jump, 4-byte displacement)
                emit_byte(0x0F); emit_byte(0x84)
                uint64 mc_jz = out_len
