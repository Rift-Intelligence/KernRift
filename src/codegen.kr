// KernRift self-hosted compiler — Code Generator (x86_64 ELF)
//
// Strategy: register-based codegen. Expressions evaluate into %rax.
// Variables live on the stack. Function calls use SysV ABI.
//
// Stack frame layout (per function):
//   [rsp + 0]          local variable 0
//   [rsp + 8]          local variable 1
//   ...
//   Frame size = n_locals * 8 (aligned to 16)

// Output buffer
static uint64 out_buf = 0
static uint64 out_len = 0
static uint64 out_cap = 0

// Source + token buffer (for reading token text)
static uint64 cg_source = 0
static uint64 cg_tokens = 0

// Variable table: maps variable name token → stack offset
// Simple flat array: [name_tok_idx(4), stack_offset(4)] × 256
static uint64 var_table = 0
static uint64 var_count = 0
static uint64 var_frame_size = 0

// Temp slot offset within frame (for expression evaluation)
// Reserved at function start, used by BinOp and function call arg staging
static uint64 temp_slot_0 = 0
static uint64 temp_slot_1 = 0

// Float tracking: 0 = result in rax (integer), 1 = result in xmm0 (f64), 2 = result in xmm0 (f32)
static uint64 expr_is_float = 0
// Struct literal tracking: 0xFFFFFFFF = not a struct, otherwise struct index
static uint64 expr_is_struct = 0xFFFFFFFF

// Struct pass-by-value ABI flag: 0 = pass pointer (legacy), 1 = pass eightbytes in registers
// Set to 1 when BOTH caller (Task 5) and callee (Task 6) changes are in place.
static uint64 abi_struct_pass_by_val = 1

// Debug mode: emit runtime safety checks (division by zero, etc.)
static uint64 debug_mode = 0

// Function table: maps function name → code offset in output
// [name_tok_idx(4), code_offset(4)] × 256
static uint64 fn_table = 0
static uint64 fn_count = 0

// Extern function table — functions declared with `extern fn name(params)`
// that are resolved at link time by the system linker. Each entry is
// 8 bytes: [name_tok(4), pad(4)]. Max 256 externs.
static uint64 extern_fn_table = 0
static uint64 extern_fn_count = 0

// Extern call sites — per-call-site record of where to emit a linker
// relocation. Each entry is 16 bytes:
//   [code_off(4), extern_idx(4), pad(8)]
// code_off is the byte offset of the instruction (ARM64) or of the
// 4-byte displacement (x86_64) inside the .text section.
static uint64 extern_call_sites = 0
static uint64 extern_call_count = 0

// Return fixup table: jmp offsets that need patching to epilogue
// [patch_offset(4)] × 64
static uint64 ret_fixups = 0
static uint64 ret_fixup_count = 0

// Loop context for break/continue
// [loop_start_offset(8), break_fixup_start(8)] × 16 deep
static uint64 loop_stack = 0
static uint64 loop_depth = 0
// Break fixup list: [patch_offset(4)] × 256
static uint64 break_fixups = 0
static uint64 break_fixup_count = 0

// Fixup table: call sites that need patching after all functions emitted
// [patch_offset(4), target_name_tok(4)] × 1024
static uint64 fixup_table = 0
static uint64 fixup_count = 0

// fn_addr fixup table: LEA instructions that need patching to function addresses
// [patch_offset(4), str_tok(4)] × 256
static uint64 fnaddr_fixup_table = 0
static uint64 fnaddr_fixup_count = 0

// Static variable table: maps name token → data offset in data section
// [name_tok_idx(4), data_offset(4)] × 256
static uint64 static_table = 0
static uint64 static_count = 0
static uint64 static_data_size = 0
// Parallel byte array: 0 = scalar static, >0 = array static (byte size)
static uint64 static_array_sizes = 0

// Struct metadata table
// For each struct: [name_tok(4), field_count(4), total_size(4), pad(4)]
// Followed by field entries: [field_name_tok(4), field_offset(4), field_size(4), pad(4)]
// Max 64 structs, each with max 16 fields
static uint64 struct_table = 0
static uint64 struct_count = 0

// Struct variable type tracking: maps var name_tok → struct index
// [var_name_tok(4), struct_idx(4)] × 1024
static uint64 struct_var_table = 0
static uint64 struct_var_count = 0

// Enum value table: maps (enum_name_tok, field_name_tok) → value
// [enum_name_tok(4), field_name_tok(4), value(8)] × 512
static uint64 enum_table = 0
static uint64 enum_count = 0

// Per-static-array element size (parallel to static_table, not reset per fn).
// Allows Index read/write to scale correctly for `static u64[N]`, `u32[N]`, `u16[N]`.
static uint64 static_elem_sizes = 0

// Static access fixup table: RIP-relative displacements to patch
// [code_patch_offset(4), static_data_offset(4)] × 2048
static uint64 static_fixups = 0
static uint64 static_fixup_count = 0

// String literal table: raw string bytes stored contiguously
static uint64 str_buf = 0
static uint64 str_len = 0
// String fixup table: [code_patch_offset(4), str_data_offset(4)] × 1024
static uint64 str_fixups = 0
static uint64 str_fixup_count = 0

// Target OS: 0=linux, 1=macos, 2=windows
static uint64 target_os = 0
// Active target arch: 0 = x86_64, 1 = arm64. Settable from main.kr
// via set_target_arch so ir.kr's get_arch_id lowering can pick the
// right constant without having to thread the value through every
// function call.
static uint64 target_arch = 0

@export
fn set_target_arch(uint64 v) { target_arch = v }

// Windows IAT call fixups: [patch_offset(4), iat_slot(4)] × 1024
static uint64 win_iat_fixups = 0
static uint64 win_iat_fixup_count = 0
// ARM64 Windows IAT fixups (same format)
static uint64 a64_win_iat_fixups = 0
static uint64 a64_win_iat_fixup_count = 0
// PE IAT RVA (set during PE header emission)
static uint64 pe_iat_rva = 0

// Per-scalar-static initial values (u64 each) — parallel to static_table.
// Written by static_set_init_last, read by emit_static_data.
static uint64 static_init_values = 0

// Per-static float kind (u32 each) — parallel to static_table.
//   0 = int/other (default), 1 = f64, 2 = f32, 3 = f16
// Set by the parser on declaration; read by the IR lowering to
// propagate f64/f32 type-flow through STATIC_LOAD and array Index
// reads so downstream `+`, `*` etc. pick IR_FADD/IR_FMUL instead
// of emitting integer arithmetic.
static uint64 static_fkinds = 0

// Local array element size table — records the per-element size of each
// local `TYPE[N] name` declaration so that index reads/writes can scale the
// index and use the right load/store width. Without this, u64[N]/u32[N]/
// u16[N] arrays silently miscompile (byte indexing with byte load/store).
// Keyed by variable name token; [name_tok(4), elem_size(4)] × 512.
static uint64 arr_elem_table = 0
static uint64 arr_elem_count = 0

// Type alias table: [alias_name_tok(4), target_size(4)] × 64
static uint64 type_alias_table = 0
static uint64 type_alias_count = 0

// Parameter pinning: read-only params pinned to callee-saved registers
// pin_param0_offset = stack offset of pinned param 0 (rbx), 0xFFFFFFFF = not pinned
// pin_param1_offset = stack offset of pinned param 1 (r12), 0xFFFFFFFF = not pinned
static uint64 pin_param0_offset = 0xFFFFFFFF
static uint64 pin_param1_offset = 0xFFFFFFFF
static uint64 pin_param0_tok = 0
static uint64 pin_param1_tok = 0

// Slice parameter length slot table
// Maps a slice param's ptr-slot offset → its len-slot offset.
// Used by FieldAccess to resolve `slice.len` to a load from the len slot.
// Max 32 slice params per function (way more than needed).
// Format: [ptr_off(4), len_off(4)] × 32
static uint64 slice_len_table = 0
static uint64 slice_len_count = 0

// Device block table (MMIO registers)
// Format: [name_tok(4), pad(4), base_addr(8)] × 64  (16 bytes each)
static uint64 device_table = 0
static uint64 device_count = 0
// Device field table
// Format: [dev_idx(4), field_tok(4), offset(4), size(4)] × 256  (16 bytes each)
static uint64 device_field_table = 0
static uint64 device_field_count = 0
// Binary op register spill: use r12 instead of stack for outermost binary op
static uint64 r12_in_use = 0
static uint64 r12_save_slot = 0

// sret hidden pointer slot: when a function returns a MEMORY-class struct
// (>16 bytes), the caller passes the return address as a hidden first arg
// in rdi (SysV) or rcx (Windows).  The callee saves it here at entry so
// the return path can copy the struct data to the caller-supplied buffer.
// 0xFFFFFFFF means "not an sret function".
static uint64 sret_slot = 0xFFFFFFFF

// Function return-type float table: maps fn name_tok → float kind (1=f64, 2=f32)
// [name_tok(4), float_kind(4)] × 512
static uint64 fn_ret_float_table = 0
static uint64 fn_ret_float_count = 0

// Function return-type struct table: maps fn name_tok → struct index
// [name_tok(4), struct_idx(4)] × 512
static uint64 fn_ret_struct_table = 0
static uint64 fn_ret_struct_count = 0

// IR backend mode: when 1, use SSA IR + register allocator + x86_64 emitter
static uint64 emit_ir_mode = 1

// Debug info: DWARF line table infrastructure
static uint64 debug_info_mode = 0
static uint64 line_table = 0
static uint64 line_table_count = 0
static uint64 last_recorded_line = 0
static uint64 current_file_id = 0
static uint64 debug_file_table = 0
static uint64 debug_file_count = 0

// Debug var table — persists across functions. Each 16-byte entry:
//   [0..4)   fn_idx (u32) into fn_table
//   [4..8)   name_tok (u32)
//   [8..12)  loc_value (u32) — stack_offset if kind=0, phys_reg if kind=1
//   [12..16) loc_kind (u32) — 0 = DW_OP_fbreg, 1 = DW_OP_regN
static uint64 debug_var_table = 0
static uint64 debug_var_count = 0
static uint64 debug_var_cap = 4096

@export
fn debug_var_record(uint64 fn_idx, uint64 name_tok, uint64 stack_offset) {
    debug_var_record_loc(fn_idx, name_tok, stack_offset, 0)
}

@export
fn debug_var_record_loc(uint64 fn_idx, uint64 name_tok, uint64 loc_value, uint64 loc_kind) {
    if debug_info_mode == 0 { return }
    if debug_var_table == 0 { debug_var_table = alloc(debug_var_cap * 16) }
    if debug_var_count >= debug_var_cap { return }
    uint64 entry = debug_var_table + debug_var_count * 16
    uint32 fi = fn_idx
    unsafe { *(entry as uint32) = fi }
    uint64 e4 = entry + 4
    uint32 nt = name_tok
    unsafe { *(e4 as uint32) = nt }
    uint64 e8 = entry + 8
    uint32 lv = loc_value
    unsafe { *(e8 as uint32) = lv }
    uint64 e12 = entry + 12
    uint32 lk = loc_kind
    unsafe { *(e12 as uint32) = lk }
    debug_var_count = debug_var_count + 1
}

@export
fn codegen_init(uint64 capacity, uint64 source, uint64 tokens) {
    out_buf = alloc(capacity)
    out_len = 0
    out_cap = capacity
    cg_source = source
    cg_tokens = tokens
    var_table = alloc(4096 * 8)
    var_count = 0
    fn_table = alloc(1024 * 8)
    fn_count = 0
    fixup_table = alloc(32768 * 8)
    fixup_count = 0
    ret_fixups = alloc(256 * 4)
    ret_fixup_count = 0
    struct_table = alloc(64 * 272)
    struct_count = 0
    struct_var_table = alloc(1024 * 8)
    struct_var_count = 0
    loop_stack = alloc(16 * 16)
    loop_depth = 0
    break_fixups = alloc(256 * 4)
    break_fixup_count = 0
    enum_table = alloc(512 * 16)
    enum_count = 0
    static_table = alloc(1024 * 8)
    static_array_sizes = alloc(1024 * 4)
    static_init_values = alloc(1024 * 8)
    static_elem_sizes = alloc(1024 * 4)
    static_fkinds = alloc(1024 * 4)
    slice_len_table = alloc(32 * 8)
    device_table = alloc(64 * 16)
    device_field_table = alloc(256 * 16)
    extern_fn_table = alloc(256 * 8)
    extern_fn_count = 0
    extern_call_sites = alloc(1024 * 16)
    extern_call_count = 0
    static_count = 0
    static_data_size = 0
    static_fixups = alloc(8192 * 8)
    static_fixup_count = 0
    str_buf = alloc(65536)
    str_len = 0
    str_fixups = alloc(4096 * 8)
    str_fixup_count = 0
    a64_var_base = 32
    win_iat_fixups = alloc(4096 * 8)
    win_iat_fixup_count = 0
    a64_win_iat_fixups = alloc(4096 * 8)
    a64_win_iat_fixup_count = 0
    a64_digit_buf = alloc(32)
    type_alias_table = alloc(64 * 8)
    type_alias_count = 0
    arr_elem_table = alloc(512 * 16)
    arr_elem_count = 0
    fnaddr_fixup_table = alloc(1024 * 8)
    fnaddr_fixup_count = 0
    pin_param0_offset = 0xFFFFFFFF
    pin_param1_offset = 0xFFFFFFFF
    fn_ret_float_table = alloc(512 * 8)
    fn_ret_float_count = 0
    fn_ret_struct_table = alloc(512 * 8)
    fn_ret_struct_count = 0
    line_table = alloc(65536 * 16)
    line_table_count = 0
    debug_file_table = alloc(256 * 8)
    debug_file_count = 0
}

// ---------------------------------------------------------------------------
// Emit helpers
// ---------------------------------------------------------------------------

fn emit_byte(uint8 b) {
    if out_len >= out_cap {
        // Grow the output buffer geometrically — doubling the cap and
        // memcpying the existing bytes — so callers can size codegen_init
        // for the common case (a few MB per slice) without paying a 512
        // MB virtual reservation up front. The Pi 400's 4 GB of RAM hits
        // hard swap with the old fixed cap.
        uint64 new_cap = out_cap * 2
        if new_cap < 4096 { new_cap = 4096 }
        uint64 new_buf = alloc(new_cap)
        memcpy(new_buf, out_buf, out_len)
        dealloc(out_buf)
        out_buf = new_buf
        out_cap = new_cap
    }
    uint64 p = out_buf + out_len
    unsafe { *(p as uint8) = b }
    out_len = out_len + 1
}

fn emit_u32_le(uint64 val) {
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    uint8 b2 = (val >> 16) & 0xFF
    uint8 b3 = (val >> 24) & 0xFF
    emit_byte(b0)
    emit_byte(b1)
    emit_byte(b2)
    emit_byte(b3)
}

fn emit_u64_le(uint64 val) {
    uint64 lo = val & 0xFFFFFFFF
    uint64 hi = (val >> 32) & 0xFFFFFFFF
    emit_u32_le(lo)
    emit_u32_le(hi)
}

fn emit_u16_le(uint64 val) {
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    emit_byte(b0)
    emit_byte(b1)
}

fn patch_u32(uint64 offset, uint64 val) {
    uint64 p = out_buf + offset
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    uint8 b2 = (val >> 16) & 0xFF
    uint8 b3 = (val >> 24) & 0xFF
    unsafe { *(p as uint8) = b0 }
    uint64 p1 = p + 1
    unsafe { *(p1 as uint8) = b1 }
    uint64 p2 = p + 2
    unsafe { *(p2 as uint8) = b2 }
    uint64 p3 = p + 3
    unsafe { *(p3 as uint8) = b3 }
}

fn patch_u16(uint64 offset, uint64 val) {
    uint64 p = out_buf + offset
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    unsafe { *(p as uint8) = b0 }
    uint64 p1 = p + 1
    unsafe { *(p1 as uint8) = b1 }
}

fn patch_u64(uint64 offset, uint64 val) {
    patch_u32(offset, val & 0xFFFFFFFF)
    patch_u32(offset + 4, (val >> 32) & 0xFFFFFFFF)
}

// ---------------------------------------------------------------------------
// DWARF line table recording
// ---------------------------------------------------------------------------

// Flag set by `line_table_record_fn_entry` so the next distinct line
// recording emits DW_LNS_set_prologue_end. GDB uses that flag to stop
// at the first real statement on 'break <fn>'.
static uint64 line_prologue_pending = 0

fn line_table_record(uint64 tok_idx) {
    if debug_info_mode == 0 { return }
    if tok_idx == 0 { return }
    uint64 line = tok_line_at(tok_idx)
    if line == last_recorded_line && line_table_count > 0 { return }
    if line_table_count >= 65536 { return }
    // Entry layout (16 bytes):
    //   [0..4)   code offset (u32)
    //   [4..6)   file id (u16)
    //   [6..8)   line (u16)
    //   [8..9)   flags (bit 0 = prologue_end)
    //   [9..16)  reserved
    uint64 entry = line_table + line_table_count * 16
    uint32 off = out_len
    unsafe { *(entry as uint32) = off }
    uint64 e4 = entry + 4
    uint16 fid = current_file_id
    unsafe { *(e4 as uint16) = fid }
    uint64 e6 = entry + 6
    uint16 ln = line
    unsafe { *(e6 as uint16) = ln }
    uint64 e8 = entry + 8
    uint8 fl = 0
    if line_prologue_pending != 0 {
        fl = 1
        line_prologue_pending = 0
    }
    unsafe { *(e8 as uint8) = fl }
    line_table_count = line_table_count + 1
    last_recorded_line = line
}

// Record a function's entry address and arm the prologue_end flag for
// the next line recording. Callers (main.kr fn dispatch) invoke this
// right after fn_register(). The next time line_table_record fires
// with a different line, that entry is marked so DW_LNS_set_prologue_end
// is emitted for it.
@export
fn line_table_record_fn_entry(uint64 fn_tok) {
    line_table_record(fn_tok)
    line_prologue_pending = 1
}

// LEB128 encoding helpers (for DWARF)

fn emit_uleb128(uint64 val) {
    uint64 v = val
    while v >= 128 {
        uint8 b = (v & 0x7F) | 0x80
        emit_byte(b)
        v = v >> 7
    }
    uint8 b = v & 0x7F
    emit_byte(b)
}

fn emit_sleb128(uint64 val) {
    uint64 more = 1
    uint64 v = val
    while more != 0 {
        uint8 b = v & 0x7F
        v = v >> 7
        if (b & 0x40) != 0 {
            if v == 0xFFFFFFFFFFFFFFFF { more = 0 }
        } else {
            if v == 0 { more = 0 }
        }
        if more != 0 { b = b | 0x80 }
        emit_byte(b)
    }
}

// ---------------------------------------------------------------------------
// Token text helpers
// ---------------------------------------------------------------------------

fn tok_text_start(uint64 tok_idx) -> uint64 {
    uint64 p = cg_tokens + tok_idx * 16 + 4
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn tok_text_len(uint64 tok_idx) -> uint64 {
    uint64 p = cg_tokens + tok_idx * 16 + 8
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn tok_source_byte(uint64 tok_idx, uint64 offset) -> uint64 {
    uint64 start = tok_text_start(tok_idx)
    uint64 p = cg_source + start + offset
    uint64 val = 0
    unsafe { *(p as uint8) -> val }
    return val & 0xFF
}

// Translate a single-byte escape character (the byte following `\`) to its
// resolved value. Returns 0xFFFFFFFFFFFFFFFF when the escape isn't known
// (callers pass the escape byte through verbatim in that case). Keeps the
// same table used by string-literal lowering and by the `parse_int_token`
// char-literal parser — if you add one here, mirror it in both places.
@export
fn escape_char_to_byte(uint64 esc) -> uint64 {
    if esc == 110 { return 10 }    // \n — line feed
    if esc == 116 { return 9 }     // \t — horizontal tab
    if esc == 114 { return 13 }    // \r — carriage return
    if esc == 48  { return 0 }     // \0 — null
    if esc == 92  { return 92 }    // \\ — backslash
    if esc == 34  { return 34 }    // \" — double quote
    if esc == 39  { return 39 }    // \' — single quote
    if esc == 98  { return 8 }     // \b — backspace
    if esc == 102 { return 12 }    // \f — form feed
    if esc == 118 { return 11 }    // \v — vertical tab
    if esc == 97  { return 7 }     // \a — alert / bell
    if esc == 101 { return 27 }    // \e — ESC (ANSI colour sequences)
    return 0xFFFFFFFFFFFFFFFF
}

// Parse a two-digit hex byte for `\xHH` escapes. Returns 0 when either
// digit is out of range — callers shouldn't land here unless the source
// already matched `\x`.
@export
fn hex_digit_pair_to_byte(uint64 h1, uint64 h2) -> uint64 {
    uint64 v1 = 0
    uint64 v2 = 0
    if h1 >= 48 && h1 <= 57 { v1 = h1 - 48 }
    else if h1 >= 97 && h1 <= 102 { v1 = h1 - 87 }
    else if h1 >= 65 && h1 <= 70 { v1 = h1 - 55 }
    if h2 >= 48 && h2 <= 57 { v2 = h2 - 48 }
    else if h2 >= 97 && h2 <= 102 { v2 = h2 - 87 }
    else if h2 >= 65 && h2 <= 70 { v2 = h2 - 55 }
    return v1 * 16 + v2
}

// Parse integer or char literal from token text
fn parse_int_token(uint64 tok_idx) -> uint64 {
    uint64 len = tok_text_len(tok_idx)
    // Check for boolean keywords: true → 1, false → 0
    if len == 4 && tok_source_byte(tok_idx, 0) == 116 { return 1 }
    if len == 5 && tok_source_byte(tok_idx, 0) == 102 { return 0 }
    // Check for char literal: 'x' or '\n' or '\xAB'
    if len >= 3 && tok_source_byte(tok_idx, 0) == 39 {
        if tok_source_byte(tok_idx, 1) == 92 {
            uint64 esc = tok_source_byte(tok_idx, 2)
            // \xHH — two-digit hex byte. Token shape is '\xHH' = 5 source bytes.
            if esc == 120 && len >= 5 {
                return hex_digit_pair_to_byte(tok_source_byte(tok_idx, 3),
                                              tok_source_byte(tok_idx, 4))
            }
            uint64 mapped = escape_char_to_byte(esc)
            if mapped != 0xFFFFFFFFFFFFFFFF { return mapped }
            return esc
        }
        return tok_source_byte(tok_idx, 1)
    }
    uint64 result = 0
    uint64 i = 0
    // Check for 0x prefix
    if len > 2 && tok_source_byte(tok_idx, 0) == 48 && tok_source_byte(tok_idx, 1) == 120 {
        i = 2
        while i < len {
            uint64 ch = tok_source_byte(tok_idx, i)
            result = result * 16
            if ch >= 48 && ch <= 57 { result = result + ch - 48 }
            if ch >= 97 && ch <= 102 { result = result + ch - 87 }
            if ch >= 65 && ch <= 70 { result = result + ch - 55 }
            i = i + 1
        }
    } else {
        while i < len {
            uint64 ch = tok_source_byte(tok_idx, i)
            result = result * 10 + ch - 48
            i = i + 1
        }
    }
    return result
}

// Compare two token texts for equality
fn tok_text_eq(uint64 tok_a, uint64 tok_b) -> uint64 {
    uint64 la = tok_text_len(tok_a)
    uint64 lb = tok_text_len(tok_b)
    if la != lb { return 0 }
    uint64 i = 0
    while i < la {
        if tok_source_byte(tok_a, i) != tok_source_byte(tok_b, i) { return 0 }
        i = i + 1
    }
    return 1
}

// Check if token text matches a string
fn tok_matches(uint64 tok_idx, uint64 str_ptr, uint64 str_len) -> uint64 {
    uint64 tlen = tok_text_len(tok_idx)
    if tlen != str_len { return 0 }
    uint64 start = tok_text_start(tok_idx)
    uint64 i = 0
    while i < tlen {
        uint64 sp = cg_source + start + i
        uint64 sc = 0
        unsafe { *(sp as uint8) -> sc }
        uint64 kp = str_ptr + i
        uint64 kc = 0
        unsafe { *(kp as uint8) -> kc }
        if sc != kc { return 0 }
        i = i + 1
    }
    return 1
}

// ---------------------------------------------------------------------------
// Variable table
// ---------------------------------------------------------------------------

static uint64 var_table_size = 0

static uint64 var_type_table = 0
static uint64 var_type_count = 0

fn var_reset() {
    var_count = 0
    var_frame_size = 0
    var_table_size = 0
    arr_elem_count = 0
    var_type_count = 0
    // struct_var_table is per-function: a variable named `w` typed as
    // struct A in fn f() must NOT leak into fn g() where `w` is typed as
    // struct B. Without this reset, struct_var_lookup(w) in g() would
    // return A's struct index (registered first), and struct_field_offset
    // would compute the wrong byte offset for fields shared by both
    // structs — producing silent garbage reads.
    struct_var_count = 0
}

fn var_type_init() {
    if var_type_table == 0 {
        var_type_table = alloc(8192)
    }
}

fn var_type_register(uint64 name_tok, uint64 type_kind) {
    var_type_init()
    if var_type_count >= 1024 {
        write(2, "error: var_type_table overflow (max 1024)\n", 42)
        exit(1)
    }
    uint64 entry = var_type_table + var_type_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 tk = type_kind
    unsafe { *(e4 as uint32) = tk }
    var_type_count = var_type_count + 1
}

fn var_type_lookup(uint64 name_tok) -> uint64 {
    var_type_init()
    uint64 i = 0
    while i < var_type_count {
        uint64 entry = var_type_table + i * 8
        uint32 nt = 0
        unsafe { *(entry as uint32) -> nt }
        uint64 wnt = nt
        if tok_text_eq(wnt, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 tk = 0
            unsafe { *(e4 as uint32) -> tk }
            uint64 wtk = tk
            return wtk
        }
        i = i + 1
    }
    return 0
}

// Walk an AST expression to decide whether it produces a signed-int value.
// The legacy backend has no per-vreg metadata, so we re-derive signedness
// from the source. Used to pick setl/setle/setg/setge over setb/setbe/seta/
// setae and idiv/sar over div/shr. See the IR-backend signed flag for the
// equivalent on the new path.
fn legacy_node_is_signed(uint64 ast_node) -> uint64 {
    if ast_node == 0 { return 0 }
    uint32 nk = ast_kind(ast_node)
    uint64 wnk = nk
    // Ident: look up declared type — int8/16/32/64 (lexer kinds 84..87) signed.
    if wnk == 32 {
        uint32 ntok = ast_data1(ast_node)
        uint64 wntok = ntok
        uint64 vt = var_type_lookup(wntok)
        if vt == 84 { return 1 }
        if vt == 85 { return 1 }
        if vt == 86 { return 1 }
        if vt == 87 { return 1 }
        return 0
    }
    // BinOp: signed if either operand is.
    if wnk == 33 {
        uint32 lhs_n = ast_child(ast_node)
        uint64 wlhs_n = lhs_n
        if legacy_node_is_signed(wlhs_n) != 0 { return 1 }
        uint32 rhs_n = ast_data2(ast_node)
        uint64 wrhs_n = rhs_n
        if legacy_node_is_signed(wrhs_n) != 0 { return 1 }
        return 0
    }
    // UnaryOp negate (-x): always produces a signed value.
    if wnk == 34 {
        uint32 op_tok_n = ast_data1(ast_node)
        uint64 wop_n = op_tok_n
        uint64 p_n = cg_tokens + wop_n * 16
        uint32 op_k_n = 0
        unsafe { *(p_n as uint32) -> op_k_n }
        if op_k_n == 31 { return 1 }
        return 0
    }
    // Call f64_to_int: cvttsd2si is signed truncation.
    if wnk == 35 {
        uint32 ct = ast_data1(ast_node)
        uint64 wct = ct
        if tok_matches(wct, "f64_to_int", 10) != 0 { return 1 }
        return 0
    }
    return 0
}

fn var_declare(uint64 name_tok) -> uint64 {
    // Check if variable already declared in this function (handles shadowing)
    uint64 existing = var_lookup(name_tok)
    if existing != 0xFFFFFFFF {
        return existing
    }
    if var_table_size >= 4096 {
        write(2, "error: var_table overflow (max 4096)\n", 37)
        exit(1)
    }
    uint64 offset = var_count * 8
    uint64 entry = var_table + var_table_size * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 off32 = offset
    unsafe { *(e4 as uint32) = off32 }
    var_table_size = var_table_size + 1
    var_count = var_count + 1
    var_frame_size = var_count * 8
    // Align frame to 16 bytes
    uint64 rem = var_frame_size & 15
    if rem != 0 {
        var_frame_size = var_frame_size + 16 - rem
    }
    // Persist in the DWARF debug-var table (no-op unless -g is active).
    // fn_count is the CURRENT function's index — it's incremented by
    // fn_register at the start of each function, so the current fn
    // lives at fn_count - 1 when var_declare is called.
    uint64 cur_fn_idx = 0
    if fn_count > 0 { cur_fn_idx = fn_count - 1 }
    debug_var_record(cur_fn_idx, name_tok, offset)
    return offset
}

fn var_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < var_table_size {
        uint64 entry = var_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Struct metadata
// ---------------------------------------------------------------------------

// Each struct entry is 16 bytes header + 16 bytes per field = 16 + 16*16 = 272 max
@export
fn struct_register(uint64 name_tok) -> uint64 {
    if struct_count >= 64 {
        write(2, "error: struct_table overflow (max 64)\n", 38)
        exit(1)
    }
    uint64 base = struct_table + struct_count * 272
    uint32 nt = name_tok
    unsafe { *(base as uint32) = nt }
    // field_count = 0 initially
    uint64 fc_addr = base + 4
    uint32 zero = 0
    unsafe { *(fc_addr as uint32) = zero }
    uint64 idx = struct_count
    struct_count = struct_count + 1
    return idx
}

@export
fn struct_add_field(uint64 struct_idx, uint64 field_tok, uint64 field_size, uint64 field_type_kind) {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    // Compute field offset = current total_size (uint16 at offset 8)
    uint64 ts_addr = base + 8
    uint16 ts = 0
    unsafe { *(ts_addr as uint16) -> ts }
    uint64 wts = ts
    // Write field entry at header(16) + field_idx * 16
    uint64 fentry = base + 16 + wfc * 16
    uint32 ft = field_tok
    unsafe { *(fentry as uint32) = ft }
    uint64 fo_addr = fentry + 4
    uint32 fo = wts
    unsafe { *(fo_addr as uint32) = fo }
    uint64 fs_addr = fentry + 8
    uint32 fs = field_size
    unsafe { *(fs_addr as uint32) = fs }
    // Store field type kind at fentry + 12
    uint64 ftk_addr = fentry + 12
    uint32 ftk32 = field_type_kind
    unsafe { *(ftk_addr as uint32) = ftk32 }
    // Update field_count and total_size
    uint32 new_fc = wfc + 1
    unsafe { *(fc_addr as uint32) = new_fc }
    uint16 new_ts = wts + field_size
    unsafe { *(ts_addr as uint16) = new_ts }
}

fn struct_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < struct_count {
        uint64 base = struct_table + i * 272
        uint32 stored = 0
        unsafe { *(base as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            return i
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn struct_total_size(uint64 struct_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272 + 8
    uint16 ts = 0
    unsafe { *(base as uint16) -> ts }
    return ts
}

fn struct_field_offset(uint64 struct_idx, uint64 field_tok) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint32 ft = 0
        unsafe { *(fentry as uint32) -> ft }
        uint64 wft = ft
        if tok_text_eq(wft, field_tok) != 0 {
            uint64 fo_addr = fentry + 4
            uint32 fo = 0
            unsafe { *(fo_addr as uint32) -> fo }
            return fo
        }
        fi = fi + 1
    }
    return 0xFFFFFFFF
}

fn struct_field_size(uint64 struct_idx, uint64 field_tok) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint32 ft = 0
        unsafe { *(fentry as uint32) -> ft }
        uint64 wft = ft
        if tok_text_eq(wft, field_tok) != 0 {
            uint64 fs_addr = fentry + 8
            uint32 fs = 0
            unsafe { *(fs_addr as uint32) -> fs }
            return fs
        }
        fi = fi + 1
    }
    return 0
}

fn struct_field_type_kind(uint64 struct_idx, uint64 field_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fentry = base + 16 + field_idx * 16 + 12
    uint32 val = 0
    unsafe { *(fentry as uint32) -> val }
    return val
}

fn struct_field_type_kind_by_tok(uint64 struct_idx, uint64 field_tok) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint32 ft = 0
        unsafe { *(fentry as uint32) -> ft }
        uint64 wft = ft
        if tok_text_eq(wft, field_tok) != 0 {
            uint64 ftk_addr = fentry + 12
            uint32 ftk = 0
            unsafe { *(ftk_addr as uint32) -> ftk }
            return ftk
        }
        fi = fi + 1
    }
    return 0
}

@export
fn struct_classify_abi(uint64 struct_idx) {
    uint64 base = struct_table + struct_idx * 272
    uint64 size = struct_total_size(struct_idx)

    if size > 16 {
        // MEMORY class
        uint64 c0_addr = base + 12
        uint16 mem = 3
        unsafe { *(c0_addr as uint16) = mem }
        uint64 c1_addr = base + 14
        unsafe { *(c1_addr as uint16) = mem }
        return
    }

    uint64 class0 = 0
    uint64 class1 = 0
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint64 fo_addr = fentry + 4
        uint32 fo = 0
        unsafe { *(fo_addr as uint32) -> fo }
        uint64 field_off = fo
        uint64 eightbyte = field_off / 8
        uint64 ftk = struct_field_type_kind(struct_idx, fi)
        uint64 is_float = 0
        if ftk == 94 || ftk == 95 || ftk == 96 { is_float = 1 }
        if eightbyte == 0 {
            if is_float != 0 && class0 == 0 { class0 = 2 }
            if is_float == 0 { class0 = 1 }
        }
        if eightbyte == 1 {
            if is_float != 0 && class1 == 0 { class1 = 2 }
            if is_float == 0 { class1 = 1 }
        }
        fi = fi + 1
    }
    uint64 c0_addr = base + 12
    uint16 c0_16 = class0
    unsafe { *(c0_addr as uint16) = c0_16 }
    uint64 c1_addr = base + 14
    uint16 c1_16 = class1
    unsafe { *(c1_addr as uint16) = c1_16 }

    // ARM64 HFA detection
    uint64 flags = 0
    if wfc >= 1 && wfc <= 4 {
        uint64 first_ftk = struct_field_type_kind(struct_idx, 0)
        uint64 all_same_float = 0
        if first_ftk == 95 || first_ftk == 96 { all_same_float = 1 }
        uint64 ci = 1
        while ci < wfc {
            uint64 ci_ftk = struct_field_type_kind(struct_idx, ci)
            if ci_ftk != first_ftk { all_same_float = 0 }
            ci = ci + 1
        }
        if all_same_float != 0 {
            uint64 hfa_type = 0
            if first_ftk == 96 { hfa_type = 1 }
            flags = 1 | ((wfc - 1) << 1) | (hfa_type << 3)
        }
    }
    uint64 flags_addr = base + 10
    uint16 fl16 = flags
    unsafe { *(flags_addr as uint16) = fl16 }
}

fn struct_abi_class0(uint64 struct_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272 + 12
    uint16 val = 0
    unsafe { *(base as uint16) -> val }
    return val
}

fn struct_abi_class1(uint64 struct_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272 + 14
    uint16 val = 0
    unsafe { *(base as uint16) -> val }
    return val
}

fn struct_abi_flags(uint64 struct_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272 + 10
    uint16 val = 0
    unsafe { *(base as uint16) -> val }
    return val
}

// Track which variables are struct-typed
fn struct_var_register(uint64 var_tok, uint64 struct_idx) {
    if struct_var_count >= 1024 {
        write(2, "error: struct_var_table overflow (max 1024)\n", 44)
        exit(1)
    }
    uint64 entry = struct_var_table + struct_var_count * 8
    uint32 vt = var_tok
    unsafe { *(entry as uint32) = vt }
    uint64 e4 = entry + 4
    uint32 si = struct_idx
    unsafe { *(e4 as uint32) = si }
    struct_var_count = struct_var_count + 1
}

fn struct_var_lookup(uint64 var_tok) -> uint64 {
    uint64 i = 0
    while i < struct_var_count {
        uint64 entry = struct_var_table + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, var_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 si = 0
            unsafe { *(e4 as uint32) -> si }
            return si
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Enum value table
// ---------------------------------------------------------------------------

@export
fn enum_register(uint64 enum_tok, uint64 field_tok, uint64 value) {
    if enum_count >= 512 {
        write(2, "error: enum_table overflow (max 512)\n", 37)
        exit(1)
    }
    uint64 entry = enum_table + enum_count * 16
    uint32 et = enum_tok
    unsafe { *(entry as uint32) = et }
    uint64 e4 = entry + 4
    uint32 ft = field_tok
    unsafe { *(e4 as uint32) = ft }
    uint64 e8 = entry + 8
    unsafe { *(e8 as uint64) = value }
    enum_count = enum_count + 1
}

fn enum_lookup(uint64 enum_tok, uint64 field_tok) -> uint64 {
    uint64 i = 0
    while i < enum_count {
        uint64 entry = enum_table + i * 16
        uint32 stored_enum = 0
        unsafe { *(entry as uint32) -> stored_enum }
        uint64 we = stored_enum
        if tok_text_eq(we, enum_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 stored_field = 0
            unsafe { *(e4 as uint32) -> stored_field }
            uint64 wf = stored_field
            if tok_text_eq(wf, field_tok) != 0 {
                uint64 e8 = entry + 8
                uint64 val = 0
                unsafe { *(e8 as uint64) -> val }
                return val
            }
        }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// Static variable table
// ---------------------------------------------------------------------------

@export
fn static_declare(uint64 name_tok) -> uint64 {
    if static_count >= 1024 {
        write(2, "error: static_table overflow (max 1024)\n", 40)
        exit(1)
    }
    uint64 offset = static_data_size
    uint64 entry = static_table + static_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 off32 = offset
    unsafe { *(e4 as uint32) = off32 }
    // Mark as scalar (0 in array_sizes)
    uint64 ae = static_array_sizes + static_count * 4
    uint32 zero32 = 0
    unsafe { *(ae as uint32) = zero32 }
    // Default initial value = 0
    uint64 iv = static_init_values + static_count * 8
    unsafe { *(iv as uint64) = 0 }
    // Default fkind = 0 (int/other)
    uint64 fk = static_fkinds + static_count * 4
    unsafe { *(fk as uint32) = zero32 }
    static_count = static_count + 1
    static_data_size = static_data_size + 8
    return offset
}

// Set the initial 8-byte value for the most recently declared scalar static.
// Called by the parser for `const TYPE name = LITERAL` and `static TYPE name = LITERAL`.
@export
fn static_set_init_last(uint64 value) {
    if static_count == 0 { return }
    uint64 idx = static_count - 1
    uint64 iv = static_init_values + idx * 8
    unsafe { *(iv as uint64) = value }
}

// Mark the most recently declared static as f64 (fk=1), f32 (fk=2),
// etc. — called by the parser when it sees `static f64 x` / `static f32 x`
// / `static f64[N] arr`. Fixes the f64 type-flow bug where reads of
// a declared-float static otherwise produce uint64-typed vregs that
// downstream arithmetic mis-interprets as integer ops.
@export
fn static_set_fkind_last(uint64 fk) {
    if static_count == 0 { return }
    uint64 idx = static_count - 1
    uint64 ep = static_fkinds + idx * 4
    uint32 fk32 = fk
    unsafe { *(ep as uint32) = fk32 }
}

// Look up the fkind (0/1/2/3) of a static by its name_tok. Returns 0
// if not found or if the static isn't a float type.
@export
fn static_fkind_of(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 ep = static_fkinds + i * 4
            uint32 fk = 0
            unsafe { *(ep as uint32) -> fk }
            return fk
        }
        i = i + 1
    }
    return 0
}

// Device table helpers: device_register returns the new device index.
@export
fn device_register(uint64 name_tok, uint64 base_addr) -> uint64 {
    if device_count >= 64 {
        write(2, "error: device_table overflow (max 64)\n", 38)
        exit(1)
    }
    uint64 entry = device_table + device_count * 16
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e8 = entry + 8
    unsafe { *(e8 as uint64) = base_addr }
    uint64 idx = device_count
    device_count = device_count + 1
    return idx
}

@export
fn device_add_field(uint64 dev_idx, uint64 field_tok, uint64 offset, uint64 size) {
    if device_field_count >= 256 {
        write(2, "error: device_field_table overflow (max 256)\n", 45)
        exit(1)
    }
    uint64 entry = device_field_table + device_field_count * 16
    uint32 di = dev_idx
    unsafe { *(entry as uint32) = di }
    uint64 e4 = entry + 4
    uint32 ft = field_tok
    unsafe { *(e4 as uint32) = ft }
    uint64 e8 = entry + 8
    uint32 off32 = offset
    unsafe { *(e8 as uint32) = off32 }
    uint64 ec = entry + 12
    uint32 sz32 = size
    unsafe { *(ec as uint32) = sz32 }
    device_field_count = device_field_count + 1
}

// Look up device by name_tok. Returns 0xFFFFFFFF if not found.
fn device_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < device_count {
        uint64 entry = device_table + i * 16
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 { return i }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Get base address of a device
fn device_base(uint64 dev_idx) -> uint64 {
    uint64 entry = device_table + dev_idx * 16
    uint64 e8 = entry + 8
    uint64 base = 0
    unsafe { *(e8 as uint64) -> base }
    return base
}

// Look up a device field. Returns offset OR 0xFFFFFFFF if not found.
fn device_field_offset_of(uint64 dev_idx, uint64 field_tok) -> uint64 {
    uint64 i = 0
    while i < device_field_count {
        uint64 entry = device_field_table + i * 16
        uint32 stored_dev = 0
        unsafe { *(entry as uint32) -> stored_dev }
        uint64 wsd = stored_dev
        if wsd == dev_idx {
            uint64 e4 = entry + 4
            uint32 stored_field = 0
            unsafe { *(e4 as uint32) -> stored_field }
            uint64 wsf = stored_field
            if tok_text_eq(wsf, field_tok) != 0 {
                uint64 e8 = entry + 8
                uint32 off = 0
                unsafe { *(e8 as uint32) -> off }
                return off
            }
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn device_field_size_of(uint64 dev_idx, uint64 field_tok) -> uint64 {
    uint64 i = 0
    while i < device_field_count {
        uint64 entry = device_field_table + i * 16
        uint32 stored_dev = 0
        unsafe { *(entry as uint32) -> stored_dev }
        uint64 wsd = stored_dev
        if wsd == dev_idx {
            uint64 e4 = entry + 4
            uint32 stored_field = 0
            unsafe { *(e4 as uint32) -> stored_field }
            uint64 wsf = stored_field
            if tok_text_eq(wsf, field_tok) != 0 {
                uint64 ec = entry + 12
                uint32 sz = 0
                unsafe { *(ec as uint32) -> sz }
                return sz
            }
        }
        i = i + 1
    }
    return 0
}

// Record a slice parameter's length slot. Per-function, cleared on function entry.
fn slice_len_register(uint64 ptr_off, uint64 len_off) {
    if slice_len_count >= 32 {
        write(2, "error: slice_len_table overflow (max 32)\n", 41)
        exit(1)
    }
    uint64 entry = slice_len_table + slice_len_count * 8
    uint32 po = ptr_off
    unsafe { *(entry as uint32) = po }
    uint64 e4 = entry + 4
    uint32 lo = len_off
    unsafe { *(e4 as uint32) = lo }
    slice_len_count = slice_len_count + 1
}

// Look up a slice's length slot offset by its ptr slot offset. Returns 0xFFFFFFFF if not a slice.
fn slice_len_lookup(uint64 ptr_off) -> uint64 {
    uint64 i = 0
    while i < slice_len_count {
        uint64 entry = slice_len_table + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if ws == ptr_off {
            uint64 e4 = entry + 4
            uint32 lo = 0
            unsafe { *(e4 as uint32) -> lo }
            return lo
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

@export
fn static_declare_array(uint64 name_tok, uint64 byte_size) -> uint64 {
    if static_count >= 1024 {
        write(2, "error: static_table overflow (max 1024)\n", 40)
        exit(1)
    }
    // Align static_data_size up to 8 for clean placement
    uint64 rem = static_data_size & 7
    if rem != 0 { static_data_size = static_data_size + 8 - rem }
    uint64 offset = static_data_size
    uint64 entry = static_table + static_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 off32 = offset
    unsafe { *(e4 as uint32) = off32 }
    // Mark as array by storing byte_size in parallel table
    uint64 ae = static_array_sizes + static_count * 4
    uint32 bs32 = byte_size
    unsafe { *(ae as uint32) = bs32 }
    // Default element size = 1 (byte); parser calls static_set_elem_size_last
    // right after this for wider element types.
    uint64 es = static_elem_sizes + static_count * 4
    uint32 one32 = 1
    unsafe { *(es as uint32) = one32 }
    // Default fkind = 0 (int/other); parser calls static_set_fkind_last
    // right after this for f32/f64 arrays.
    uint64 fkp = static_fkinds + static_count * 4
    uint32 zero_fk = 0
    unsafe { *(fkp as uint32) = zero_fk }
    static_count = static_count + 1
    // Allocate byte_size bytes, padded to 8-byte boundary
    uint64 padded = byte_size
    uint64 brem = byte_size & 7
    if brem != 0 { padded = byte_size + 8 - brem }
    static_data_size = static_data_size + padded
    return offset
}

// Record the element size for the most recently declared static array.
// Called by the parser right after static_declare_array when the array's
// element type is wider than u8.
@export
fn static_set_elem_size_last(uint64 elem_size) {
    if static_count == 0 { return }
    uint64 idx = static_count - 1
    uint64 es = static_elem_sizes + idx * 4
    uint32 sz = elem_size
    unsafe { *(es as uint32) = sz }
}

// Look up a static array's element size by name_tok. Returns 1 (byte) if
// the name isn't a static array.
@export
fn static_elem_size_of(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 es = static_elem_sizes + i * 4
            uint32 sz = 0
            unsafe { *(es as uint32) -> sz }
            return sz
        }
        i = i + 1
    }
    return 1
}

// Return byte size if name_tok refers to a static array, 0 if scalar, 0xFFFFFFFF if not found
fn static_array_size_of(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 ae = static_array_sizes + i * 4
            uint32 sz = 0
            unsafe { *(ae as uint32) -> sz }
            return sz
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn static_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Look up a static by literal name (for generated code, not user code)
fn static_lookup_by_name(uint64 name_str, uint64 name_len) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_matches(ws, name_str, name_len) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Type alias table
// ---------------------------------------------------------------------------

@export
fn type_alias_register(uint64 name_tok, uint64 target_size) {
    if type_alias_count >= 64 {
        write(2, "error: type_alias_table overflow (max 64)\n", 42)
        exit(1)
    }
    uint64 entry = type_alias_table + type_alias_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 ts = target_size
    unsafe { *(e4 as uint32) = ts }
    type_alias_count = type_alias_count + 1
}

@export
fn type_alias_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < type_alias_count {
        uint64 entry = type_alias_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 ts = 0
            unsafe { *(e4 as uint32) -> ts }
            return ts
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Map a type keyword token (u8..u64 / i8..i64 / uint8..uint64) to its byte size.
// Default 1 (byte) for anything else, so legacy u8 arrays keep working.
fn type_tok_elem_size(uint64 type_tok) -> uint64 {
    uint64 p = cg_tokens + type_tok * 16
    uint32 k = 0
    unsafe { *(p as uint32) -> k }
    uint64 wk = k
    if wk == 80 { return 1 }
    if wk == 98 { return 1 }
    if wk == 99 { return 1 }
    if wk == 81 { return 2 }
    if wk == 82 { return 4 }
    if wk == 83 { return 8 }
    if wk == 84 { return 1 }
    if wk == 85 { return 2 }
    if wk == 86 { return 4 }
    if wk == 87 { return 8 }
    if wk == 94 { return 2 }
    if wk == 95 { return 4 }
    if wk == 96 { return 8 }
    return 1
}

// Register a local array's element size so that index ops can scale correctly.
fn arr_elem_register(uint64 name_tok, uint64 elem_size) {
    if arr_elem_count >= 512 {
        write(2, "error: arr_elem_table overflow (max 512)\n", 41)
        exit(1)
    }
    uint64 entry = arr_elem_table + arr_elem_count * 16
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 es = elem_size
    unsafe { *(e4 as uint32) = es }
    // Default count = 0 means "unknown / unchecked" for bounds.
    uint64 e8 = entry + 8
    uint32 zero32 = 0
    unsafe { *(e8 as uint32) = zero32 }
    arr_elem_count = arr_elem_count + 1
}

// Record the element count for the most recently declared array.
// Callers invoke this after arr_elem_register with the literal size.
// A count of 0 leaves the slot as "unknown" — no bounds check emitted.
@export
fn arr_count_set_last(uint64 count) {
    if arr_elem_count == 0 { return }
    uint64 entry = arr_elem_table + (arr_elem_count - 1) * 16
    uint64 e8 = entry + 8
    uint32 c32 = count
    unsafe { *(e8 as uint32) = c32 }
}

// Look up an array's element size. Checks local (per-function) array
// declarations first, then falls through to module-level static arrays.
// Returns 1 (byte) for anything else — keeps raw alloc + byte-indexed code
// paths unchanged.
fn arr_elem_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < arr_elem_count {
        uint64 entry = arr_elem_table + i * 16
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 es = 0
            unsafe { *(e4 as uint32) -> es }
            return es
        }
        i = i + 1
    }
    return static_elem_size_of(name_tok)
}

// Return the declared element count of an array, or 0xFFFFFFFF if
// the size is not known at compile time. Looks at stack-array
// declarations first, then derives the count for static arrays
// from their byte size and element size.
@export
fn arr_count_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < arr_elem_count {
        uint64 entry = arr_elem_table + i * 16
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e8 = entry + 8
            uint32 c = 0
            unsafe { *(e8 as uint32) -> c }
            uint64 wc = c
            if wc == 0 { return 0xFFFFFFFF }
            return wc
        }
        i = i + 1
    }
    // Static array path: bytes / elem_size.
    uint64 bytes = static_array_size_of(name_tok)
    if bytes == 0xFFFFFFFF || bytes == 0 { return 0xFFFFFFFF }
    uint64 es = static_elem_size_of(name_tok)
    if es == 0 { return 0xFFFFFFFF }
    return bytes / es
}

// Emit: load static at data_offset into rax (RIP-relative, placeholder)
fn emit_static_load(uint64 data_offset) {
    if static_fixup_count >= 8192 {
        write(2, "error: static_fixups overflow (max 8192)\n", 41)
        exit(1)
    }
    // mov disp32(%rip), %rax → 48 8B 05 [disp32]
    emit_byte(0x48)
    emit_byte(0x8B)
    emit_byte(0x05)
    // Record fixup: patch this disp32 later
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_u32_le(0)
}

// Emit: lea rax, [rip + disp32] — RIP-relative address of a static
// Used for static arrays to put the address of the data in rax.
fn emit_static_lea(uint64 data_offset) {
    if static_fixup_count >= 8192 {
        write(2, "error: static_fixups overflow (max 8192)\n", 41)
        exit(1)
    }
    // lea rax, [rip + disp32] → 48 8D 05 [disp32]
    emit_byte(0x48)
    emit_byte(0x8D)
    emit_byte(0x05)
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_u32_le(0)
    // Invalidate the rax cache: rax now holds a static address, not [rsp+*]
    rax_cache = 0
}

// Emit: store rax to static at data_offset (RIP-relative, placeholder)
fn emit_static_store(uint64 data_offset) {
    if static_fixup_count >= 8192 {
        write(2, "error: static_fixups overflow (max 8192)\n", 41)
        exit(1)
    }
    // mov %rax, disp32(%rip) → 48 89 05 [disp32]
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0x05)
    // Record fixup
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_u32_le(0)
}

// Resolve all static RIP-relative fixups. Call after all code is emitted.
// data_start = out_len at the time statics are placed.
@export
fn resolve_static_fixups(uint64 data_start) {
    uint64 i = 0
    while i < static_fixup_count {
        uint64 fentry = static_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 data_off = 0
        unsafe { *(fe4 as uint32) -> data_off }
        // RIP = code_off + 4 (past the disp32 bytes)
        // target = data_start + data_off
        // disp = target - RIP
        uint64 rip = code_off + 4
        uint64 wdo = data_off
        uint64 target = data_start + wdo
        uint64 disp = target - rip
        patch_u32(code_off, disp)
        i = i + 1
    }
}

// Emit string literal data
@export
fn emit_string_data() {
    uint64 i = 0
    while i < str_len {
        uint64 sp = str_buf + i
        uint8 b = 0
        unsafe { *(sp as uint8) -> b }
        emit_byte(b)
        i = i + 1
    }
}

// Resolve string literal RIP-relative fixups
@export
fn resolve_string_fixups(uint64 str_data_start) {
    uint64 i = 0
    while i < str_fixup_count {
        uint64 fentry = str_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 str_off = 0
        unsafe { *(fe4 as uint32) -> str_off }
        uint64 rip = code_off + 4
        uint64 wso = str_off
        uint64 target = str_data_start + wso
        uint64 disp = target - rip
        patch_u32(code_off, disp)
        i = i + 1
    }
}

// Emit zero-initialized data for all statics
@export
fn emit_static_data() {
    // Walk the static table in declaration order. Scalar slots (array_size==0)
    // get their recorded init value; array slots stay zero.
    uint64 emitted = 0
    uint64 si = 0
    while si < static_count {
        // offset of this slot within the static data segment
        uint64 entry = static_table + si * 8
        uint64 e4 = entry + 4
        uint32 slot_off = 0
        unsafe { *(e4 as uint32) -> slot_off }
        // Pad with zeros up to this slot's offset
        while emitted < slot_off {
            emit_byte(0)
            emitted = emitted + 1
        }
        uint64 asp = static_array_sizes + si * 4
        uint32 asz = 0
        unsafe { *(asp as uint32) -> asz }
        if asz == 0 {
            // Scalar: 8 bytes of init value
            uint64 ivp = static_init_values + si * 8
            uint64 val = 0
            unsafe { *(ivp as uint64) -> val }
            uint64 bi = 0
            while bi < 8 {
                uint8 b = (val >> (bi * 8)) & 0xFF
                emit_byte(b)
                bi = bi + 1
            }
            emitted = emitted + 8
        } else {
            // Array: emit `asz` zero bytes
            uint64 ai = 0
            while ai < asz {
                emit_byte(0)
                ai = ai + 1
            }
            emitted = emitted + asz
        }
        si = si + 1
    }
    // Final tail of zeros (alignment/padding)
    while emitted < static_data_size {
        emit_byte(0)
        emitted = emitted + 1
    }
}

// ---------------------------------------------------------------------------
// Function table
// ---------------------------------------------------------------------------

fn fn_register(uint64 name_tok, uint64 code_offset) {
    if fn_count >= 1024 {
        write(2, "error: fn_table overflow (max 1024)\n", 36)
        exit(1)
    }
    uint64 entry = fn_table + fn_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 co = code_offset
    unsafe { *(e4 as uint32) = co }
    fn_count = fn_count + 1
}

// Per-function `@section("name")` annotation storage. Each entry is 16
// bytes: u32 fn_name_tok, u32 section_text_start, u32 section_text_len,
// u32 reserved. Keyed by the function's name token (not its index in
// fn_table because this may be populated before fn_register runs).
static uint64 fn_section_table = 0
static uint64 fn_section_count = 0

fn fn_section_init() {
    if fn_section_table == 0 {
        fn_section_table = alloc(1024 * 16)
    }
}

@export
fn fn_section_set(uint64 name_tok, uint64 str_start, uint64 str_len) {
    fn_section_init()
    if fn_section_count >= 1024 { return }
    uint64 entry = fn_section_table + fn_section_count * 16
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 ss = str_start
    unsafe { *(e4 as uint32) = ss }
    uint64 e8 = entry + 8
    uint32 sl = str_len
    unsafe { *(e8 as uint32) = sl }
    fn_section_count = fn_section_count + 1
}

// Returns the section string's byte range as (start << 32) | len, or
// 0 if the function has no @section annotation.
@export
fn fn_section_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_section_count {
        uint64 entry = fn_section_table + i * 16
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 ss = 0
            unsafe { *(e4 as uint32) -> ss }
            uint64 e8 = entry + 8
            uint32 sl = 0
            unsafe { *(e8 as uint32) -> sl }
            uint64 wss = ss
            uint64 wsl = sl
            return (wss << 32) | wsl
        }
        i = i + 1
    }
    return 0
}

fn fn_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_count {
        uint64 entry = fn_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Register an extern function. Returns its extern index for later use.
@export
fn extern_fn_register(uint64 name_tok) -> uint64 {
    if extern_fn_count >= 256 {
        write(2, "error: extern_fn_table overflow (max 256)\n", 42)
        exit(1)
    }
    uint64 idx = extern_fn_count
    uint64 entry = extern_fn_table + extern_fn_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    extern_fn_count = extern_fn_count + 1
    return idx
}

// Return the extern index for a given name_tok, or 0xFFFFFFFF if not extern.
@export
fn extern_fn_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < extern_fn_count {
        uint64 entry = extern_fn_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 { return i }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Record an extern call site for later relocation emission.
// code_off is the byte offset inside the .text section:
//   x86_64: the start of the 4-byte disp32 (call site + 1)
//   ARM64:  the start of the BL instruction
fn extern_call_record(uint64 code_off, uint64 extern_idx) {
    if extern_call_count >= 1024 {
        write(2, "error: extern_call_sites overflow (max 1024)\n", 45)
        exit(1)
    }
    uint64 entry = extern_call_sites + extern_call_count * 16
    uint32 co = code_off
    unsafe { *(entry as uint32) = co }
    uint64 e4 = entry + 4
    uint32 xi = extern_idx
    unsafe { *(e4 as uint32) = xi }
    extern_call_count = extern_call_count + 1
}

// ---------------------------------------------------------------------------
// x86_64 code emission
// ---------------------------------------------------------------------------

// emit: mov rax, imm64
fn emit_mov_rax_imm(uint64 val) {
    rax_invalidate()
    if val == 0 {
        // xor eax, eax (2 bytes, zero-extends to rax)
        emit_byte(0x31)
        emit_byte(0xC0)
        return
    }
    if val <= 0x7FFFFFFF {
        // mov eax, imm32 (5 bytes, zero-extends)
        emit_byte(0xB8)
        emit_u32_le(val)
    } else {
        // movabs rax, imm64 (10 bytes)
        emit_byte(0x48)
        emit_byte(0xB8)
        emit_u64_le(val)
    }
}

// emit: mov [rsp+off], rax
// Register cache: tracks if rax already holds a stack slot value
// rax_cache = 0 means not cached, rax_cache = offset+1 means rax holds [rsp+offset]
static uint64 rax_cache = 0

fn rax_invalidate() {
    rax_cache = 0
}

fn emit_store_rax_to_stack(uint64 offset) {
    emit_byte(0x48)
    emit_byte(0x89)
    if offset == 0 {
        emit_byte(0x04)
        emit_byte(0x24)
    } else if offset < 128 {
        emit_byte(0x44)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
    // After store, rax still holds the value for this offset
    rax_cache = offset + 1
}

// Store rdx into [rsp+offset]. ModR/M reg field = rdx (2), so the middle
// byte differs from the rax version by 0x10. Used for 2-tuple destructure.
fn emit_store_rdx_to_stack(uint64 offset) {
    emit_byte(0x48)
    emit_byte(0x89)
    if offset == 0 {
        emit_byte(0x14)
        emit_byte(0x24)
    } else if offset < 128 {
        emit_byte(0x54)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x94)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd xmm0, [rsp+offset] — load f64 from stack
fn emit_load_xmm0_f64(uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10)
    if offset < 128 {
        emit_byte(0x44); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd [rsp+offset], xmm0 — store f64 to stack
fn emit_store_xmm0_f64(uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x11)
    if offset < 128 {
        emit_byte(0x44); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movss xmm0, [rsp+offset] — load f32 from stack
fn emit_load_xmm0_f32(uint64 offset) {
    emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x10)
    if offset < 128 {
        emit_byte(0x44); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movss [rsp+offset], xmm0 — store f32 to stack
fn emit_store_xmm0_f32(uint64 offset) {
    emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x11)
    if offset < 128 {
        emit_byte(0x44); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd xmm1, [rsp+offset] — load f64 into temp register
fn emit_load_xmm1_f64(uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10)
    if offset < 128 {
        emit_byte(0x4C); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x8C); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movss xmm1, [rsp+offset] — load f32 into temp register
fn emit_load_xmm1_f32(uint64 offset) {
    emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x10)
    if offset < 128 {
        emit_byte(0x4C); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x8C); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd xmm1, [rsp+offset] — store f64 from temp register
fn emit_store_xmm1_f64(uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x11)
    if offset < 128 {
        emit_byte(0x4C); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x8C); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd xmmN, [rsp+offset] — load f64 into xmmN (N=0..7)
fn emit_load_xmmN_f64(uint64 reg, uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10)
    uint8 reg3 = reg << 3
    if offset < 128 {
        uint8 mb = 0x44 | reg3
        emit_byte(mb); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        uint8 mb = 0x84 | reg3
        emit_byte(mb); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd [rsp+offset], xmmN — store f64 from xmmN (N=0..7)
fn emit_store_xmmN_f64(uint64 reg, uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x11)
    uint8 reg3 = reg << 3
    if offset < 128 {
        uint8 mb = 0x44 | reg3
        emit_byte(mb); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        uint8 mb = 0x84 | reg3
        emit_byte(mb); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// Pre-pass helpers used by the type checker to register return-types
// before codegen runs without leaving stray duplicates behind.
@export
fn fn_ret_struct_count_get() -> uint64 { return fn_ret_struct_count }
@export
fn fn_ret_struct_count_set(uint64 v) { fn_ret_struct_count = v }
@export
fn fn_ret_float_count_get() -> uint64 { return fn_ret_float_count }
@export
fn fn_ret_float_count_set(uint64 v) { fn_ret_float_count = v }

// Register a function's float return type
fn fn_ret_float_register(uint64 name_tok, uint64 float_kind) {
    if fn_ret_float_count >= 512 {
        write(2, "error: fn_ret_float_table overflow (max 512)\n", 45)
        exit(1)
    }
    uint64 entry = fn_ret_float_table + fn_ret_float_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 fk = float_kind
    unsafe { *(e4 as uint32) = fk }
    fn_ret_float_count = fn_ret_float_count + 1
}

// Look up a function's float return type: 0=int, 1=f64, 2=f32
fn fn_ret_float_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_ret_float_count {
        uint64 entry = fn_ret_float_table + i * 8
        uint32 nt = 0
        unsafe { *(entry as uint32) -> nt }
        uint64 wnt = nt
        if tok_text_eq(wnt, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 fk = 0
            unsafe { *(e4 as uint32) -> fk }
            uint64 wfk = fk
            return wfk
        }
        i = i + 1
    }
    return 0
}

// Register a function's struct return type
fn fn_ret_struct_register(uint64 name_tok, uint64 struct_idx) {
    if fn_ret_struct_count >= 512 {
        write(2, "error: fn_ret_struct_table overflow (max 512)\n", 46)
        exit(1)
    }
    uint64 entry = fn_ret_struct_table + fn_ret_struct_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 si = struct_idx
    unsafe { *(e4 as uint32) = si }
    fn_ret_struct_count = fn_ret_struct_count + 1
}

// Look up a function's struct return type: 0xFFFFFFFF = not struct, else struct_idx
fn fn_ret_struct_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_ret_struct_count {
        uint64 entry = fn_ret_struct_table + i * 8
        uint32 nt = 0
        unsafe { *(entry as uint32) -> nt }
        uint64 wnt = nt
        if tok_text_eq(wnt, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 si = 0
            unsafe { *(e4 as uint32) -> si }
            uint64 wsi = si
            return wsi
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Helper: is this type token a float type?
fn is_float_type(uint64 type_kind) -> uint64 {
    if type_kind == 95 { return 1 }
    if type_kind == 96 { return 1 }
    return 0
}

fn is_f32_type(uint64 type_kind) -> uint64 {
    if type_kind == 95 { return 1 }
    return 0
}

// Helper: get token kind from token index (reads from token array)
fn tok_kind_at_raw(uint64 tok_idx) -> uint64 {
    uint64 p = cg_tokens + tok_idx * 16
    uint32 k = 0
    unsafe { *(p as uint32) -> k }
    uint64 wk = k
    return wk
}

// Parse an x86_64 register name token into a 4-bit register code.
// Returns 0..15 for recognised names, 0xFFFF for unknown.
// Recognised: rax..rdi (0..7), r8..r15 (8..15).
fn x86_reg_code(uint64 name_tok) -> uint64 {
    if tok_matches(name_tok, "rax", 3) != 0 { return 0 }
    if tok_matches(name_tok, "rcx", 3) != 0 { return 1 }
    if tok_matches(name_tok, "rdx", 3) != 0 { return 2 }
    if tok_matches(name_tok, "rbx", 3) != 0 { return 3 }
    if tok_matches(name_tok, "rsp", 3) != 0 { return 4 }
    if tok_matches(name_tok, "rbp", 3) != 0 { return 5 }
    if tok_matches(name_tok, "rsi", 3) != 0 { return 6 }
    if tok_matches(name_tok, "rdi", 3) != 0 { return 7 }
    if tok_matches(name_tok, "r8", 2)  != 0 { return 8 }
    if tok_matches(name_tok, "r9", 2)  != 0 { return 9 }
    if tok_matches(name_tok, "r10", 3) != 0 { return 10 }
    if tok_matches(name_tok, "r11", 3) != 0 { return 11 }
    if tok_matches(name_tok, "r12", 3) != 0 { return 12 }
    if tok_matches(name_tok, "r13", 3) != 0 { return 13 }
    if tok_matches(name_tok, "r14", 3) != 0 { return 14 }
    if tok_matches(name_tok, "r15", 3) != 0 { return 15 }
    return 0xFFFF
}

// Emit `mov dst, src` for any two 64-bit registers (0..15).
// ModR/M: mod=3, reg=src, rm=dst. REX.W always; REX.R if src>=8; REX.B if dst>=8.
fn emit_mov_reg_reg(uint64 dst, uint64 src) {
    uint8 rex = 0x48
    if src >= 8 { rex = rex | 0x04 }   // REX.R
    if dst >= 8 { rex = rex | 0x01 }   // REX.B
    emit_byte(rex)
    emit_byte(0x89)
    uint8 mb = 0xC0 | ((src & 7) << 3) | (dst & 7)
    emit_byte(mb)
}

// Emit `mov reg, [rsp+offset]` for any 64-bit reg (0..15). Used to load
// an asm-block input variable into the register named by the constraint.
// Handles pinned params (rbx/r12) by emitting a reg-reg move instead.
fn emit_mov_reg_from_stack(uint64 reg, uint64 offset) {
    if offset == pin_param0_offset && pin_param0_offset != 0xFFFFFFFF {
        emit_mov_reg_reg(reg, 3)   // mov reg, rbx
        return
    }
    if offset == pin_param1_offset && pin_param1_offset != 0xFFFFFFFF {
        emit_mov_reg_reg(reg, 12)  // mov reg, r12
        return
    }
    uint8 rex = 0x48
    if reg >= 8 { rex = 0x4C }
    emit_byte(rex)
    emit_byte(0x8B)
    uint64 reg3 = (reg & 7) << 3
    if offset < 128 {
        uint8 mb = 0x44 | reg3
        emit_byte(mb)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        uint8 mb = 0x84 | reg3
        emit_byte(mb)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// Emit `mov [rsp+offset], reg` for any 64-bit reg (0..15). Used to store
// an asm-block output register into the destination variable slot.
fn emit_mov_reg_to_stack(uint64 reg, uint64 offset) {
    uint8 rex = 0x48
    if reg >= 8 { rex = 0x4C }
    emit_byte(rex)
    emit_byte(0x89)
    uint64 reg3 = (reg & 7) << 3
    if offset < 128 {
        uint8 mb = 0x44 | reg3
        emit_byte(mb)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        uint8 mb = 0x84 | reg3
        emit_byte(mb)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// emit: mov rax, [rsp+off] — skipped if rax already holds this value
fn emit_load_rax_from_stack(uint64 offset) {
    // Pinned param0: use rbx instead of stack
    if offset == pin_param0_offset && pin_param0_offset != 0xFFFFFFFF {
        if rax_cache == offset + 1 { return }
        // mov rax, rbx (48 89 D8)
        emit_byte(0x48); emit_byte(0x89); emit_byte(0xD8)
        rax_cache = offset + 1
        return
    }
    // Check cache: if rax already holds [rsp+offset], skip the load
    if rax_cache == offset + 1 { return }
    emit_byte(0x48)
    emit_byte(0x8B)
    if offset == 0 {
        emit_byte(0x04)
        emit_byte(0x24)
    } else if offset < 128 {
        emit_byte(0x44)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
    rax_cache = offset + 1
}

// emit: push rax
fn emit_push_rax() {
    rax_invalidate()
    emit_byte(0x50)
}

// emit: pop rcx
fn emit_pop_rcx() {
    emit_byte(0x59)
}

// emit: add rax, rcx
fn emit_add_rax_rcx() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x01)
    emit_byte(0xC8)
}

// emit: sub rax, rcx  (rax = rax - rcx)
fn emit_sub_rax_rcx() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x29)
    emit_byte(0xC8)
}

// emit: imul rax, rcx
fn emit_mul_rax_rcx() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x0F)
    emit_byte(0xAF)
    emit_byte(0xC1)
}

// emit: mov rdi, rax (first arg)
fn emit_mov_rdi_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC7)
}

// emit: mov rsi, rax (second arg)
fn emit_mov_rsi_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC6)
}

// emit: mov rdx, rax (third arg)
fn emit_mov_rdx_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC2)
}

// ---------------------------------------------------------------------------
// Windows x64 ABI helpers
// ---------------------------------------------------------------------------

fn win_fixup_add(uint64 patch_off, uint64 slot) {
    if win_iat_fixup_count >= 4096 {
        write(2, "error: win_iat_fixups overflow (max 4096)\n", 42)
        exit(1)
    }
    uint64 entry = win_iat_fixups + win_iat_fixup_count * 8
    uint32 po = patch_off
    unsafe { *(entry as uint32) = po }
    uint64 e4 = entry + 4
    uint32 sl = slot
    unsafe { *(e4 as uint32) = sl }
    win_iat_fixup_count = win_iat_fixup_count + 1
}

// sub rsp, N for Windows API calls (N must keep RSP 16-byte aligned)
// After prologue (push rbx + sub rsp, frame), RSP is 16-aligned
// So we need N divisible by 16 for alignment
// Use 0x20 (32) for <=4 args, 0x30 (48) for 5 args, 0x40 (64) for 7 args
fn emit_win_alloc_stack(uint64 nbytes) {
    emit_byte(0x48)
    emit_byte(0x83)
    emit_byte(0xEC)
    uint8 nb = nbytes
    emit_byte(nb)
}

fn emit_win_free_stack(uint64 nbytes) {
    emit_byte(0x48)
    emit_byte(0x83)
    emit_byte(0xC4)
    uint8 nb = nbytes
    emit_byte(nb)
}

// mov rcx, rax (Windows 1st arg)
fn emit_mov_rcx_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC1)
}

// mov r8, rax (Windows 3rd arg)
fn emit_mov_r8_rax() {
    emit_byte(0x49)
    emit_byte(0x89)
    emit_byte(0xC0)
}

// mov r9, imm32 (sign-extended, Windows 4th arg)
fn emit_mov_r9_imm(uint64 val) {
    emit_byte(0x49)
    emit_byte(0xC7)
    emit_byte(0xC1)
    emit_u32_le(val)
}

// call qword [rip + disp32] — IAT indirect call
// All 13 entries are loader-resolved; slot 0-12 maps directly to IAT[0..12]
fn emit_win_call_iat(uint64 slot) {
    rax_invalidate()
    emit_byte(0xFF)
    emit_byte(0x15)
    uint64 patch_off = out_len
    emit_u32_le(0)
    win_fixup_add(patch_off, slot)
}

// mov [rip + disp32], rax — store resolved fn ptr to IAT slot
fn emit_win_store_iat(uint64 slot) {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0x05)
    uint64 patch_off = out_len
    emit_u32_le(0)
    win_fixup_add(patch_off, slot)
}

// ABI helper: which register holds integer arg N?
// Returns register code: 0=rax, 1=rcx, 2=rdx, 3=rbx, 6=rsi, 7=rdi, 8=r8, 9=r9
// Returns 0xFFFF if the arg goes on the stack.
fn abi_arg_register(uint64 idx, uint64 os) -> uint64 {
    if os == 2 {
        if idx == 0 { return 1 }
        if idx == 1 { return 2 }
        if idx == 2 { return 8 }
        if idx == 3 { return 9 }
        return 0xFFFF
    }
    if idx == 0 { return 7 }
    if idx == 1 { return 6 }
    if idx == 2 { return 2 }
    if idx == 3 { return 1 }
    if idx == 4 { return 8 }
    if idx == 5 { return 9 }
    return 0xFFFF
}

fn abi_reg_count(uint64 os) -> uint64 {
    if os == 2 { return 4 }
    return 6
}

// Stack offset for overflow arg idx, from callee's rsp after prologue.
// frame_adjust = var_frame_size + 8 (push rbx)
fn abi_overflow_offset(uint64 idx, uint64 os, uint64 frame_adjust) -> uint64 {
    if os == 2 {
        return frame_adjust + 8 + 32 + (idx - 4) * 8
    }
    return frame_adjust + 8 + (idx - 6) * 8
}

// Helper: add a null-terminated string to str_buf, return its offset
fn resolver_add_str(uint64 s) -> uint64 {
    uint64 soff = str_len
    uint64 i = 0
    uint64 p = s + i
    uint64 ch = 0
    unsafe { *(p as uint8) -> ch }
    while ch != 0 {
        if str_len >= 65536 {
            write(2, "error: str_buf overflow (max 65536)\n", 36)
            exit(1)
        }
        uint8 cb = ch
        uint64 dp = str_buf + str_len
        unsafe { *(dp as uint8) = cb }
        str_len = str_len + 1
        i = i + 1
        p = s + i
        unsafe { *(p as uint8) -> ch }
    }
    if str_len >= 65536 {
        write(2, "error: str_buf overflow (max 65536)\n", 36)
        exit(1)
    }
    uint64 dp = str_buf + str_len
    uint8 nz = 0
    unsafe { *(dp as uint8) = nz }
    str_len = str_len + 1
    return soff
}

// Helper: emit lea rdx, [rip+disp32] with string fixup
fn emit_lea_rdx_str(uint64 str_offset) {
    if str_fixup_count >= 4096 {
        write(2, "error: str_fixups overflow (max 4096)\n", 38)
        exit(1)
    }
    emit_byte(0x48); emit_byte(0x8D); emit_byte(0x15)
    uint64 fentry = str_fixups + str_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 so = str_offset
    unsafe { *(fe4 as uint32) = so }
    str_fixup_count = str_fixup_count + 1
    emit_u32_le(0)
}

// Helper: emit lea rcx, [rip+disp32] with string fixup
fn emit_lea_rcx_str(uint64 str_offset) {
    if str_fixup_count >= 4096 {
        write(2, "error: str_fixups overflow (max 4096)\n", 38)
        exit(1)
    }
    emit_byte(0x48); emit_byte(0x8D); emit_byte(0x0D)
    uint64 fentry = str_fixups + str_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 so = str_offset
    unsafe { *(fe4 as uint32) = so }
    str_fixup_count = str_fixup_count + 1
    emit_u32_le(0)
}

// neg rax
fn emit_neg_rax() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0xF7)
    emit_byte(0xD8)
}

// sub rax, imm8
fn emit_sub_rax_imm8(uint64 val) {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x83)
    emit_byte(0xE8)
    uint8 b = val
    emit_byte(b)
}

// mov [rsp+32], imm32 (5th arg on stack for Windows calls)
fn emit_win_stack_arg5(uint64 val) {
    emit_byte(0x48)
    emit_byte(0xC7)
    emit_byte(0x44)
    emit_byte(0x24)
    emit_byte(0x20)
    emit_u32_le(val)
}

// Resolve Windows IAT fixups: patch call [rip+disp32] with correct displacement
// text_start: offset of code within file, iat_rva: RVA of IAT in .idata section
@export
fn resolve_win_iat_fixups(uint64 text_start, uint64 iat_rva) {
    // PE image base = 0x140000000, text section RVA = 0x1000
    // Code at file offset text_start corresponds to RVA 0x1000
    // So code at file offset X has RVA = 0x1000 + (X - text_start)
    // RIP at end of call instruction = RVA of byte after the disp32
    // Target = iat_rva + slot * 8
    // disp32 = target_rva - rip_rva
    uint64 i = 0
    while i < win_iat_fixup_count {
        uint64 entry = win_iat_fixups + i * 8
        uint32 patch_off = 0
        unsafe { *(entry as uint32) -> patch_off }
        uint64 e4 = entry + 4
        uint32 slot = 0
        unsafe { *(e4 as uint32) -> slot }
        uint64 wpatch = patch_off
        uint64 wslot = slot
        // RIP at end of this instruction = RVA of (patch_off + 4)
        uint64 rip_rva = 0x1000 + (wpatch + 4 - text_start)
        uint64 target_rva = iat_rva + wslot * 8
        // disp32 = target_rva - rip_rva (signed 32-bit)
        uint64 disp = target_rva - rip_rva
        patch_u32(wpatch, disp & 0xFFFFFFFF)
        i = i + 1
    }
}

// emit: setCC al + movzx eax, al (flags already set by caller)
fn emit_setcc(uint64 op_tok_kind) {
    emit_byte(0x0F)
    if op_tok_kind == 35 { emit_byte(0x94) }
    else if op_tok_kind == 36 { emit_byte(0x95) }
    else if op_tok_kind == 37 { emit_byte(0x92) }
    else if op_tok_kind == 38 { emit_byte(0x96) }
    else if op_tok_kind == 39 { emit_byte(0x97) }
    else if op_tok_kind == 40 { emit_byte(0x93) }
    else { emit_byte(0x94) }
    emit_byte(0xC0)
    emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0) // movzx eax, al
}

// Signed-aware setcc: signed inputs need setl/setle/setg/setge (0x9C/0x9E/
// 0x9F/0x9D) instead of unsigned setb/setbe/seta/setae. Equality (==/!=)
// stays bitwise — sign doesn't change those.
fn emit_setcc_typed(uint64 op_tok_kind, uint64 is_signed) {
    if is_signed == 0 {
        emit_setcc(op_tok_kind)
        return
    }
    emit_byte(0x0F)
    if op_tok_kind == 35 { emit_byte(0x94) }
    else if op_tok_kind == 36 { emit_byte(0x95) }
    else if op_tok_kind == 37 { emit_byte(0x9C) }       // setl
    else if op_tok_kind == 38 { emit_byte(0x9E) }       // setle
    else if op_tok_kind == 39 { emit_byte(0x9F) }       // setg
    else if op_tok_kind == 40 { emit_byte(0x9D) }       // setge
    else { emit_byte(0x94) }
    emit_byte(0xC0)
    emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)   // movzx eax, al
}

fn emit_compare_typed(uint64 op_tok_kind, uint64 is_signed) {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x39)
    emit_byte(0xC8)
    emit_setcc_typed(op_tok_kind, is_signed)
}

// emit: cmp rax, rcx + setCC al + movzx eax, al
fn emit_compare(uint64 op_tok_kind) {
    rax_invalidate()
    // cmp rax, rcx
    emit_byte(0x48)
    emit_byte(0x39)
    emit_byte(0xC8)

    emit_setcc(op_tok_kind)
}


// ---------------------------------------------------------------------------
// AST code generation (recursive)
// ---------------------------------------------------------------------------

// Generate code for an expression. Result is in %rax.
@export
fn gen_expr(uint64 node) {
    // Invalidate rax cache — gen_expr will put a new value in rax
    rax_invalidate()
    expr_is_struct = 0xFFFFFFFF

    // Record line for debug info
    uint32 dbg_tok = ast_tok(node)
    if dbg_tok == 0 { dbg_tok = ast_data1(node) }
    uint64 wdbg = dbg_tok
    if wdbg != 0 { line_table_record(wdbg) }

    uint32 kind = ast_kind(node)

    // Unary operator: !, -, ~
    if kind == 34 {
        uint32 operand_idx = ast_child(node)
        uint64 wop = operand_idx
        gen_expr(wop)
        // Determine op from token kind
        uint32 op_tok = ast_data1(node)
        uint64 wot = op_tok
        uint64 p = cg_tokens + wot * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }
        uint64 wok = op_kind
        if wok == 27 {
            // ! logical NOT: test rax, rax; sete al; movzbl al, eax
            emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
            emit_byte(0x0F); emit_byte(0x94); emit_byte(0xC0)
            emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)
        } else if wok == 31 {
            // - negate: neg rax
            emit_byte(0x48); emit_byte(0xF7); emit_byte(0xD8)
        } else if wok == 26 {
            // ~ bitwise NOT: not rax
            emit_byte(0x48); emit_byte(0xF7); emit_byte(0xD0)
        }
        return
    }

    // sizeof literal → mov rax, compile-time size
    if kind == 49 {
        uint32 sz_lo = ast_data1(node)
        uint64 val = sz_lo
        emit_mov_rax_imm(val)
        expr_is_float = 0
        return
    }

    // StructLit — struct literal expression
    if kind == 48 {
        uint32 sname_tok = ast_data1(node)
        uint64 wsn = sname_tok
        uint64 si = struct_lookup(wsn)
        uint64 ssize = struct_total_size(si)
        // Allocate temp stack area for struct
        uint64 slit_base = var_count * 8
        uint64 slots_needed = (ssize + 7) / 8
        var_count = var_count + slots_needed
        var_frame_size = var_count * 8
        uint64 srem = var_frame_size & 15
        if srem != 0 { var_frame_size = var_frame_size + 16 - srem }

        // Walk field expressions and store each
        uint32 is_named = ast_data2(node)
        uint64 wnamed = is_named
        uint32 fchild = ast_child(node)
        uint64 wfchild = fchild
        uint64 fidx = 0
        while wfchild != 0 {
            gen_expr(wfchild)
            // rax = field value
            // Determine field offset and size
            uint64 foff = 0
            uint64 fsize = 8
            if wnamed != 0 {
                // Named: field name stored in tok_idx of the child expression
                uint32 fname = ast_tok(wfchild)
                uint64 wfn = fname
                foff = struct_field_offset(si, wfn)
                fsize = struct_field_size(si, wfn)
            } else {
                // Positional: use field index to get offset/size from struct table
                uint64 fbase = struct_table + si * 272 + 16 + fidx * 16
                uint64 foff_addr = fbase + 4
                uint32 fo32 = 0
                unsafe { *(foff_addr as uint32) -> fo32 }
                foff = fo32
                uint64 fs_addr = fbase + 8
                uint32 fs32 = 0
                unsafe { *(fs_addr as uint32) -> fs32 }
                fsize = fs32
            }
            // If expr produced a float, move xmm0 bits into rax
            if expr_is_float == 1 {
                // movq rax, xmm0: 66 48 0F 7E C0
                emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F)
                emit_byte(0x7E); emit_byte(0xC0)
            }
            if expr_is_float == 2 {
                // movd eax, xmm0: 66 0F 7E C0
                emit_byte(0x66); emit_byte(0x0F)
                emit_byte(0x7E); emit_byte(0xC0)
            }
            // Store rax to [rsp + slit_base + foff] with appropriate width
            uint64 dest = slit_base + foff
            if fsize == 8 {
                emit_store_rax_to_stack(dest)
            } else if fsize == 4 {
                // mov [rsp+dest], eax
                if dest < 128 {
                    emit_byte(0x89); emit_byte(0x44); emit_byte(0x24)
                    uint8 d8 = dest; emit_byte(d8)
                } else {
                    emit_byte(0x89); emit_byte(0x84); emit_byte(0x24)
                    emit_u32_le(dest)
                }
            } else if fsize == 2 {
                // mov [rsp+dest], ax
                if dest < 128 {
                    emit_byte(0x66); emit_byte(0x89); emit_byte(0x44)
                    emit_byte(0x24); uint8 d8 = dest; emit_byte(d8)
                } else {
                    emit_byte(0x66); emit_byte(0x89); emit_byte(0x84)
                    emit_byte(0x24); emit_u32_le(dest)
                }
            } else {
                // mov [rsp+dest], al
                if dest < 128 {
                    emit_byte(0x88); emit_byte(0x44); emit_byte(0x24)
                    uint8 d8 = dest; emit_byte(d8)
                } else {
                    emit_byte(0x88); emit_byte(0x84); emit_byte(0x24)
                    emit_u32_le(dest)
                }
            }
            fidx = fidx + 1
            uint32 fnxt = ast_next(wfchild)
            wfchild = fnxt
        }
        // Result: lea rax, [rsp + slit_base]
        if slit_base < 128 {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44)
            emit_byte(0x24); uint8 sb8 = slit_base; emit_byte(sb8)
        } else {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x84)
            emit_byte(0x24); emit_u32_le(slit_base)
        }
        expr_is_struct = si
        expr_is_float = 0
        return
    }

    // Integer literal → mov rax, value
    if kind == 30 {
        uint32 tok = ast_data1(node)
        uint64 val = parse_int_token(tok)
        emit_mov_rax_imm(val)
        expr_is_float = 0
        return
    }

    // Float literal
    if kind == 46 {
        uint32 lit_tok_f = ast_data1(node)
        uint64 tstart_f = tok_text_start(lit_tok_f)
        uint64 tlen_f = tok_text_len(lit_tok_f)

        // Parse integer part (digits before '.') and fractional part (after '.')
        uint64 int_val = 0
        uint64 frac_val = 0
        uint64 frac_divisor = 1
        uint64 past_dot = 0
        uint64 fi = 0
        while fi < tlen_f {
            uint64 cp_f = cg_source + tstart_f + fi
            uint64 ch_f = 0
            unsafe { *(cp_f as uint8) -> ch_f }
            if ch_f == 46 { past_dot = 1; fi = fi + 1; continue }
            if ch_f == 102 { fi = fi + 1; continue }
            if ch_f >= 48 && ch_f <= 57 {
                if past_dot == 0 {
                    int_val = int_val * 10 + (ch_f - 48)
                } else {
                    frac_val = frac_val * 10 + (ch_f - 48)
                    frac_divisor = frac_divisor * 10
                }
            }
            fi = fi + 1
        }

        if frac_val == 0 {
            // No fractional part (e.g., 3.0) — just convert integer
            emit_mov_rax_imm(int_val)
            // cvtsi2sd xmm0, rax: F2 48 0F 2A C0
            emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)
        } else {
            // Full float: int_part + frac_part / 10^digits
            // Step 1: xmm0 = int_to_f64(int_val), save to temp_slot_0
            emit_mov_rax_imm(int_val)
            emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)
            emit_store_xmm0_f64(temp_slot_0)

            // Step 2: xmm0 = int_to_f64(frac_val)
            emit_mov_rax_imm(frac_val)
            emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)

            // Step 3: xmm1 = int_to_f64(frac_divisor)
            emit_store_xmm0_f64(temp_slot_1)
            emit_mov_rax_imm(frac_divisor)
            emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)
            // movsd xmm1, xmm0: F2 0F 10 C8
            emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
            emit_load_xmm0_f64(temp_slot_1)

            // Step 4: xmm0 = frac_val / frac_divisor
            // divsd xmm0, xmm1: F2 0F 5E C1
            emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1)

            // Step 5: xmm0 += int_part (from temp_slot_0)
            emit_load_xmm1_f64(temp_slot_0)
            // addsd xmm0, xmm1: F2 0F 58 C1
            emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1)
        }

        // Check for 'f' suffix → f32
        uint64 last_p = cg_source + tstart_f + tlen_f - 1
        uint64 last_c = 0
        unsafe { *(last_p as uint8) -> last_c }
        if last_c == 102 {
            // cvtsd2ss xmm0, xmm0: F2 0F 5A C0 (narrow f64 → f32)
            emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5A); emit_byte(0xC0)
            expr_is_float = 2
        } else {
            expr_is_float = 1
        }
        return
    }

    // String literal → store bytes in str_buf, emit LEA rip-relative
    if kind == 31 {
        uint32 tok = ast_data1(node)
        uint64 wtok = tok
        uint64 tstart = tok_text_start(wtok)
        uint64 tlen = tok_text_len(wtok)
        // Check str_buf capacity before copying
        if str_len + tlen >= 65536 {
            write(2, "error: str_buf overflow (max 65536)\n", 36)
            exit(1)
        }
        // String data offset in str_buf
        uint64 str_offset = str_len
        // Copy string bytes (skip opening quote, process escapes, skip closing quote)
        uint64 si = 1
        while si < tlen - 1 {
            uint64 ch = tok_source_byte(wtok, si)
            if ch == 92 {
                si = si + 1
                uint64 esc = tok_source_byte(wtok, si)
                if esc == 120 && si + 2 < tlen {
                    // \xHH — consume two hex digits
                    ch = hex_digit_pair_to_byte(tok_source_byte(wtok, si + 1),
                                                tok_source_byte(wtok, si + 2))
                    si = si + 2
                } else {
                    uint64 mapped = escape_char_to_byte(esc)
                    if mapped != 0xFFFFFFFFFFFFFFFF { ch = mapped }
                    else { ch = esc }
                }
            }
            uint64 sp = str_buf + str_len
            uint8 cb = ch
            unsafe { *(sp as uint8) = cb }
            str_len = str_len + 1
            si = si + 1
        }
        // Null-terminate
        uint64 sp = str_buf + str_len
        uint8 zero = 0
        unsafe { *(sp as uint8) = zero }
        str_len = str_len + 1
        // Emit: lea disp32(%rip), %rax → 48 8D 05 [disp32]
        if str_fixup_count >= 4096 {
            write(2, "error: str_fixups overflow (max 4096)\n", 38)
            exit(1)
        }
        emit_byte(0x48)
        emit_byte(0x8D)
        emit_byte(0x05)
        // Record fixup
        uint64 fentry = str_fixups + str_fixup_count * 8
        uint32 cp = out_len
        unsafe { *(fentry as uint32) = cp }
        uint64 fe4 = fentry + 4
        uint32 so = str_offset
        unsafe { *(fe4 as uint32) = so }
        str_fixup_count = str_fixup_count + 1
        emit_u32_le(0)
        return
    }

    // FString (50) — legacy x86: build interpolated string
    // Concatenates StrPart content (baked to str_buf at compile time) and
    // formats expression values into a stack buffer at var_frame_size.
    // Returns rax = pointer to null-terminated result buffer.
    if kind == 50 {
        uint64 fs_buf_off = var_frame_size  // scratch area above frame
        // zero the running offset: temp_slot_1 = 0
        emit_byte(0x48); emit_byte(0x31); emit_byte(0xC0)  // xor rax, rax
        emit_store_rax_to_stack(temp_slot_1)

        uint32 fs_child = ast_child(node)
        uint64 wfs_child = fs_child
        while wfs_child != 0 {
            uint32 fs_ck = ast_kind(wfs_child)
            if fs_ck == 31 {
                uint32 fs_raw = ast_data2(wfs_child)
                uint64 wfs_raw = fs_raw
                if wfs_raw != 0 {
                    // Raw StrPart: bake into str_buf, emit lea rsi + rep movsb
                    uint32 fs_tok = ast_data1(wfs_child)
                    uint64 wfs_tok = fs_tok
                    uint64 fs_tlen = tok_text_len(wfs_tok)
                    if fs_tlen != 0 {
                        if str_len + fs_tlen >= 65536 {
                            write(2, "error: str_buf overflow\n", 24)
                            exit(1)
                        }
                        uint64 fs_soff = str_len
                        uint64 fs_si = 0
                        while fs_si < fs_tlen {
                            uint64 fs_ch = tok_source_byte(wfs_tok, fs_si)
                            uint64 fs_sp = str_buf + str_len
                            uint8 fs_cb = fs_ch
                            unsafe { *(fs_sp as uint8) = fs_cb }
                            str_len = str_len + 1
                            fs_si = fs_si + 1
                        }
                        uint64 fs_nsp = str_buf + str_len
                        uint8 fs_nz = 0
                        unsafe { *(fs_nsp as uint8) = fs_nz }
                        str_len = str_len + 1
                        if str_fixup_count >= 4096 {
                            write(2, "error: str_fixups overflow\n", 27)
                            exit(1)
                        }
                        // lea rsi, [rip + fs_soff]  (source)
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x35)
                        uint64 fs_fe = str_fixups + str_fixup_count * 8
                        uint32 fs_cp = out_len
                        unsafe { *(fs_fe as uint32) = fs_cp }
                        uint64 fs_fe4 = fs_fe + 4
                        uint32 fs_so = fs_soff
                        unsafe { *(fs_fe4 as uint32) = fs_so }
                        str_fixup_count = str_fixup_count + 1
                        emit_u32_le(0)
                        // r10 = rsi (save src), rcx = strlen
                        emit_byte(0x49); emit_byte(0x89); emit_byte(0xF2)  // mov r10, rsi
                        emit_byte(0x48); emit_byte(0x31); emit_byte(0xC9)  // xor rcx, rcx
                        uint64 fs_sl = out_len
                        emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x06)  // movzbl (%rsi), eax
                        emit_byte(0x84); emit_byte(0xC0)                    // test al, al
                        emit_byte(0x74); emit_byte(0x05)                    // jz +5
                        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC1)   // inc rcx
                        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC6)   // inc rsi
                        uint64 fs_slb = fs_sl - out_len - 1
                        uint8 fs_slbb = fs_slb; emit_byte(0xEB); emit_byte(fs_slbb)
                        // rcx=len, r10=src. Compute dest = [rsp+fs_buf_off] + offset
                        emit_byte(0x4C); emit_byte(0x89); emit_byte(0xD6)  // mov rsi, r10 (restore src)
                        // lea rdi, [rsp + fs_buf_off]
                        if fs_buf_off < 128 {
                            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x7C); emit_byte(0x24)
                            uint8 fbo1 = fs_buf_off; emit_byte(fbo1)
                        } else {
                            emit_byte(0x48); emit_byte(0x8D); emit_byte(0xBC); emit_byte(0x24)
                            emit_u32_le(fs_buf_off)
                        }
                        // rax = offset from temp_slot_1
                        emit_byte(0x48); emit_byte(0x8B)
                        if temp_slot_1 < 128 {
                            emit_byte(0x44); emit_byte(0x24); uint8 ts1a = temp_slot_1; emit_byte(ts1a)
                        } else {
                            emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                        }
                        emit_byte(0x48); emit_byte(0x01); emit_byte(0xC7)  // add rdi, rax
                        // rep movsb (rcx=len, rsi=src, rdi=dest)
                        emit_byte(0xF3); emit_byte(0xA4)
                        // update offset: load temp_slot_1, add rcx (save in r10), store
                        emit_byte(0x49); emit_byte(0x89); emit_byte(0xCA)  // mov r10, rcx
                        emit_byte(0x48); emit_byte(0x8B)
                        if temp_slot_1 < 128 {
                            emit_byte(0x44); emit_byte(0x24); uint8 ts1b = temp_slot_1; emit_byte(ts1b)
                        } else {
                            emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                        }
                        emit_byte(0x4C); emit_byte(0x01); emit_byte(0xD0)  // add rax, r10
                        emit_store_rax_to_stack(temp_slot_1)
                    }
                } else {
                    // Regular StrLit: gen_expr -> rax=str ptr
                    gen_expr(wfs_child)
                    emit_byte(0x48); emit_byte(0x89); emit_byte(0xC6)  // mov rsi, rax
                    emit_byte(0x49); emit_byte(0x89); emit_byte(0xF2)  // mov r10, rsi
                    emit_byte(0x48); emit_byte(0x31); emit_byte(0xC9)  // xor rcx, rcx
                    uint64 fs_sl2 = out_len
                    emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x06)
                    emit_byte(0x84); emit_byte(0xC0)
                    emit_byte(0x74); emit_byte(0x05)
                    emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC1)
                    emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC6)
                    uint64 fs_slb2 = fs_sl2 - out_len - 1
                    uint8 fs_slbb2 = fs_slb2; emit_byte(0xEB); emit_byte(fs_slbb2)
                    emit_byte(0x4C); emit_byte(0x89); emit_byte(0xD6)  // mov rsi, r10
                    if fs_buf_off < 128 {
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x7C); emit_byte(0x24)
                        uint8 fbo2 = fs_buf_off; emit_byte(fbo2)
                    } else {
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0xBC); emit_byte(0x24)
                        emit_u32_le(fs_buf_off)
                    }
                    emit_byte(0x48); emit_byte(0x8B)
                    if temp_slot_1 < 128 {
                        emit_byte(0x44); emit_byte(0x24); uint8 ts1c = temp_slot_1; emit_byte(ts1c)
                    } else {
                        emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                    }
                    emit_byte(0x48); emit_byte(0x01); emit_byte(0xC7)  // add rdi, rax
                    emit_byte(0xF3); emit_byte(0xA4)                   // rep movsb
                    emit_byte(0x49); emit_byte(0x89); emit_byte(0xCA)  // mov r10, rcx
                    emit_byte(0x48); emit_byte(0x8B)
                    if temp_slot_1 < 128 {
                        emit_byte(0x44); emit_byte(0x24); uint8 ts1d = temp_slot_1; emit_byte(ts1d)
                    } else {
                        emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                    }
                    emit_byte(0x4C); emit_byte(0x01); emit_byte(0xD0)  // add rax, r10
                    emit_store_rax_to_stack(temp_slot_1)
                }
            } else {
                // Expression: evaluate and format as decimal integer
                gen_expr(wfs_child)
                emit_store_rax_to_stack(temp_slot_0)
                // dest rdi = [rsp+fs_buf_off] + offset
                if fs_buf_off < 128 {
                    emit_byte(0x48); emit_byte(0x8D); emit_byte(0x7C); emit_byte(0x24)
                    uint8 fbo3 = fs_buf_off; emit_byte(fbo3)
                } else {
                    emit_byte(0x48); emit_byte(0x8D); emit_byte(0xBC); emit_byte(0x24)
                    emit_u32_le(fs_buf_off)
                }
                emit_byte(0x48); emit_byte(0x8B)
                if temp_slot_1 < 128 {
                    emit_byte(0x4C); emit_byte(0x24); uint8 ts1e = temp_slot_1; emit_byte(ts1e)
                } else {
                    emit_byte(0x8C); emit_byte(0x24); emit_u32_le(temp_slot_1)
                }
                emit_byte(0x48); emit_byte(0x01); emit_byte(0xCF)  // add rdi, rcx
                // rdi = dest. Load value.
                emit_load_rax_from_stack(temp_slot_0)
                // zero check
                emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
                emit_byte(0x0F); emit_byte(0x85)
                uint64 fs_jnz = out_len; emit_u32_le(0)
                // zero: write '0', len=1
                emit_byte(0xC6); emit_byte(0x07); emit_byte(0x30)
                emit_byte(0x49); emit_byte(0xC7); emit_byte(0xC2); emit_u32_le(1)
                emit_byte(0xE9)
                uint64 fs_jfin = out_len; emit_u32_le(0)
                uint64 fs_jnz_t = out_len - fs_jnz - 4
                uint32 fs_jnz_t32 = fs_jnz_t
                unsafe { *((out_buf + fs_jnz) as uint32) = fs_jnz_t32 }
                // nonzero: push digits, then pop to dest
                emit_byte(0x49); emit_byte(0x89); emit_byte(0xFB)   // r11 = rdi (dest start)
                emit_byte(0x4D); emit_byte(0x31); emit_byte(0xD2)   // xor r10, r10 (count)
                uint64 fs_dl = out_len
                emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)   // test rax, rax
                emit_byte(0x74); emit_byte(0x0E)                     // jz dl_done
                emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)   // xor rdx, rdx
                emit_byte(0x48); emit_byte(0xB9); emit_u32_le(10); emit_u32_le(0) // mov rcx, 10
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF1)   // div rcx
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xC2); emit_byte(0x30) // add rdx, '0'
                emit_byte(0x52)                                       // push rdx
                emit_byte(0x49); emit_byte(0xFF); emit_byte(0xC2)   // inc r10
                uint64 fs_dlb = fs_dl - out_len - 1
                uint8 fs_dlbb = fs_dlb; emit_byte(0xEB); emit_byte(fs_dlbb)
                // pop digits to rdi in correct order
                uint64 fs_pop = out_len
                emit_byte(0x4D); emit_byte(0x85); emit_byte(0xD2)   // test r10, r10
                emit_byte(0x74); emit_byte(0x07)                     // jz pop_done
                emit_byte(0x59)                                       // pop rcx
                emit_byte(0x88); emit_byte(0x0F)                     // mov [rdi], cl
                emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC7)   // inc rdi
                emit_byte(0x49); emit_byte(0xFF); emit_byte(0xCA)   // dec r10
                uint64 fs_popb = fs_pop - out_len - 1
                uint8 fs_popbb = fs_popb; emit_byte(0xEB); emit_byte(fs_popbb)
                // r10=0 now. len = rdi - r11
                emit_byte(0x4C); emit_byte(0x29); emit_byte(0xDF)   // sub rdi, r11
                emit_byte(0x49); emit_byte(0x89); emit_byte(0xFA)   // r10 = rdi (len)
                uint64 fs_jfin_t = out_len - fs_jfin - 4
                uint32 fs_jfin_t32 = fs_jfin_t
                unsafe { *((out_buf + fs_jfin) as uint32) = fs_jfin_t32 }
                // update offset
                emit_byte(0x48); emit_byte(0x8B)
                if temp_slot_1 < 128 {
                    emit_byte(0x44); emit_byte(0x24); uint8 ts1f = temp_slot_1; emit_byte(ts1f)
                } else {
                    emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                }
                emit_byte(0x4C); emit_byte(0x01); emit_byte(0xD0)  // add rax, r10
                emit_store_rax_to_stack(temp_slot_1)
            }
            uint32 fs_nxt = ast_next(wfs_child)
            wfs_child = fs_nxt
        }

        // Null-terminate: buf[offset] = 0
        if fs_buf_off < 128 {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44); emit_byte(0x24)
            uint8 fbo4 = fs_buf_off; emit_byte(fbo4)
        } else {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x84); emit_byte(0x24)
            emit_u32_le(fs_buf_off)
        }
        emit_byte(0x48); emit_byte(0x8B)
        if temp_slot_1 < 128 {
            emit_byte(0x4C); emit_byte(0x24); uint8 ts1z = temp_slot_1; emit_byte(ts1z)
        } else {
            emit_byte(0x8C); emit_byte(0x24); emit_u32_le(temp_slot_1)
        }
        emit_byte(0x48); emit_byte(0x01); emit_byte(0xC8)   // add rax, rcx
        emit_byte(0xC6); emit_byte(0x00); emit_byte(0x00)   // mov byte[rax], 0
        // Return pointer to buffer start
        if fs_buf_off < 128 {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44); emit_byte(0x24)
            uint8 fbo5 = fs_buf_off; emit_byte(fbo5)
        } else {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x84); emit_byte(0x24)
            emit_u32_le(fs_buf_off)
        }
        rax_invalidate()
        return
    }

    // Array indexing: arr[i] → load elem_size bytes from base + i*elem_size
    if kind == 37 {
        uint32 arr_tok = ast_data1(node)
        uint64 warrt = arr_tok
        uint64 arr_offset = var_lookup(arr_tok)
        uint64 elem_sz = arr_elem_lookup(arr_tok)
        // Evaluate index expression
        uint32 idx_child = ast_child(node)
        uint64 wi = idx_child
        gen_expr(wi)
        // Bounds check under --debug for arrays with a known compile-time
        // length. We treat the index as unsigned — negative-looking values
        // (from signed math) become huge positives and fail the check.
        if debug_mode != 0 {
            uint64 bc_count = arr_count_lookup(warrt)
            if bc_count != 0xFFFFFFFF {
                // cmp rax, imm32 — tolerate counts up to 2^31-1
                emit_byte(0x48); emit_byte(0x3D)
                emit_u32_le(bc_count)
                // jb rel8 — in-range, skip the trap
                emit_byte(0x72)
                uint64 bc_jb = out_len
                emit_byte(0)
                // trap: exit(1)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 { emit_mov_rcx_rax(); emit_win_alloc_stack(0x20); emit_win_call_iat(0) }
                else if target_os == 1 { emit_mov_rax_imm(0x2000001); emit_byte(0x0F); emit_byte(0x05) }
                else { emit_mov_rax_imm(231); emit_byte(0x0F); emit_byte(0x05) }
                uint64 bc_skip = out_len - bc_jb - 1
                uint8 bc_s = bc_skip
                uint64 bc_pp = out_buf + bc_jb
                unsafe { *(bc_pp as uint8) = bc_s }
            }
        }
        // mov rcx, rax (save index)
        emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
        if arr_offset != 0xFFFFFFFF {
            emit_load_rax_from_stack(arr_offset)
        } else {
            uint64 sas = static_array_size_of(warrt)
            if sas != 0xFFFFFFFF && sas != 0 {
                uint64 soff_a = static_lookup(warrt)
                emit_static_lea(soff_a)
            } else {
                arr_offset = 0
                emit_load_rax_from_stack(arr_offset)
            }
        }
        // rax = base, rcx = index. Load with scaled SIB addressing.
        // SIB byte = (log2(scale) << 6) | (1 << 3) | 0  where index=rcx, base=rax
        //   scale 1 → 0x08, scale 2 → 0x48, scale 4 → 0x88, scale 8 → 0xC8
        uint8 sib = 0x08
        if elem_sz == 2 { sib = 0x48 }
        if elem_sz == 4 { sib = 0x88 }
        if elem_sz == 8 { sib = 0xC8 }
        if elem_sz == 1 {
            // movzbl (%rax,%rcx,1), %eax
            emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x04); emit_byte(sib)
        } else if elem_sz == 2 {
            // movzwl (%rax,%rcx,2), %eax
            emit_byte(0x0F); emit_byte(0xB7); emit_byte(0x04); emit_byte(sib)
        } else if elem_sz == 4 {
            // movl (%rax,%rcx,4), %eax  (zero-extends to rax)
            emit_byte(0x8B); emit_byte(0x04); emit_byte(sib)
        } else {
            // movq (%rax,%rcx,8), %rax
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x04); emit_byte(sib)
        }
        return
    }

    // Field access: EnumName.Field (enum constant) or var.field (struct field read)
    // Also: arr[i].field for struct arrays.
    if kind == 36 {
        uint32 child_idx = ast_child(node)
        uint64 wchild = child_idx
        uint32 field_tok = ast_data2(node)
        // Struct array element field read: child is an Index node
        if wchild != 0 {
            uint32 cfk = ast_kind(wchild)
            uint64 wcfk = cfk
            if wcfk == 37 {
                uint32 ai_tok = ast_data1(wchild)
                uint64 wait = ai_tok
                uint64 sia = struct_var_lookup(ai_tok)
                if sia != 0xFFFFFFFF {
                    // Compute struct stride and field offset
                    uint64 stride = struct_total_size(sia)
                    uint64 foff_i = struct_field_offset(sia, field_tok)
                    uint64 fsz_i = struct_field_size(sia, field_tok)
                    // Evaluate index into rax
                    uint32 idx_ch = ast_child(wchild)
                    uint64 widx = idx_ch
                    gen_expr(widx)
                    // rax = index. Multiply by stride: mov rcx, stride; mul rcx → rax*rcx
                    emit_mov_rcx_rax()
                    // Load stride imm into rax
                    emit_mov_rax_imm(stride)
                    // imul rax, rcx (48 0F AF C1)
                    emit_byte(0x48); emit_byte(0x0F); emit_byte(0xAF); emit_byte(0xC1)
                    // Save offset-into-array to rcx
                    emit_mov_rcx_rax()
                    // Load base address of the array
                    uint64 aoff = var_lookup(wait)
                    if aoff != 0xFFFFFFFF {
                        emit_load_rax_from_stack(aoff)
                    }
                    // rax = base, rcx = i*stride. addr = base + rcx + foff_i
                    emit_byte(0x48); emit_byte(0x01); emit_byte(0xC8) // add rax, rcx
                    if foff_i != 0 {
                        emit_byte(0x48); emit_byte(0x05)
                        emit_u32_le(foff_i)
                    }
                    // Load field value based on size
                    if fsz_i == 1 {
                        emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
                    } else if fsz_i == 2 {
                        emit_byte(0x0F); emit_byte(0xB7); emit_byte(0x00)
                    } else if fsz_i == 4 {
                        emit_byte(0x8B); emit_byte(0x00)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                    }
                    return
                }
            }
        }
        // Nested struct field read: child is another FieldAccess
        if wchild != 0 {
            uint32 cfk2 = ast_kind(wchild)
            uint64 wcfk2 = cfk2
            if wcfk2 == 36 {
                // Evaluate inner field chain — produces pointer in rax, sets expr_is_struct
                gen_expr(wchild)
                uint64 nsi = expr_is_struct
                if nsi != 0xFFFFFFFF {
                    uint64 nfoff = struct_field_offset(nsi, field_tok)
                    uint64 nfsz = struct_field_size(nsi, field_tok)
                    if nfoff != 0 {
                        emit_byte(0x48); emit_byte(0x05)
                        emit_u32_le(nfoff)
                    }
                    uint64 nftk = struct_field_type_kind_by_tok(nsi, field_tok)
                    if nftk >= 256 {
                        expr_is_struct = nftk - 256
                        return
                    }
                    expr_is_struct = 0xFFFFFFFF
                    if nftk == 96 {
                        emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0x00)
                        expr_is_float = 1
                        return
                    }
                    if nftk == 95 {
                        emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x10); emit_byte(0x00)
                        expr_is_float = 2
                        return
                    }
                    if nfsz == 1 {
                        emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
                    } else if nfsz == 4 {
                        emit_byte(0x8B); emit_byte(0x00)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                    }
                    return
                }
            }
        }
        // Extract object token from child Ident node
        uint32 obj_tok = 0
        if wchild != 0 {
            uint32 child_kind = ast_kind(wchild)
            uint64 wck = child_kind
            if wck == 32 {
                obj_tok = ast_data1(wchild)
            }
        }
        // Slice length access: slice_var.len → load from the slice's length slot
        if obj_tok != 0 {
            uint64 wot_sl = obj_tok
            uint64 ptr_off_sl = var_lookup(wot_sl)
            if ptr_off_sl != 0xFFFFFFFF {
                uint64 len_off_sl = slice_len_lookup(ptr_off_sl)
                if len_off_sl != 0xFFFFFFFF {
                    // Confirm the field name is "len"
                    uint64 wft_sl = field_tok
                    if tok_matches(wft_sl, "len", 3) != 0 {
                        emit_load_rax_from_stack(len_off_sl)
                        return
                    }
                }
            }
        }
        // Device field read: UART0.Data → vloadN(base + offset)
        if obj_tok != 0 {
            uint64 wdt = obj_tok
            uint64 dev_idx = device_lookup(wdt)
            if dev_idx != 0xFFFFFFFF {
                uint64 wft_d = field_tok
                uint64 dev_off = device_field_offset_of(dev_idx, wft_d)
                if dev_off != 0xFFFFFFFF {
                    uint64 dev_sz = device_field_size_of(dev_idx, wft_d)
                    uint64 dev_addr = device_base(dev_idx) + dev_off
                    // rax = address
                    emit_mov_rax_imm(dev_addr)
                    // volatile load width-aware + mfence
                    if dev_sz == 1 {
                        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
                    } else if dev_sz == 2 {
                        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xB7); emit_byte(0x00)
                    } else if dev_sz == 4 {
                        emit_byte(0x8B); emit_byte(0x00)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                    }
                    // mfence (barrier after load)
                    emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
                    rax_cache = 0
                    return
                }
            }
        }
        // Check if obj_tok is a struct variable
        uint64 si = struct_var_lookup(obj_tok)
        if si != 0xFFFFFFFF {
            // Struct field read: load base + field_offset
            uint64 var_off = var_lookup(obj_tok)
            if var_off == 0xFFFFFFFF { var_off = 0 }
            uint64 foff = struct_field_offset(si, field_tok)
            uint64 fsz = struct_field_size(si, field_tok)
            // Load struct base address
            emit_load_rax_from_stack(var_off)
            // Add field offset
            if foff != 0 {
                emit_byte(0x48); emit_byte(0x05)
                emit_u32_le(foff)
            }
            // Check if field is a float type or nested struct
            uint64 fftk = struct_field_type_kind_by_tok(si, field_tok)
            if fftk >= 256 {
                // Nested struct field: leave address in rax, set expr_is_struct
                expr_is_struct = fftk - 256
                return
            }
            if fftk == 96 {
                // f64 field: movsd xmm0, [rax] — F2 0F 10 00
                emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0x00)
                expr_is_float = 1
                return
            }
            if fftk == 95 {
                // f32 field: movss xmm0, [rax] — F3 0F 10 00
                emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x10); emit_byte(0x00)
                expr_is_float = 2
                return
            }
            // Load field value based on size
            if fsz == 1 {
                emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
            } else if fsz == 4 {
                emit_byte(0x8B); emit_byte(0x00)
            } else {
                emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
            }
            return
        }
        // Enum constant
        uint64 val = enum_lookup(obj_tok, field_tok)
        emit_mov_rax_imm(val)
        return
    }

    // Identifier → load from stack variable or static
    if kind == 32 {
        uint32 tok = ast_data1(node)
        uint64 wident_tok = tok
        uint64 offset = var_lookup(tok)
        if offset != 0xFFFFFFFF {
            // Check if this variable is float-typed
            uint64 vtype = var_type_lookup(tok)
            if is_float_type(vtype) != 0 {
                if is_f32_type(vtype) != 0 {
                    emit_load_xmm0_f32(offset)
                    expr_is_float = 2
                } else {
                    emit_load_xmm0_f64(offset)
                    expr_is_float = 1
                }
                return
            }
            emit_load_rax_from_stack(offset)
            expr_is_float = 0
            // Track if this is a struct variable
            uint64 svi = struct_var_lookup(wident_tok)
            if svi != 0xFFFFFFFF {
                expr_is_struct = svi
            }
        } else {
            uint64 soff = static_lookup(tok)
            if soff != 0xFFFFFFFF {
                // Static array: emit LEA (address). Scalar: emit MOV (value).
                uint64 sas_i = static_array_size_of(wident_tok)
                if sas_i != 0xFFFFFFFF && sas_i != 0 {
                    emit_static_lea(soff)
                } else {
                    emit_static_load(soff)
                }
            } else {
                uint64 id_len = tok_text_len(tok)
                if id_len != 0 {
                    write(2, "error: use of undeclared identifier '", 37)
                    write(2, cg_source + tok_text_start(tok), id_len)
                    write(2, "'\n", 2)
                    exit(1)
                }
            }
        }
        return
    }

    // Binary operation: lhs OP rhs
    // Evaluate lhs first into rax, save to a fresh temp slot,
    // then evaluate rhs into rax, move to rcx, restore lhs.
    if kind == 33 {
        // Constant folding: if both operands are IntLit, compute at compile time
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        uint32 rhs_idx_cf = ast_data2(node)
        uint64 wrhs_cf = rhs_idx_cf
        uint32 lhs_kind = ast_kind(wlhs)
        uint32 rhs_kind = ast_kind(wrhs_cf)
        if lhs_kind == 30 && rhs_kind == 30 {
            uint32 l_tok = ast_data1(wlhs)
            uint32 r_tok = ast_data1(wrhs_cf)
            uint64 lv = parse_int_token(l_tok)
            uint64 rv = parse_int_token(r_tok)
            uint32 op_tok_cf = ast_data1(node)
            uint64 wop_cf = op_tok_cf
            uint64 pcf = cg_tokens + wop_cf * 16
            uint32 op_cf = 0
            unsafe { *(pcf as uint32) -> op_cf }
            uint64 result = 0
            if op_cf == 30 { result = lv + rv }
            else if op_cf == 31 { result = lv - rv }
            else if op_cf == 22 { result = lv * rv }
            else if op_cf == 32 { if rv != 0 { result = lv / rv } }
            else if op_cf == 33 { if rv != 0 { result = lv - lv / rv * rv } }
            else if op_cf == 23 { result = lv & rv }
            else if op_cf == 24 { result = lv | rv }
            else if op_cf == 25 { result = lv ^ rv }
            else if op_cf == 43 { result = lv << rv }
            else if op_cf == 44 { result = lv >> rv }
            emit_mov_rax_imm(result)
            return
        }

        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        uint32 rhs_kind_check = ast_kind(wrhs)
        uint64 wrk = rhs_kind_check
        uint32 lhs_kind_check = ast_kind(wlhs)
        uint64 wlk = lhs_kind_check

        // Fast path: pinned_param ± IntLit → lea rax, [rbx ± imm]
        // Eliminates 5 instructions (mov+mov+mov+xchg+op → lea)
        uint64 used_lea = 0
        if wlk == 32 && wrk == 30 && pin_param0_offset != 0xFFFFFFFF {
            uint32 lhs_tok = ast_data1(wlhs)
            uint64 loff = var_lookup(lhs_tok)
            if loff == pin_param0_offset {
                uint32 op_tok_lea = ast_data1(node)
                uint64 opl = cg_tokens + op_tok_lea * 16
                uint32 opk_lea = 0
                unsafe { *(opl as uint32) -> opk_lea }
                if opk_lea == 30 || opk_lea == 31 {
                    // Parse the integer literal. Pick the narrowest LEA
                    // encoding that losslessly represents the signed disp.
                    // The old code unconditionally used disp8 — truncating
                    // and sign-extending a uint64 into an 8-bit field —
                    // so `x + 181` came out as `x + (-75)` and quietly
                    // miscompiled every arithmetic expression with a
                    // literal in [128, 255]. Found by tests/fuzz.
                    uint32 rhs_tok = ast_data1(wrhs)
                    uint64 imm_val = parse_int_token(rhs_tok)
                    uint64 disp = imm_val
                    if opk_lea == 31 { disp = 0 - imm_val }
                    // disp fits in signed int8 if its top 57 bits match
                    // the sign bit (all 0 for [0..127], all 1 for [-128..-1]).
                    uint64 top = disp >> 7
                    uint64 fits_i8 = 0
                    if top == 0 { fits_i8 = 1 }
                    if top == 0x1FFFFFFFFFFFFFF { fits_i8 = 1 }
                    uint64 top32 = disp >> 31
                    uint64 fits_i32 = 0
                    if top32 == 0 { fits_i32 = 1 }
                    if top32 == 0x1FFFFFFFF { fits_i32 = 1 }
                    if fits_i8 != 0 {
                        // lea rax, [rbx + disp8]: 48 8D 43 <disp8>
                        uint8 d8 = disp
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x43); emit_byte(d8)
                        rax_cache = 0
                        used_lea = 1
                    } else if fits_i32 != 0 {
                        // lea rax, [rbx + disp32]: 48 8D 83 <disp32>
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x83)
                        emit_u32_le(disp & 0xFFFFFFFF)
                        rax_cache = 0
                        used_lea = 1
                    }
                    // imm doesn't fit in int32 — fall through to the
                    // general arithmetic path below, which materialises
                    // the 64-bit constant explicitly.
                }
            }
        }

        // --- Float arithmetic path ---
        // Evaluate LHS, check if float, store to temp, evaluate RHS,
        // then emit SSE ops if both sides are float.
        uint64 lhs_is_float = 0

        if used_lea != 0 {
            // LEA already computed the result — skip all expression evaluation
        } else if wrk == 30 || wrk == 32 {
            // Simple RHS: skip stack temp
            gen_expr(wlhs)
            lhs_is_float = expr_is_float
            if lhs_is_float != 0 {
                // Float LHS: store xmm0 to temp
                uint64 ft0 = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 ft0r = var_frame_size & 15
                if ft0r != 0 { var_frame_size = var_frame_size + 16 - ft0r }
                if lhs_is_float == 2 {
                    emit_store_xmm0_f32(ft0)
                } else {
                    emit_store_xmm0_f64(ft0)
                }
                gen_expr(wrhs)
                uint64 rhs_is_float = expr_is_float
                if lhs_is_float != 0 && rhs_is_float != 0 {
                    // movsd xmm1, xmm0 (save RHS): F2 0F 10 C8
                    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                    // Reload LHS from temp
                    if lhs_is_float == 2 {
                        emit_load_xmm0_f32(ft0)
                    } else {
                        emit_load_xmm0_f64(ft0)
                    }
                    uint32 op_tok_fb = ast_data1(node)
                    uint64 wop_fb = op_tok_fb
                    uint64 pfb = cg_tokens + wop_fb * 16
                    uint32 op_kind_fb = 0
                    unsafe { *(pfb as uint32) -> op_kind_fb }
                    if lhs_is_float == 2 {
                        if op_kind_fb == 30 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) } // addss
                        if op_kind_fb == 31 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) } // subss
                        if op_kind_fb == 22 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) } // mulss
                        if op_kind_fb == 32 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) } // divss
                    } else {
                        if op_kind_fb == 30 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) } // addsd
                        if op_kind_fb == 31 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) } // subsd
                        if op_kind_fb == 22 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) } // mulsd
                        if op_kind_fb == 32 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) } // divsd
                    }
                    expr_is_float = lhs_is_float
                    return
                }
            } else {
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
                rax_cache = 0
                gen_expr(wrhs)
                emit_byte(0x48); emit_byte(0x87); emit_byte(0xC1)
                rax_cache = 0
            }
        } else if r12_in_use == 0 {
            // Complex RHS: hold lhs in r12 (callee-saved, survives calls)
            gen_expr(wlhs)
            lhs_is_float = expr_is_float
            if lhs_is_float != 0 {
                // Float LHS: store xmm0 to temp (can't use r12 for float)
                uint64 ft1 = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 ft1r = var_frame_size & 15
                if ft1r != 0 { var_frame_size = var_frame_size + 16 - ft1r }
                if lhs_is_float == 2 {
                    emit_store_xmm0_f32(ft1)
                } else {
                    emit_store_xmm0_f64(ft1)
                }
                gen_expr(wrhs)
                uint64 rhs_is_float2 = expr_is_float
                if lhs_is_float != 0 && rhs_is_float2 != 0 {
                    // movsd xmm1, xmm0 (save RHS): F2 0F 10 C8
                    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                    if lhs_is_float == 2 {
                        emit_load_xmm0_f32(ft1)
                    } else {
                        emit_load_xmm0_f64(ft1)
                    }
                    uint32 op_tok_fc = ast_data1(node)
                    uint64 wop_fc = op_tok_fc
                    uint64 pfc = cg_tokens + wop_fc * 16
                    uint32 op_kind_fc = 0
                    unsafe { *(pfc as uint32) -> op_kind_fc }
                    if lhs_is_float == 2 {
                        if op_kind_fc == 30 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) }
                        if op_kind_fc == 31 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) }
                        if op_kind_fc == 22 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) }
                        if op_kind_fc == 32 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) }
                    } else {
                        if op_kind_fc == 30 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) }
                        if op_kind_fc == 31 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) }
                        if op_kind_fc == 22 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) }
                        if op_kind_fc == 32 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) }
                    }
                    expr_is_float = lhs_is_float
                    return
                }
            } else {
                r12_in_use = 1
                emit_byte(0x49); emit_byte(0x89); emit_byte(0xC4) // mov r12, rax
                rax_cache = 0
                gen_expr(wrhs)
                r12_in_use = 0
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1) // mov rcx, rax
                emit_byte(0x4C); emit_byte(0x89); emit_byte(0xE0) // mov rax, r12
                rax_cache = 0
            }
        } else {
            // r12 in use (nested): fall back to stack
            gen_expr(wlhs)
            lhs_is_float = expr_is_float
            uint64 binop_temp = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 brem = var_frame_size & 15
            if brem != 0 { var_frame_size = var_frame_size + 16 - brem }
            if lhs_is_float != 0 {
                if lhs_is_float == 2 {
                    emit_store_xmm0_f32(binop_temp)
                } else {
                    emit_store_xmm0_f64(binop_temp)
                }
                gen_expr(wrhs)
                uint64 rhs_is_float3 = expr_is_float
                if lhs_is_float != 0 && rhs_is_float3 != 0 {
                    // movsd xmm1, xmm0 (save RHS): F2 0F 10 C8
                    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                    if lhs_is_float == 2 {
                        emit_load_xmm0_f32(binop_temp)
                    } else {
                        emit_load_xmm0_f64(binop_temp)
                    }
                    uint32 op_tok_fd = ast_data1(node)
                    uint64 wop_fd = op_tok_fd
                    uint64 pfd = cg_tokens + wop_fd * 16
                    uint32 op_kind_fd = 0
                    unsafe { *(pfd as uint32) -> op_kind_fd }
                    if lhs_is_float == 2 {
                        if op_kind_fd == 30 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) }
                        if op_kind_fd == 31 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) }
                        if op_kind_fd == 22 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) }
                        if op_kind_fd == 32 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) }
                    } else {
                        if op_kind_fd == 30 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) }
                        if op_kind_fd == 31 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) }
                        if op_kind_fd == 22 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) }
                        if op_kind_fd == 32 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) }
                    }
                    expr_is_float = lhs_is_float
                    return
                }
            } else {
                emit_store_rax_to_stack(binop_temp)
                gen_expr(wrhs)
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
                emit_load_rax_from_stack(binop_temp)
            }
        }

        // Determine operation from token kind (skip if LEA already computed)
        if used_lea == 0 {
        uint32 op_tok = ast_data1(node)
        uint64 wop = op_tok
        uint64 p = cg_tokens + wop * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }

        // Re-derive signedness from the AST so /, %, >> can pick the
        // sign-aware encoding (idiv / sar) when either operand is a
        // signed-int source. Plain ADD/SUB/MUL produce identical bits
        // in two's complement so they don't need a separate path.
        uint64 binop_is_signed = 0
        if legacy_node_is_signed(wlhs) != 0 { binop_is_signed = 1 }
        if legacy_node_is_signed(wrhs) != 0 { binop_is_signed = 1 }

        if op_kind == 30 {
            emit_add_rax_rcx()
            if debug_mode != 0 {
                // Overflow check: jno rel8 — skip trap if no signed overflow
                // Also catches unsigned carry for unsigned types
                emit_byte(0x71)
                uint64 jo_add = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_add_skip = out_len - jo_add - 1
                uint8 jo_add_s8 = jo_add_skip
                uint64 jo_add_pp = out_buf + jo_add
                unsafe { *(jo_add_pp as uint8) = jo_add_s8 }
            }
        }
        else if op_kind == 31 {
            emit_sub_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_sub = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_sub_skip = out_len - jo_sub - 1
                uint8 jo_sub_s8 = jo_sub_skip
                uint64 jo_sub_pp = out_buf + jo_sub
                unsafe { *(jo_sub_pp as uint8) = jo_sub_s8 }
            }
        }
        else if op_kind == 22 {
            emit_mul_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_mul = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_mul_skip = out_len - jo_mul - 1
                uint8 jo_mul_s8 = jo_mul_skip
                uint64 jo_mul_pp = out_buf + jo_mul
                unsafe { *(jo_mul_pp as uint8) = jo_mul_s8 }
            }
        }
        else if op_kind == 32 {
            // / division: rax / rcx
            if debug_mode != 0 {
                // Division by zero check: test rcx, rcx; jnz +skip; exit(1)
                emit_byte(0x48); emit_byte(0x85); emit_byte(0xC9)  // test rcx, rcx
                emit_byte(0x75)  // jnz rel8
                uint64 dz_jnz_patch = out_len
                emit_byte(0)  // placeholder
                // Divisor is zero — exit(1)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                // Patch jnz to skip the trap
                uint64 dz_skip = out_len - dz_jnz_patch - 1
                uint8 dz_skip8 = dz_skip
                uint64 dz_pp = out_buf + dz_jnz_patch
                unsafe { *(dz_pp as uint8) = dz_skip8 }
            }
            if binop_is_signed != 0 {
                // cqo (sign-extend rax → rdx:rax); idiv rcx → quotient in rax
                emit_byte(0x48); emit_byte(0x99)
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF9)
            } else {
                // xor rdx, rdx; div rcx → quotient in rax
                emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF1)
            }
        }
        else if op_kind == 33 {
            // % modulo: rax % rcx
            if debug_mode != 0 {
                // Division by zero check: test rcx, rcx; jnz +skip; exit(1)
                emit_byte(0x48); emit_byte(0x85); emit_byte(0xC9)  // test rcx, rcx
                emit_byte(0x75)  // jnz rel8
                uint64 mz_jnz_patch = out_len
                emit_byte(0)  // placeholder
                // Divisor is zero — exit(1)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                // Patch jnz to skip the trap
                uint64 mz_skip = out_len - mz_jnz_patch - 1
                uint8 mz_skip8 = mz_skip
                uint64 mz_pp = out_buf + mz_jnz_patch
                unsafe { *(mz_pp as uint8) = mz_skip8 }
            }
            if binop_is_signed != 0 {
                // cqo + idiv rcx → remainder in rdx; mov rax, rdx
                emit_byte(0x48); emit_byte(0x99)
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF9)
            } else {
                // xor rdx, rdx; div rcx → remainder in rdx; mov rax, rdx
                emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF1)
            }
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xD0)
        }
        else if op_kind == 23 {
            // & bitwise AND: and rcx, rax
            emit_byte(0x48)
            emit_byte(0x21)
            emit_byte(0xC8)
        }
        else if op_kind == 24 {
            // | bitwise OR: or rcx, rax
            emit_byte(0x48)
            emit_byte(0x09)
            emit_byte(0xC8)
        }
        else if op_kind == 25 {
            // ^ bitwise XOR: xor rcx, rax
            emit_byte(0x48)
            emit_byte(0x31)
            emit_byte(0xC8)
        }
        else if op_kind == 43 {
            // << shift left: shl cl, rax (cl = low byte of rcx)
            emit_byte(0x48)
            emit_byte(0xD3)
            emit_byte(0xE0)
        }
        else if op_kind == 44 {
            // >> shift right: SAR (sign-extending) for signed inputs,
            // SHR (zero-fill) otherwise. ModRM /7 = 0xF8, /5 = 0xE8.
            emit_byte(0x48)
            emit_byte(0xD3)
            if binop_is_signed != 0 { emit_byte(0xF8) } else { emit_byte(0xE8) }
        }
        // Compound assignment ops (desugared by parser: x += y → x = x + y)
        else if op_kind == 45 {
            emit_add_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_ca = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_ca_skip = out_len - jo_ca - 1
                uint8 jo_ca_s8 = jo_ca_skip
                uint64 jo_ca_pp = out_buf + jo_ca
                unsafe { *(jo_ca_pp as uint8) = jo_ca_s8 }
            }
        }
        else if op_kind == 46 {
            emit_sub_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_cs = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_cs_skip = out_len - jo_cs - 1
                uint8 jo_cs_s8 = jo_cs_skip
                uint64 jo_cs_pp = out_buf + jo_cs
                unsafe { *(jo_cs_pp as uint8) = jo_cs_s8 }
            }
        }
        else if op_kind == 47 {
            emit_mul_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_cm = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_cm_skip = out_len - jo_cm - 1
                uint8 jo_cm_s8 = jo_cm_skip
                uint64 jo_cm_pp = out_buf + jo_cm
                unsafe { *(jo_cm_pp as uint8) = jo_cm_s8 }
            }
        }
        else if op_kind == 50 {
            emit_byte(0x48); emit_byte(0x21); emit_byte(0xC8) // &=
        }
        else if op_kind == 51 {
            emit_byte(0x48); emit_byte(0x09); emit_byte(0xC8) // |=
        }
        else if op_kind == 52 {
            emit_byte(0x48); emit_byte(0x31); emit_byte(0xC8) // ^=
        }
        } // end if used_lea == 0
        return
    }

    // Comparison: lhs CMP rhs → 0 or 1 in rax
    if kind == 38 {
        // Constant comparison folding
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        uint32 rhs_idx_cc = ast_data2(node)
        uint64 wrhs_cc = rhs_idx_cc
        uint32 lk_cc = ast_kind(wlhs)
        uint32 rk_cc = ast_kind(wrhs_cc)
        if lk_cc == 30 && rk_cc == 30 {
            uint32 lt_cc = ast_data1(wlhs)
            uint32 rt_cc = ast_data1(wrhs_cc)
            uint64 lvc = parse_int_token(lt_cc)
            uint64 rvc = parse_int_token(rt_cc)
            uint32 op_cc = ast_data1(node)
            uint64 pcc = cg_tokens + op_cc * 16
            uint32 okcc = 0
            unsafe { *(pcc as uint32) -> okcc }
            uint64 res = 0
            if okcc == 35 { if lvc == rvc { res = 1 } }
            else if okcc == 36 { if lvc != rvc { res = 1 } }
            else if okcc == 37 { if lvc < rvc { res = 1 } }
            else if okcc == 38 { if lvc <= rvc { res = 1 } }
            else if okcc == 39 { if lvc > rvc { res = 1 } }
            else if okcc == 40 { if lvc >= rvc { res = 1 } }
            emit_mov_rax_imm(res)
            return
        }

        // Struct comparison: == and != on struct values
        uint32 rhs_idx_pre = ast_data2(node)
        uint64 wrhs_pre = rhs_idx_pre
        uint32 lhs_k_pre = ast_kind(wlhs)
        uint32 rhs_k_pre = ast_kind(wrhs_pre)
        uint64 lhs_si_pre = 0xFFFFFFFF
        uint64 rhs_si_pre = 0xFFFFFFFF
        if lhs_k_pre == 32 {
            uint32 lt_pre = ast_data1(wlhs)
            uint64 wlt_pre = lt_pre
            lhs_si_pre = struct_var_lookup(wlt_pre)
        }
        if lhs_si_pre != 0xFFFFFFFF && rhs_k_pre == 32 {
            uint32 rt_pre = ast_data1(wrhs_pre)
            uint64 wrt_pre = rt_pre
            rhs_si_pre = struct_var_lookup(wrt_pre)
        }
        if lhs_si_pre != 0xFFFFFFFF && rhs_si_pre != 0xFFFFFFFF {
            // Both operands are struct variables — emit qword-by-qword comparison
            gen_expr(wlhs)
            uint64 sc_lhs_slot = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 sc_rem1 = var_frame_size & 15
            if sc_rem1 != 0 { var_frame_size = var_frame_size + 16 - sc_rem1 }
            emit_store_rax_to_stack(sc_lhs_slot)

            gen_expr(wrhs_pre)
            uint64 sc_rhs_slot = var_count * 8
            var_count = var_count + 1
            uint64 sc_acc_slot = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 sc_rem2 = var_frame_size & 15
            if sc_rem2 != 0 { var_frame_size = var_frame_size + 16 - sc_rem2 }
            emit_store_rax_to_stack(sc_rhs_slot)

            uint64 sc_size = struct_total_size(lhs_si_pre)
            uint64 sc_slots = (sc_size + 7) / 8

            // Start with result = 1 (assume equal)
            emit_mov_rax_imm(1)
            emit_store_rax_to_stack(sc_acc_slot)

            uint64 qi = 0
            while qi < sc_slots {
                // Load lhs qword
                emit_load_rax_from_stack(sc_lhs_slot)
                uint64 qoff = qi * 8
                if qoff == 0 {
                    // mov rax, [rax]
                    emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                } else {
                    if qoff < 128 {
                        // mov rax, [rax+disp8]
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x40)
                        uint8 qo8 = qoff; emit_byte(qo8)
                    } else {
                        // mov rax, [rax+disp32]
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x80)
                        uint32 qo32 = qoff
                        uint8 qb0 = qo32 & 0xFF; emit_byte(qb0)
                        uint8 qb1 = (qo32 >> 8) & 0xFF; emit_byte(qb1)
                        uint8 qb2 = (qo32 >> 16) & 0xFF; emit_byte(qb2)
                        uint8 qb3 = (qo32 >> 24) & 0xFF; emit_byte(qb3)
                    }
                }
                // mov rcx, rax
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)

                // Load rhs qword
                emit_load_rax_from_stack(sc_rhs_slot)
                if qoff == 0 {
                    emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                } else {
                    if qoff < 128 {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x40)
                        uint8 qo8r = qoff; emit_byte(qo8r)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x80)
                        uint32 qo32r = qoff
                        uint8 qb0r = qo32r & 0xFF; emit_byte(qb0r)
                        uint8 qb1r = (qo32r >> 8) & 0xFF; emit_byte(qb1r)
                        uint8 qb2r = (qo32r >> 16) & 0xFF; emit_byte(qb2r)
                        uint8 qb3r = (qo32r >> 24) & 0xFF; emit_byte(qb3r)
                    }
                }

                // cmp rcx, rax
                emit_byte(0x48); emit_byte(0x39); emit_byte(0xC1)
                // sete al
                emit_byte(0x0F); emit_byte(0x94); emit_byte(0xC0)
                // movzx eax, al
                emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)

                // AND with accumulated result
                // mov rcx, rax
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
                emit_load_rax_from_stack(sc_acc_slot)
                // and rax, rcx
                emit_byte(0x48); emit_byte(0x21); emit_byte(0xC8)
                emit_store_rax_to_stack(sc_acc_slot)

                qi = qi + 1
            }

            emit_load_rax_from_stack(sc_acc_slot)

            // Check operator: == (35) or != (36)
            uint32 op_tok_sc = ast_data1(node)
            uint64 wop_sc = op_tok_sc
            uint64 p_sc = cg_tokens + wop_sc * 16
            uint32 op_kind_sc = 0
            unsafe { *(p_sc as uint32) -> op_kind_sc }
            if op_kind_sc == 36 {
                // != : invert (xor rax, 1)
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xF0); emit_byte(0x01)
            }

            rax_invalidate()
            expr_is_float = 0
            expr_is_struct = 0xFFFFFFFF
            return
        }

        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        uint32 rhs_kind_cmp = ast_kind(wrhs)
        uint64 wrk_cmp = rhs_kind_cmp
        uint32 lhs_kind_cmp2 = ast_kind(wlhs)
        uint64 wlk_cmp = lhs_kind_cmp2

        // Fast path: cmp pinned_param, imm → cmp rbx, imm8
        uint64 used_direct_cmp = 0
        if wlk_cmp == 32 && wrk_cmp == 30 && pin_param0_offset != 0xFFFFFFFF {
            uint32 lhs_tok_c = ast_data1(wlhs)
            uint64 loff_c = var_lookup(lhs_tok_c)
            if loff_c == pin_param0_offset {
                uint32 rhs_tok_c = ast_data1(wrhs)
                uint64 cmp_imm = parse_int_token(rhs_tok_c)
                // cmp rbx, imm8: 48 83 FB <imm8>
                if cmp_imm < 128 {
                    uint8 ci8 = cmp_imm
                    emit_byte(0x48); emit_byte(0x83); emit_byte(0xFB); emit_byte(ci8)
                    used_direct_cmp = 1
                }
            }
        }

        if used_direct_cmp != 0 {
            // Direct cmp already emitted — skip expression evaluation
        } else if wrk_cmp == 30 || wrk_cmp == 32 {
            // Simple RHS: skip stack temp (for integers)
            gen_expr(wlhs)
            uint64 lhs_is_float_s = expr_is_float
            if lhs_is_float_s != 0 {
                // Float LHS: store xmm0 to temp, eval RHS, ucomisd
                uint64 fcmp_temp_s = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 fcrem_s = var_frame_size & 15
                if fcrem_s != 0 { var_frame_size = var_frame_size + 16 - fcrem_s }
                if lhs_is_float_s == 2 {
                    emit_store_xmm0_f32(fcmp_temp_s)
                } else {
                    emit_store_xmm0_f64(fcmp_temp_s)
                }
                gen_expr(wrhs)
                // movsd xmm1, xmm0 (RHS): F2 0F 10 C8
                emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                // reload LHS into xmm0
                if lhs_is_float_s == 2 {
                    emit_load_xmm0_f32(fcmp_temp_s)
                } else {
                    emit_load_xmm0_f64(fcmp_temp_s)
                }
                // ucomisd xmm0, xmm1: 66 0F 2E C1  (ucomiss: 0F 2E C1)
                if lhs_is_float_s == 2 {
                    emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                } else {
                    emit_byte(0x66); emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                }
                uint32 op_tok_fs = ast_data1(node)
                uint64 wop_fs = op_tok_fs
                uint64 p_fs = cg_tokens + wop_fs * 16
                uint32 op_kind_fs = 0
                unsafe { *(p_fs as uint32) -> op_kind_fs }
                rax_invalidate()
                emit_setcc(op_kind_fs)
                expr_is_float = 0
                return
            }
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            rax_cache = 0
            gen_expr(wrhs)
            emit_byte(0x48); emit_byte(0x87); emit_byte(0xC1)
            rax_cache = 0
        } else if r12_in_use == 0 {
            gen_expr(wlhs)
            uint64 lhs_is_float_r = expr_is_float
            if lhs_is_float_r != 0 {
                // Float LHS: store xmm0 to temp, eval RHS, ucomisd
                uint64 fcmp_temp_r = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 fcrem_r = var_frame_size & 15
                if fcrem_r != 0 { var_frame_size = var_frame_size + 16 - fcrem_r }
                if lhs_is_float_r == 2 {
                    emit_store_xmm0_f32(fcmp_temp_r)
                } else {
                    emit_store_xmm0_f64(fcmp_temp_r)
                }
                gen_expr(wrhs)
                // movsd xmm1, xmm0 (RHS): F2 0F 10 C8
                emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                // reload LHS into xmm0
                if lhs_is_float_r == 2 {
                    emit_load_xmm0_f32(fcmp_temp_r)
                } else {
                    emit_load_xmm0_f64(fcmp_temp_r)
                }
                // ucomisd xmm0, xmm1: 66 0F 2E C1  (ucomiss: 0F 2E C1)
                if lhs_is_float_r == 2 {
                    emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                } else {
                    emit_byte(0x66); emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                }
                uint32 op_tok_fr = ast_data1(node)
                uint64 wop_fr = op_tok_fr
                uint64 p_fr = cg_tokens + wop_fr * 16
                uint32 op_kind_fr = 0
                unsafe { *(p_fr as uint32) -> op_kind_fr }
                rax_invalidate()
                emit_setcc(op_kind_fr)
                expr_is_float = 0
                return
            }
            r12_in_use = 1
            emit_byte(0x49); emit_byte(0x89); emit_byte(0xC4)
            rax_cache = 0
            gen_expr(wrhs)
            r12_in_use = 0
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            emit_byte(0x4C); emit_byte(0x89); emit_byte(0xE0)
            rax_cache = 0
        } else {
            gen_expr(wlhs)
            uint64 lhs_is_float_k = expr_is_float
            uint64 cmp_temp = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 crem = var_frame_size & 15
            if crem != 0 { var_frame_size = var_frame_size + 16 - crem }
            if lhs_is_float_k != 0 {
                // Float LHS: store xmm0 to temp, eval RHS, ucomisd
                if lhs_is_float_k == 2 {
                    emit_store_xmm0_f32(cmp_temp)
                } else {
                    emit_store_xmm0_f64(cmp_temp)
                }
                gen_expr(wrhs)
                // movsd xmm1, xmm0 (RHS): F2 0F 10 C8
                emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                // reload LHS into xmm0
                if lhs_is_float_k == 2 {
                    emit_load_xmm0_f32(cmp_temp)
                } else {
                    emit_load_xmm0_f64(cmp_temp)
                }
                // ucomisd xmm0, xmm1: 66 0F 2E C1  (ucomiss: 0F 2E C1)
                if lhs_is_float_k == 2 {
                    emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                } else {
                    emit_byte(0x66); emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                }
                uint32 op_tok_fk = ast_data1(node)
                uint64 wop_fk = op_tok_fk
                uint64 p_fk = cg_tokens + wop_fk * 16
                uint32 op_kind_fk = 0
                unsafe { *(p_fk as uint32) -> op_kind_fk }
                rax_invalidate()
                emit_setcc(op_kind_fk)
                expr_is_float = 0
                return
            }
            emit_store_rax_to_stack(cmp_temp)
            gen_expr(wrhs)
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            emit_load_rax_from_stack(cmp_temp)
        }

        uint32 op_tok = ast_data1(node)
        uint64 wop = op_tok
        uint64 p = cg_tokens + wop * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }

        // Signedness of the integer compare: derived from the AST since the
        // legacy backend has no per-vreg metadata.
        uint64 cmp_signed = 0
        if legacy_node_is_signed(wlhs) != 0 { cmp_signed = 1 }
        if legacy_node_is_signed(wrhs) != 0 { cmp_signed = 1 }
        if used_direct_cmp != 0 {
            // cmp rbx, imm already set flags — just emit setcc
            rax_invalidate()
            emit_setcc_typed(op_kind, cmp_signed)
        } else {
            emit_compare_typed(op_kind, cmp_signed)
        }
        return
    }

    // LogicalAnd (&&): non-short-circuit, evaluate both, AND results
    if kind == 39 {
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        gen_expr(wlhs)
        uint64 and_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 arem = var_frame_size & 15
        if arem != 0 { var_frame_size = var_frame_size + 16 - arem }
        emit_store_rax_to_stack(and_temp)
        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        gen_expr(wrhs)
        // test both: rax = (lhs != 0) && (rhs != 0)
        // test rax, rax → set ZF if rhs==0
        emit_byte(0x48)
        emit_byte(0x85)
        emit_byte(0xC0)
        // setne cl
        emit_byte(0x0F)
        emit_byte(0x95)
        emit_byte(0xC1)
        // load lhs, test
        emit_load_rax_from_stack(and_temp)
        emit_byte(0x48)
        emit_byte(0x85)
        emit_byte(0xC0)
        // setne al
        emit_byte(0x0F)
        emit_byte(0x95)
        emit_byte(0xC0)
        // and al, cl
        emit_byte(0x20)
        emit_byte(0xC8)
        // movzbl al, eax
        emit_byte(0x0F)
        emit_byte(0xB6)
        emit_byte(0xC0)
        return
    }

    // LogicalOr (||): non-short-circuit
    if kind == 40 {
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        gen_expr(wlhs)
        uint64 or_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 orem = var_frame_size & 15
        if orem != 0 { var_frame_size = var_frame_size + 16 - orem }
        emit_store_rax_to_stack(or_temp)
        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        gen_expr(wrhs)
        // or lhs into rax, then test
        emit_byte(0x48)
        emit_byte(0x89)
        emit_byte(0xC1)
        emit_load_rax_from_stack(or_temp)
        // or rcx, rax
        emit_byte(0x48)
        emit_byte(0x09)
        emit_byte(0xC8)
        // test rax, rax; setne al; movzbl
        emit_byte(0x48)
        emit_byte(0x85)
        emit_byte(0xC0)
        emit_byte(0x0F)
        emit_byte(0x95)
        emit_byte(0xC0)
        emit_byte(0x0F)
        emit_byte(0xB6)
        emit_byte(0xC0)
        return
    }

    // Function call: callee(args...)
    if kind == 35 {
        uint32 callee_tok = ast_data1(node)

        // User-declared extern fn shadows builtins by design: if the programmer
        // wrote `extern fn write(...)`, they want libc's write, not the syscall.
        uint64 wct_pre = callee_tok
        uint64 ext_pre = extern_fn_lookup(wct_pre)
        uint64 is_extern_call = 0
        if ext_pre != 0xFFFFFFFF { is_extern_call = 1 }

        // Check for built-in: exit(code)
        uint64 wct = callee_tok
        if is_extern_call == 0 && tok_matches(wct, "exit", 4) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 wfa = first_arg
            gen_expr(wfa)
            if target_os == 2 {
                // Windows: ExitProcess(code)
                emit_mov_rcx_rax()
                emit_win_alloc_stack(0x20)
                emit_win_call_iat(0)
            } else {
                emit_mov_rdi_rax()
                if target_os == 1 { emit_mov_rax_imm(0x2000001) } else { emit_mov_rax_imm(231) }
                emit_byte(0x0F)
                emit_byte(0x05)
            }
            return
        }

        // Check for built-in: write(fd, buf, len)
        if is_extern_call == 0 && tok_matches(wct, "write", 5) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr(wa1)
            emit_store_rax_to_stack(temp_slot_0)
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr(wa2)
            emit_store_rax_to_stack(temp_slot_1)
            uint32 arg3 = ast_next(wa2)
            uint64 wa3 = arg3
            gen_expr(wa3)
            if target_os == 2 {
                // Windows: GetStdHandle(-(10+fd)) then WriteFile(handle, buf, len, NULL, NULL)
                // Save len to extra temp
                uint64 extra_tmp = var_frame_size
                emit_store_rax_to_stack(extra_tmp)
                // GetStdHandle: rcx = -(10 + fd)
                emit_load_rax_from_stack(temp_slot_0)
                emit_neg_rax()
                emit_sub_rax_imm8(10)
                emit_mov_rcx_rax()
                emit_win_alloc_stack(0x20)
                emit_win_call_iat(1)
                emit_win_free_stack(0x20)
                // rax = handle
                emit_mov_rcx_rax()
                emit_load_rax_from_stack(temp_slot_1)
                // mov rdx, rax (buf)
                emit_mov_rdx_rax()
                emit_load_rax_from_stack(extra_tmp)
                emit_mov_r8_rax()
                emit_mov_r9_imm(0)
                emit_win_alloc_stack(0x30)
                emit_win_stack_arg5(0)
                emit_win_call_iat(2)
                emit_win_free_stack(0x30)
            } else {
                // rax = len -> rdx
                emit_mov_rdx_rax()
                emit_load_rax_from_stack(temp_slot_1)
                emit_mov_rsi_rax()
                emit_load_rax_from_stack(temp_slot_0)
                emit_mov_rdi_rax()
                if target_os == 1 { emit_mov_rax_imm(0x2000004) } else { emit_mov_rax_imm(1) }
                emit_byte(0x0F)
                emit_byte(0x05)
            }
            return
        }

        // Check for built-in: alloc(size) → mmap / VirtualAlloc
        // Returns pointer+8 to caller; first 8 bytes hold the original size.
        if is_extern_call == 0 && tok_matches(wct, "alloc", 5) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 wfa = first_arg
            gen_expr(wfa)
            // Save original requested size
            emit_store_rax_to_stack(temp_slot_0)
            // add rax, 8 — allocate 8 extra bytes for size header
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xC0); emit_byte(8)
            if target_os == 2 {
                // Windows: VirtualAlloc(NULL, size, MEM_COMMIT|MEM_RESERVE, PAGE_READWRITE)
                // rax = size+8
                emit_mov_rdx_rax()
                // rcx = NULL (lpAddress)
                emit_mov_rax_imm(0)
                emit_mov_rcx_rax()
                // r8 = 0x3000 (MEM_COMMIT | MEM_RESERVE)
                emit_mov_rax_imm(0x3000)
                emit_mov_r8_rax()
                // r9 = 4 (PAGE_READWRITE)
                emit_mov_r9_imm(4)
                emit_win_alloc_stack(0x20)
                emit_win_call_iat(6)
                emit_win_free_stack(0x20)
                // rax = raw pointer from VirtualAlloc
                // Store size header at [rax], return rax+8
                emit_store_rax_to_stack(temp_slot_1)
                emit_load_rax_from_stack(temp_slot_0)
                // mov rcx, rax (save original size in rcx)
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
                emit_load_rax_from_stack(temp_slot_1)
                // mov [rax], rcx (store size at start of allocation)
                emit_byte(0x48); emit_byte(0x89); emit_byte(0x08)
                // add rax, 8 (return ptr+8 to caller)
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xC0); emit_byte(8)
            } else {
                // rax = size+8 -> rsi (length)
                emit_mov_rsi_rax()
                // rdi = 0 (addr = NULL)
                emit_byte(0x48)
                emit_byte(0x31)
                emit_byte(0xFF)
                // rdx = 3 (PROT_READ | PROT_WRITE)
                emit_mov_rax_imm(3)
                emit_mov_rdx_rax()
                // r10 = flags
                if target_os == 1 {
                    emit_mov_rax_imm(0x1002)
                } else {
                    emit_mov_rax_imm(0x22)
                }
                // mov r10, rax
                emit_byte(0x49)
                emit_byte(0x89)
                emit_byte(0xC2)
                // r8 = -1 (fd)
                emit_byte(0x49)
                emit_byte(0xC7)
                emit_byte(0xC0)
                emit_u32_le(0xFFFFFFFF)
                // r9 = 0 (offset)
                emit_byte(0x4D)
                emit_byte(0x31)
                emit_byte(0xC9)
                // rax = syscall number
                if target_os == 1 { emit_mov_rax_imm(0x20000C5) } else { emit_mov_rax_imm(9) }
                emit_byte(0x0F)
                emit_byte(0x05)
                // rax = raw mmap pointer
                // Store size header at [rax], return rax+8
                emit_store_rax_to_stack(temp_slot_1)
                emit_load_rax_from_stack(temp_slot_0)
                // mov rcx, rax (save original size in rcx)
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
                emit_load_rax_from_stack(temp_slot_1)
                // mov [rax], rcx (store size at start of allocation)
                emit_byte(0x48); emit_byte(0x89); emit_byte(0x08)
                // add rax, 8 (return ptr+8 to caller)
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xC0); emit_byte(8)
            }
            rax_cache = 0
            return
        }

        // Check for built-in: file_open(path, flags) → open / CreateFileA
        if is_extern_call == 0 && tok_matches(wct, "file_open", 9) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr(wa1)
            emit_store_rax_to_stack(temp_slot_0)
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr(wa2)
            emit_store_rax_to_stack(temp_slot_1)
            if target_os == 2 {
                // Windows: CreateFileA(path, access, share, NULL, disp, attrs, NULL)
                // Use GENERIC_READ|GENERIC_WRITE (0xC0000000) + OPEN_ALWAYS(4)
                // rcx = path
                emit_load_rax_from_stack(temp_slot_0)
                emit_mov_rcx_rax()
                // rdx = 0xC0000000 (GENERIC_READ|GENERIC_WRITE)
                emit_mov_rax_imm(0xC0000000)
                emit_mov_rdx_rax()
                // r8 = FILE_SHARE_READ|WRITE = 3
                emit_mov_rax_imm(3)
                emit_mov_r8_rax()
                // r9 = NULL (security)
                emit_mov_r9_imm(0)
                emit_win_alloc_stack(0x40)
                // [rsp+32] = disposition: 3-flags (read=3=OPEN_EXISTING, write=2=CREATE_ALWAYS)
                emit_load_rax_from_stack(temp_slot_1 + 0x40)  // flags (adjusted for stack shift)
                emit_neg_rax()
                // add eax, 3
                emit_byte(0x83); emit_byte(0xC0); emit_byte(3)
                // mov [rsp+0x20], rax
                emit_byte(0x48); emit_byte(0x89); emit_byte(0x44); emit_byte(0x24); emit_byte(0x20)
                // [rsp+40] = FILE_ATTRIBUTE_NORMAL=0x80
                emit_byte(0x48); emit_byte(0xC7); emit_byte(0x44)
                emit_byte(0x24); emit_byte(0x28); emit_u32_le(0x80)
                // [rsp+48] = NULL (template)
                emit_byte(0x48); emit_byte(0xC7); emit_byte(0x44)
                emit_byte(0x24); emit_byte(0x30); emit_u32_le(0)
                emit_win_call_iat(3)
                emit_win_free_stack(0x40)
            } else {
                emit_load_rax_from_stack(temp_slot_0)
                emit_mov_rdi_rax()
                emit_load_rax_from_stack(temp_slot_1)
                // mov rcx, rax (save flags)
                emit_byte(0x48)
                emit_byte(0x89)
                emit_byte(0xC1)
                // cmp ecx, 1
                emit_byte(0x83)
                emit_byte(0xF9)
                emit_byte(0x01)
                // jne +5 (skip the mov eax)
                emit_byte(0x75)
                emit_byte(0x05)
                if target_os == 1 {
                    emit_mov_rax_imm(0x601)
                } else {
                    emit_mov_rax_imm(0x241)
                }
                emit_mov_rsi_rax()
                emit_mov_rax_imm(0x1A4)
                emit_mov_rdx_rax()
                if target_os == 1 { emit_mov_rax_imm(0x2000005) } else { emit_mov_rax_imm(2) }
                emit_byte(0x0F)
                emit_byte(0x05)
            }
            return
        }

        // Check for built-in: file_read(fd, buf, len) → read / ReadFile
        if is_extern_call == 0 && tok_matches(wct, "file_read", 9) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr(wa1)
            emit_store_rax_to_stack(temp_slot_0)
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr(wa2)
            emit_store_rax_to_stack(temp_slot_1)
            uint32 arg3 = ast_next(wa2)
            uint64 wa3 = arg3
            gen_expr(wa3)
            if target_os == 2 {
                // Windows: ReadFile(handle, buf, len, &bytesRead, NULL)
                // Use a frame slot for bytesRead output
                uint64 extra_tmp = var_frame_size
                emit_store_rax_to_stack(extra_tmp)
                uint64 br_slot = extra_tmp + 8
                // Zero bytesRead slot
                emit_mov_rax_imm(0)
                emit_store_rax_to_stack(br_slot)
                // Set up ReadFile parameters
                emit_load_rax_from_stack(temp_slot_0)
                emit_mov_rcx_rax()                      // rcx = handle
                emit_load_rax_from_stack(temp_slot_1)
                emit_mov_rdx_rax()                      // rdx = buf
                emit_load_rax_from_stack(extra_tmp)
                // r8d = nNumberOfBytesToRead (truncate to 32-bit)
                // mov r8d, eax
                emit_byte(0x41); emit_byte(0x89); emit_byte(0xC0)
                // lea r9, [rsp + br_slot]
                emit_byte(0x4C); emit_byte(0x8D); emit_byte(0x4C); emit_byte(0x24)
                uint8 br8 = br_slot
                emit_byte(br8)
                emit_win_alloc_stack(0x30)
                emit_win_stack_arg5(0)                  // lpOverlapped = NULL
                emit_win_call_iat(4)                    // call ReadFile
                emit_win_free_stack(0x30)
                // Return bytesRead (not the BOOL)
                emit_load_rax_from_stack(br_slot)
            } else {
                emit_mov_rdx_rax()
                emit_load_rax_from_stack(temp_slot_1)
                emit_mov_rsi_rax()
                emit_load_rax_from_stack(temp_slot_0)
                emit_mov_rdi_rax()
                if target_os == 1 { emit_mov_rax_imm(0x2000003) } else { emit_mov_rax_imm(0) }
                emit_byte(0x0F)
                emit_byte(0x05)
            }
            return
        }

        // Check for built-in: file_write(fd, buf, len) → write / WriteFile
        if is_extern_call == 0 && tok_matches(wct, "file_write", 10) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr(wa1)
            emit_store_rax_to_stack(temp_slot_0)
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr(wa2)
            emit_store_rax_to_stack(temp_slot_1)
            uint32 arg3 = ast_next(wa2)
            uint64 wa3 = arg3
            gen_expr(wa3)
            if target_os == 2 {
                // Windows: WriteFile(handle, buf, len, &bytesWritten, NULL)
                uint64 extra_tmp = var_frame_size
                emit_store_rax_to_stack(extra_tmp)
                emit_load_rax_from_stack(temp_slot_0)
                emit_mov_rcx_rax()
                emit_load_rax_from_stack(temp_slot_1)
                emit_mov_rdx_rax()
                emit_load_rax_from_stack(extra_tmp)
                emit_mov_r8_rax()
                emit_win_alloc_stack(0x30)
                // zero [rsp+0x28] for bytesWritten output
                emit_byte(0xC7); emit_byte(0x44); emit_byte(0x24); emit_byte(0x28); emit_u32_le(0)
                // lea r9, [rsp+0x28] — point to bytesWritten
                emit_byte(0x4C); emit_byte(0x8D); emit_byte(0x4C); emit_byte(0x24); emit_byte(0x28)
                emit_win_stack_arg5(0)
                emit_win_call_iat(2)
                emit_win_free_stack(0x30)
            } else {
                emit_mov_rdx_rax()
                emit_load_rax_from_stack(temp_slot_1)
                emit_mov_rsi_rax()
                emit_load_rax_from_stack(temp_slot_0)
                emit_mov_rdi_rax()
                if target_os == 1 { emit_mov_rax_imm(0x2000004) } else { emit_mov_rax_imm(1) }
                emit_byte(0x0F)
                emit_byte(0x05)
            }
            return
        }

        // Check for built-in: file_close(fd) → close / CloseHandle
        if is_extern_call == 0 && tok_matches(wct, "file_close", 10) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 wfa = first_arg
            gen_expr(wfa)
            if target_os == 2 {
                // Windows: CloseHandle(handle)
                emit_mov_rcx_rax()
                emit_win_alloc_stack(0x20)
                emit_win_call_iat(5)
                emit_win_free_stack(0x20)
            } else {
                emit_mov_rdi_rax()
                if target_os == 1 { emit_mov_rax_imm(0x2000006) } else { emit_mov_rax_imm(3) }
                emit_byte(0x0F)
                emit_byte(0x05)
            }
            return
        }

        // fmt_uint: treat as a user-defined function call (must be defined in source)

        // Check for built-in: file_size(fd) → lseek / GetFileSize
        if is_extern_call == 0 && tok_matches(wct, "file_size", 9) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 wfa = first_arg
            gen_expr(wfa)
            if target_os == 2 {
                // Windows: GetFileSizeEx(handle, &size)
                // rcx = handle, rdx = pointer to output uint64
                emit_store_rax_to_stack(temp_slot_0)
                emit_mov_rcx_rax()
                // Use stack for output: lea rdx, [rsp + temp_slot_1]
                emit_byte(0x48); emit_byte(0x8D); emit_byte(0x54)
                emit_byte(0x24)
                uint8 ts1 = temp_slot_1
                emit_byte(ts1)
                emit_win_alloc_stack(0x20)
                emit_win_call_iat(8)  // GetFileSizeEx
                emit_win_free_stack(0x20)
                // Load size from temp_slot_1
                emit_load_rax_from_stack(temp_slot_1)
            } else {
                emit_mov_rdi_rax()
                // lseek(fd, 0, SEEK_END=2) -> rax = size
                // rsi = 0
                emit_byte(0x48)
                emit_byte(0x31)
                emit_byte(0xF6)
                // rdx = 2 (SEEK_END)
                emit_mov_rax_imm(2)
                emit_mov_rdx_rax()
                if target_os == 1 { emit_mov_rax_imm(0x20000C7) } else { emit_mov_rax_imm(8) }
                emit_byte(0x0F)
                emit_byte(0x05)
                // Save size
                emit_push_rax()
                // lseek(fd, 0, SEEK_SET=0) to rewind
                emit_byte(0x48)
                emit_byte(0x31)
                emit_byte(0xF6)
                emit_byte(0x48)
                emit_byte(0x31)
