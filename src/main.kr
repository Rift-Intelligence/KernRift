    uint64 root8 = parse_module()
    inline_pass(root8)
    dce_init()
    dce_scan(root8)

    emit_elf_header_android_x86_64()
    uint64 text_start8 = codegen_output_len()

    uint32 child8 = ast_child(root8)
    uint64 wchild8 = child8
    while wchild8 != 0 {
        uint32 ck8 = ast_kind(wchild8)
        if ck8 == 2 {
            uint32 fn_name8 = ast_data1(wchild8)
            if dce_is_live(fn_name8) != 0 {
                if emit_ir_mode != 0 {
                    fn_register(fn_name8, out_len)
                    ir_init()
                    ir_emit_x86_function(wchild8)
                } else {
                    gen_function(wchild8)
                }
            }
        }
        uint32 nxt8 = ast_next(wchild8)
        wchild8 = nxt8
    }
    resolve_fixups()
    resolve_fnaddr_fixups()
    while (codegen_output_len() & 7) != 0 { emit_byte(0) }
    uint64 data_start8 = codegen_output_len()
    emit_static_data()
    resolve_static_fixups(data_start8)
    uint64 str_start8 = codegen_output_len()
    emit_string_data()
    resolve_string_fixups(str_start8)

    // Android PIE ELF: separate RX code + RW data segments
    uint64 androidx_entry = find_main_offset()
    patch_u32(24, androidx_entry & 0xFFFFFFFF)
    patch_u32(28, (androidx_entry >> 32) & 0xFFFFFFFF)
    uint64 androidx_rx = codegen_output_len()
    patch_u32(208, androidx_rx & 0xFFFFFFFF)
    patch_u32(212, (androidx_rx >> 32) & 0xFFFFFFFF)
    patch_u32(216, androidx_rx & 0xFFFFFFFF)
    patch_u32(220, (androidx_rx >> 32) & 0xFFFFFFFF)
    uint64 androidx_rx_aligned = (androidx_rx + 0xFFFF) & ~0xFFFF
    while codegen_output_len() < androidx_rx_aligned { emit_byte(0) }
    while (codegen_output_len() & 7) != 0 { emit_byte(0) }
    uint64 ax_dfoff = codegen_output_len()
    emit_static_data()
    uint64 ax_draw = codegen_output_len() - ax_dfoff
    uint64 ax_dal = (ax_draw + 0xFFFF) & ~0xFFFF
    if ax_dal == 0 { ax_dal = 0x10000 }
    while codegen_output_len() < ax_dfoff + ax_dal { emit_byte(0) }
    resolve_static_fixups(ax_dfoff)
    patch_u32(296, ax_dfoff & 0xFFFFFFFF)
    patch_u32(300, (ax_dfoff >> 32) & 0xFFFFFFFF)
    patch_u32(304, androidx_rx_aligned & 0xFFFFFFFF)
    patch_u32(308, (androidx_rx_aligned >> 32) & 0xFFFFFFFF)
    patch_u32(312, androidx_rx_aligned & 0xFFFFFFFF)
    patch_u32(316, (androidx_rx_aligned >> 32) & 0xFFFFFFFF)
    patch_u32(320, ax_draw & 0xFFFFFFFF)
    patch_u32(324, (ax_draw >> 32) & 0xFFFFFFFF)
    // p_memsz = page-aligned size: bionic SIGBUSes on p_memsz=0.
    patch_u32(328, ax_dal & 0xFFFFFFFF)
    patch_u32(332, (ax_dal >> 32) & 0xFFFFFFFF)

    uint64 androidx_len = codegen_output_len()
    uint64 androidx_buf = alloc(androidx_len)
    uint64 axi = 0
    while axi < androidx_len {
        uint64 sp = out_buf + axi
        uint64 dp = androidx_buf + axi
        uint64 bv = 0
        unsafe { *(sp as uint8) -> bv }
        uint8 bb = bv
        unsafe { *(dp as uint8) = bb }
        axi = axi + 1
    set_target_arch(1)
    }

    // === Compile ARM64 Android PIE ELF ===
    target_os = 3
    out_len = 0
    fn_count = 0
    fixup_count = 0
    static_fixup_count = 0
    str_fixup_count = 0
    str_len = 0
    extern_fn_count = 0
    extern_call_count = 0
    fnaddr_fixup_count = 0
    static_count = 0
    static_data_size = 0
    struct_count = 0
    struct_var_count = 0
    enum_count = 0
    type_alias_count = 0
    arr_elem_count = 0
    fn_ret_float_count = 0
    fn_ret_struct_count = 0
    line_table_count = 0
    last_recorded_line = 0
    debug_file_count = 0
    diag_count = 0
    diag_error_count = 0
    diag_warn_count = 0
    slice_len_count = 0
    device_count = 0
    device_field_count = 0
    var_type_count = 0
    win_iat_fixup_count = 0
    a64_win_iat_fixup_count = 0

    restore_src_and_tokens(source, size, src_snapshot, my_tokens, tok_bytes, tok_snapshot)
    ast_init(262144)
    parser_init(my_tokens, saved_tcount)
    uint64 root7 = parse_module()
    inline_pass(root7)
    dce_init()
    dce_scan(root7)

    emit_elf_header_android_a64()
    uint64 text_start7 = codegen_output_len()

    uint32 child7 = ast_child(root7)
    uint64 wchild7 = child7
    while wchild7 != 0 {
        uint32 ck7 = ast_kind(wchild7)
        if ck7 == 2 {
            uint32 fn_name7 = ast_data1(wchild7)
            if dce_is_live(fn_name7) != 0 {
                if emit_ir_mode != 0 {
                    fn_register(fn_name7, out_len)
                    ir_init()
                    ir_emit_arm64_function(wchild7)
                } else {
                    gen_function_a64(wchild7)
                }
            }
        }
        uint32 nxt7 = ast_next(wchild7)
        wchild7 = nxt7
    }
    resolve_fixups_a64()
    resolve_fnaddr_fixups_a64()
    // Align to 8 bytes on arm64 (matches direct compile() path) so static
    // data LDR (imm12 scaled by 8) can encode any slot offset exactly.
    while (codegen_output_len() & 7) != 0 { emit_byte(0) }
    while (codegen_output_len() & 7) != 0 { emit_byte(0) }
    uint64 data_start7 = codegen_output_len()
    emit_static_data()
    resolve_static_fixups_a64(data_start7)
    uint64 str_start7 = codegen_output_len()
    emit_string_data()
    resolve_string_fixups_a64(str_start7)

    // Android PIE ELF: separate RX code + RW data segments
    uint64 android_entry = find_main_offset()
    patch_u32(24, android_entry & 0xFFFFFFFF)
    patch_u32(28, (android_entry >> 32) & 0xFFFFFFFF)
    // PT_LOAD RX: code + strings only
    uint64 android_rx = codegen_output_len()
    patch_u32(208, android_rx & 0xFFFFFFFF)
    patch_u32(212, (android_rx >> 32) & 0xFFFFFFFF)
    patch_u32(216, android_rx & 0xFFFFFFFF)
    patch_u32(220, (android_rx >> 32) & 0xFFFFFFFF)
    // Pad to 64KB page boundary for PT_LOAD RW
    uint64 android_rx_aligned = (android_rx + 0xFFFF) & ~0xFFFF
    while codegen_output_len() < android_rx_aligned { emit_byte(0) }
    // Emit data segment (statics)
    while (codegen_output_len() & 7) != 0 { emit_byte(0) }
    uint64 a7_dfoff = codegen_output_len()
    emit_static_data()
    uint64 a7_draw = codegen_output_len() - a7_dfoff
    uint64 a7_dal = (a7_draw + 0xFFFF) & ~0xFFFF
    if a7_dal == 0 { a7_dal = 0x10000 }
    while codegen_output_len() < a7_dfoff + a7_dal { emit_byte(0) }
    // Re-resolve static fixups to point into RW segment
    resolve_static_fixups_a64(a7_dfoff)
    // Patch PT_LOAD RW @288
    patch_u32(296, a7_dfoff & 0xFFFFFFFF)
    patch_u32(300, (a7_dfoff >> 32) & 0xFFFFFFFF)
    patch_u32(304, android_rx_aligned & 0xFFFFFFFF)
    patch_u32(308, (android_rx_aligned >> 32) & 0xFFFFFFFF)
    patch_u32(312, android_rx_aligned & 0xFFFFFFFF)
    patch_u32(316, (android_rx_aligned >> 32) & 0xFFFFFFFF)
    patch_u32(320, a7_draw & 0xFFFFFFFF)
    patch_u32(324, (a7_draw >> 32) & 0xFFFFFFFF)
    // p_memsz = page-aligned size: bionic SIGBUSes on p_memsz=0.
    patch_u32(328, a7_dal & 0xFFFFFFFF)
    patch_u32(332, (a7_dal >> 32) & 0xFFFFFFFF)

    uint64 android_len = codegen_output_len()
    uint64 android_buf = alloc(android_len)
    uint64 adi = 0
    while adi < android_len {
        uint64 sp = out_buf + adi
        uint64 dp = android_buf + adi
        uint64 bv = 0
        unsafe { *(sp as uint8) -> bv }
        uint8 bb = bv
        unsafe { *(dp as uint8) = bb }
        adi = adi + 1
    }

    // Reset target_os for fat binary emission
    target_os = 0

    // === BCJ filter before compression ===
    // x86_64 slices: filter E8/E9 CALL/JMP
    filter_x86_64_bcj(x86_buf, x86_len, 1)
    filter_x86_64_bcj(pe_x86_buf, pe_x86_len, 1)
    filter_x86_64_bcj(macho_x86_buf, macho_x86_len, 1)
    filter_x86_64_bcj(androidx_buf, androidx_len, 1)
    // arm64 slices: filter B/BL instructions
    filter_aarch64_bcj(a64_buf, a64_len, 1)
    filter_aarch64_bcj(pe_a64_buf, pe_a64_len, 1)
    filter_aarch64_bcj(macho_a64_buf, macho_a64_len, 1)
    filter_aarch64_bcj(android_buf, android_len, 1)

    // === Custom target subset: emit only the selected slices, each
    // compressed as a standalone (non-paired) LZ4 blob. The runner treats
    // an entry with pair_off == 0 and pair_uncomp_size == slice_uncomp_size
    // as a single-slice blob. Full-set selection (all 8) drops into the
    // default paired-compression path below for tighter compression.
    if target_mask != 0 && target_mask != 0xFF {
        uint64 comp_bufs = alloc(8 * 8)
        uint64 comp_lens = alloc(8 * 8)
        uint64 uncomp_lens = alloc(8 * 8)
        uint64 zi = 0
        while zi < 8 {
            uint64 zp = comp_bufs + zi * 8
            uint64 zl = comp_lens + zi * 8
            uint64 zu = uncomp_lens + zi * 8
            unsafe { *(zp as uint64) = 0 }
            unsafe { *(zl as uint64) = 0 }
            unsafe { *(zu as uint64) = 0 }
            zi = zi + 1
        }

        uint64 sel_count = 0
        uint64 aid = 1
        while aid <= 8 {
            uint64 bit = aid - 1
            if ((target_mask >> bit) & 1) != 0 {
                uint64 buf = 0
                uint64 len = 0
                if aid == 1 { buf = x86_buf; len = x86_len }
                if aid == 2 { buf = a64_buf; len = a64_len }
                if aid == 3 { buf = pe_x86_buf; len = pe_x86_len }
                if aid == 4 { buf = pe_a64_buf; len = pe_a64_len }
                if aid == 5 { buf = macho_x86_buf; len = macho_x86_len }
                if aid == 6 { buf = macho_a64_buf; len = macho_a64_len }
                if aid == 7 { buf = android_buf; len = android_len }
                if aid == 8 { buf = androidx_buf; len = androidx_len }
                uint64 cap = lz4_compress_bound(len)
                uint64 cbuf = alloc(cap)
                uint64 clen = lz4_compress_frame(buf, len, cbuf)
                uint64 cp = comp_bufs + bit * 8
                uint64 lp = comp_lens + bit * 8
                uint64 ulp = uncomp_lens + bit * 8
                unsafe { *(cp as uint64) = cbuf }
                unsafe { *(lp as uint64) = clen }
                unsafe { *(ulp as uint64) = len }
                sel_count = sel_count + 1
            }
            aid = aid + 1
        }

        out_len = 0
        emit_krbofat_v2_header(sel_count)
        uint64 c_data_offset = 16 + sel_count * 48
        uint64 c_pad = (16 - (c_data_offset & 15)) & 15
        c_data_offset = c_data_offset + c_pad

        uint64 cur_off = c_data_offset
        uint64 aid2 = 1
        while aid2 <= 8 {
            uint64 bit2 = aid2 - 1
            if ((target_mask >> bit2) & 1) != 0 {
                uint64 lp2 = comp_lens + bit2 * 8
                uint64 ulp2 = uncomp_lens + bit2 * 8
                uint64 clen2 = 0
                uint64 ulen2 = 0
                unsafe { *(lp2 as uint64) -> clen2 }
                unsafe { *(ulp2 as uint64) -> ulen2 }
                emit_krbofat_v2_entry_hdr(aid2, 1, cur_off, clen2, ulen2)
                emit_krbofat_v2_entry_rt(0, ulen2)
                cur_off = cur_off + clen2
            }
            aid2 = aid2 + 1
        }

        uint64 cpi = 0
        while cpi < c_pad { emit_byte(0); cpi = cpi + 1 }

        uint64 aid3 = 1
        while aid3 <= 8 {
            uint64 bit3 = aid3 - 1
            if ((target_mask >> bit3) & 1) != 0 {
                uint64 cp3 = comp_bufs + bit3 * 8
                uint64 lp3 = comp_lens + bit3 * 8
                uint64 cbuf3 = 0
                uint64 clen3 = 0
                unsafe { *(cp3 as uint64) -> cbuf3 }
                unsafe { *(lp3 as uint64) -> clen3 }
                emit_raw_bytes(cbuf3, clen3)
            }
            aid3 = aid3 + 1
        }

        codegen_write_output(output_path)

        uint8[64] nb3
        uint64 msg3 = "custom fat binary: "
        write(1, msg3, 19)
        uint64 nl3 = fmt_uint(nb3, sel_count)
        write(1, nb3, nl3)
        msg3 = " slice"
        write(1, msg3, 6)
        if sel_count != 1 {
            msg3 = "s"
            write(1, msg3, 1)
        }
        msg3 = " -> "
        write(1, msg3, 4)
        uint64 olen3 = str_len(output_path)
        write(1, output_path, olen3)
        msg3 = "\n"
        write(1, msg3, 1)
        return
    }

    // === LZ4 compress 4 arch-paired blobs ===
    // Best layout from experimental benchmarks (FAT_COMPRESSION_EXPERIMENTS.md):
    //   x86_64: Linux + macOS,     Windows + Android
    //   arm64:  Linux + Android,   Windows + macOS
    uint64[1] x64_lm_comp_slot
    uint64[1] x64_lm_comp_len_slot
    uint64[1] x64_lm_linux_off_slot
    uint64[1] x64_lm_mac_off_slot
    uint64[1] x64_lm_pair_len_slot
    compress_pair_best(
        x86_buf, x86_len, macho_x86_buf, macho_x86_len,
        x64_lm_comp_slot, x64_lm_comp_len_slot,
        x64_lm_linux_off_slot, x64_lm_mac_off_slot,
        x64_lm_pair_len_slot
    )
    uint64 x64_lm_comp = slot_load_u64(x64_lm_comp_slot)
    uint64 x64_lm_comp_len = slot_load_u64(x64_lm_comp_len_slot)
    uint64 x64_lm_linux_off = slot_load_u64(x64_lm_linux_off_slot)
    uint64 x64_lm_mac_off = slot_load_u64(x64_lm_mac_off_slot)
    uint64 x64_lm_pair_len = slot_load_u64(x64_lm_pair_len_slot)

    uint64[1] x64_wa_comp_slot
    uint64[1] x64_wa_comp_len_slot
    uint64[1] x64_wa_win_off_slot
    uint64[1] x64_wa_android_off_slot
    uint64[1] x64_wa_pair_len_slot
    compress_pair_best(
        pe_x86_buf, pe_x86_len, androidx_buf, androidx_len,
        x64_wa_comp_slot, x64_wa_comp_len_slot,
        x64_wa_win_off_slot, x64_wa_android_off_slot,
        x64_wa_pair_len_slot
    )
    uint64 x64_wa_comp = slot_load_u64(x64_wa_comp_slot)
    uint64 x64_wa_comp_len = slot_load_u64(x64_wa_comp_len_slot)
    uint64 x64_wa_win_off = slot_load_u64(x64_wa_win_off_slot)
    uint64 x64_wa_android_off = slot_load_u64(x64_wa_android_off_slot)
    uint64 x64_wa_pair_len = slot_load_u64(x64_wa_pair_len_slot)

    uint64[1] arm_la_comp_slot
    uint64[1] arm_la_comp_len_slot
    uint64[1] arm_la_linux_off_slot
    uint64[1] arm_la_android_off_slot
    uint64[1] arm_la_pair_len_slot
    compress_pair_best(
        a64_buf, a64_len, android_buf, android_len,
        arm_la_comp_slot, arm_la_comp_len_slot,
        arm_la_linux_off_slot, arm_la_android_off_slot,
        arm_la_pair_len_slot
    )
    uint64 arm_la_comp = slot_load_u64(arm_la_comp_slot)
    uint64 arm_la_comp_len = slot_load_u64(arm_la_comp_len_slot)
    uint64 arm_la_linux_off = slot_load_u64(arm_la_linux_off_slot)
    uint64 arm_la_android_off = slot_load_u64(arm_la_android_off_slot)
    uint64 arm_la_pair_len = slot_load_u64(arm_la_pair_len_slot)

    uint64[1] arm_wm_comp_slot
    uint64[1] arm_wm_comp_len_slot
    uint64[1] arm_wm_win_off_slot
    uint64[1] arm_wm_mac_off_slot
    uint64[1] arm_wm_pair_len_slot
    compress_pair_best(
        pe_a64_buf, pe_a64_len, macho_a64_buf, macho_a64_len,
        arm_wm_comp_slot, arm_wm_comp_len_slot,
        arm_wm_win_off_slot, arm_wm_mac_off_slot,
        arm_wm_pair_len_slot
    )
    uint64 arm_wm_comp = slot_load_u64(arm_wm_comp_slot)
    uint64 arm_wm_comp_len = slot_load_u64(arm_wm_comp_len_slot)
    uint64 arm_wm_win_off = slot_load_u64(arm_wm_win_off_slot)
    uint64 arm_wm_mac_off = slot_load_u64(arm_wm_mac_off_slot)
    uint64 arm_wm_pair_len = slot_load_u64(arm_wm_pair_len_slot)

    // === Emit KrboFat v2 ===
    out_len = 0
    emit_krbofat_v2_header(8)
    uint64 data_offset = 16 + 8 * 48
    uint64 pad = (16 - (data_offset & 15)) & 15
    data_offset = data_offset + pad
    uint64 blob1_data_off = data_offset
    uint64 blob2_data_off = blob1_data_off + x64_lm_comp_len
    uint64 blob3_data_off = blob2_data_off + x64_wa_comp_len
    uint64 blob4_data_off = blob3_data_off + arm_la_comp_len

    // Entry fields: arch_id, compression, blob_offset, blob_comp_size,
    // slice_uncomp_size, slice_offset_in_pair, pair_uncomp_size.
    emit_krbofat_v2_entry_hdr(1, 1, blob1_data_off, x64_lm_comp_len, x86_len)
    emit_krbofat_v2_entry_rt(x64_lm_linux_off, x64_lm_pair_len)
    emit_krbofat_v2_entry_hdr(2, 1, blob3_data_off, arm_la_comp_len, a64_len)
    emit_krbofat_v2_entry_rt(arm_la_linux_off, arm_la_pair_len)
    emit_krbofat_v2_entry_hdr(3, 1, blob2_data_off, x64_wa_comp_len, pe_x86_len)
    emit_krbofat_v2_entry_rt(x64_wa_win_off, x64_wa_pair_len)
    emit_krbofat_v2_entry_hdr(4, 1, blob4_data_off, arm_wm_comp_len, pe_a64_len)
    emit_krbofat_v2_entry_rt(arm_wm_win_off, arm_wm_pair_len)
    emit_krbofat_v2_entry_hdr(5, 1, blob1_data_off, x64_lm_comp_len, macho_x86_len)
    emit_krbofat_v2_entry_rt(x64_lm_mac_off, x64_lm_pair_len)
    emit_krbofat_v2_entry_hdr(6, 1, blob4_data_off, arm_wm_comp_len, macho_a64_len)
    emit_krbofat_v2_entry_rt(arm_wm_mac_off, arm_wm_pair_len)
    emit_krbofat_v2_entry_hdr(7, 1, blob3_data_off, arm_la_comp_len, android_len)
    emit_krbofat_v2_entry_rt(arm_la_android_off, arm_la_pair_len)
    emit_krbofat_v2_entry_hdr(8, 1, blob2_data_off, x64_wa_comp_len, androidx_len)
    emit_krbofat_v2_entry_rt(x64_wa_android_off, x64_wa_pair_len)

    uint64 pi = 0
    while pi < pad { emit_byte(0); pi = pi + 1 }

    emit_raw_bytes(x64_lm_comp, x64_lm_comp_len)
    emit_raw_bytes(x64_wa_comp, x64_wa_comp_len)
    emit_raw_bytes(arm_la_comp, arm_la_comp_len)
    emit_raw_bytes(arm_wm_comp, arm_wm_comp_len)

    codegen_write_output(output_path)

    uint8[64] nb
    uint64 msg = "fat binary: x86_64("
    write(1, msg, 19)
    uint64 nl = fmt_uint(nb, x86_len)
    write(1, nb, nl)
    msg = ") + arm64("
    write(1, msg, 10)
    nl = fmt_uint(nb, a64_len)
    write(1, nb, nl)
    msg = ") + win-x64("
    write(1, msg, 12)
    nl = fmt_uint(nb, pe_x86_len)
    write(1, nb, nl)
    msg = ") + win-arm("
    write(1, msg, 12)
    nl = fmt_uint(nb, pe_a64_len)
    write(1, nb, nl)
    msg = ") + mac-x64("
    write(1, msg, 12)
    nl = fmt_uint(nb, macho_x86_len)
    write(1, nb, nl)
    msg = ") + mac-arm("
    write(1, msg, 12)
    nl = fmt_uint(nb, macho_a64_len)
    write(1, nb, nl)
    msg = ") + android-arm64("
    write(1, msg, 18)
    nl = fmt_uint(nb, android_len)
    write(1, nb, nl)
    msg = ") + android-x64("
    write(1, msg, 16)
    nl = fmt_uint(nb, androidx_len)
    write(1, nb, nl)
    msg = ") -> "
    write(1, msg, 5)
    uint64 olen = str_len(output_path)
    write(1, output_path, olen)
    // Same "(X.XX ms)" timer as single-file compile(). Gated on t_start_fat
    // having landed as non-zero — older target_os paths that stub time_ns()
    // to 0 just fall back to the plain newline.
    uint64 t_end_fat = time_ns()
    if t_start_fat != 0 {
        uint64 elapsed_fat = t_end_fat - t_start_fat
        uint64 ms_whole_f = elapsed_fat / 1000000
        uint64 ms_hund_f  = (elapsed_fat / 10000) % 100
        msg = "  ("
        write(1, msg, 3)
        uint64 w_len_f = fmt_uint(nb, ms_whole_f)
        write(1, nb, w_len_f)
        msg = "."
        write(1, msg, 1)
        uint8[2] hb_f
        uint8 d0_f = 48 + (ms_hund_f / 10)
        uint8 d1_f = 48 + (ms_hund_f % 10)
        unsafe { *(hb_f as uint8) = d0_f }
        uint64 hb_f1 = hb_f + 1
        unsafe { *(hb_f1 as uint8) = d1_f }
        write(1, hb_f, 2)
        msg = " ms)\n"
        write(1, msg, 5)
    } else {
        msg = "\n"
        write(1, msg, 1)
    }
}

// Statics set by _start trampoline
static uint64 cli_argc = 0
static uint64 cli_argv = 0

// Type-checker gate. Default ON; --no-check-types disables for
// emergency builds. Phase 1 rules emit errors; Phase 2 rules (added
// later) emit warnings until their violation counts are triaged.
static uint64 check_types_enabled = 1

// Living compiler CLI options
static uint64 lc_ci_mode = 0
static uint64 lc_min_fitness = 0
static uint64 lc_fix_mode = 0
static uint64 lc_dry_run = 0
static uint64 lc_list_proposals = 0
static uint64 lc_promote_name = 0
static uint64 lc_deprecate_name = 0
static uint64 lc_reject_name = 0
static uint64 freestanding = 0

fn parse_uint_arg(uint64 s) -> uint64 {
    uint64 val = 0
    uint64 i = 0
    uint64 p = s + i
    uint64 c = 0
    unsafe { *(p as uint8) -> c }
    while c >= 48 && c <= 57 {
        val = val * 10 + (c - 48)
        i = i + 1
        p = s + i
        unsafe { *(p as uint8) -> c }
    }
    return val
}

@export
fn main() {
    // Windows: parse raw GetCommandLineA result into argc/argv
    if cli_argc == 0xFFFFFFFF {
        win_init_args()
    }

    uint64 input_path = 0
    uint64 output_path = "a.krbo"
    uint64 mode = 0
    uint64 arch = 0
    uint64 emit_mode = 0
    uint64 arch_set = 0
    uint64 emit_set = 0

    if cli_argc > 1 {
        uint64 i = 1
        while i < cli_argc {
            uint64 arg_ptr = cli_argv + i * 8
            uint64 arg = 0
            unsafe { *(arg_ptr as uint64) -> arg }
            if str_starts_with(arg, "-o", 2) != 0 {
                uint64 arg_len = str_len(arg)
                if arg_len == 2 {
                    i = i + 1
                    uint64 next_ptr = cli_argv + i * 8
                    unsafe { *(next_ptr as uint64) -> output_path }
                } else {
                    output_path = arg + 2
                }
            } else if str_starts_with(arg, "--arch=", 7) != 0 {
                arch_set = 1
                uint64 arch_str = arg + 7
                if str_starts_with(arch_str, "arm64", 5) != 0 {
                    arch = 1
                } else if str_starts_with(arch_str, "aarch64", 7) != 0 {
                    arch = 1
                } else {
                    arch = 0
                }
            } else if str_starts_with(arg, "--emit=", 7) != 0 {
                emit_set = 1
                uint64 emit_str = arg + 7
                if str_starts_with(emit_str, "elfexe", 6) != 0 {
                    emit_mode = 0
                } else if str_starts_with(emit_str, "elf", 3) != 0 {
                    // "elf" / "elf-arm64" / "elf-x86_64" aliases for ELF
                    emit_mode = 0
                } else if str_starts_with(emit_str, "linux", 5) != 0 {
                    // "linux", "linux-x86_64", "linux-arm64", "linux-x86-64" all alias to ELF
                    emit_mode = 0
                } else if str_starts_with(emit_str, "macho", 5) != 0 {
                    emit_mode = 1
                } else if str_starts_with(emit_str, "mac", 3) != 0 {
                    // "macos", "mac-x64", "mac-arm64" alias to Mach-O
                    emit_mode = 1
                } else if str_starts_with(emit_str, "darwin", 6) != 0 {
                    emit_mode = 1
                } else if str_starts_with(emit_str, "windows", 7) != 0 {
                    // "windows", "windows-x64", "windows-arm64" alias to PE
                    emit_mode = 2
                } else if str_starts_with(emit_str, "win", 3) != 0 {
                    // "win", "win-x64", "win-arm64" alias to PE
                    emit_mode = 2
                } else if str_starts_with(emit_str, "pe", 2) != 0 {
                    emit_mode = 2
                } else if str_starts_with(emit_str, "obj", 3) != 0 {
                    emit_mode = 3
                } else if str_starts_with(emit_str, "android", 7) != 0 {
                    emit_mode = 4
                } else if str_starts_with(emit_str, "asm", 3) != 0 {
                    emit_mode = 5
                } else if str_starts_with(emit_str, "ir", 2) != 0 {
                    emit_mode = 6
                } else {
                    write(2, "error: unknown emit format '", 28)
                    uint64 esl = str_len(emit_str)
                    write(2, emit_str, esl)
                    write(2, "'\n", 2)
                    write(2, "valid: elfexe, linux, macho, mac, pe, windows, win, obj, android, asm, ir\n", 74)
                    exit(1)
                }
            } else if str_eq_full(arg, "-c") != 0 {
                emit_set = 1
                emit_mode = 3
            } else if str_starts_with(arg, "--targets=", 10) != 0 {
                parse_targets_arg(arg + 10)
            } else if str_starts_with(arg, "--target=", 9) != 0 {
                uint64 tgt_str = arg + 9
                if str_starts_with(tgt_str, "macos", 5) != 0 {
                    target_os = 1
                } else if str_starts_with(tgt_str, "darwin", 6) != 0 {
                    target_os = 1
                } else if str_starts_with(tgt_str, "windows", 7) != 0 {
                    target_os = 2
                } else if str_starts_with(tgt_str, "win", 3) != 0 {
                    target_os = 2
                } else if str_starts_with(tgt_str, "linux", 5) != 0 {
                    target_os = 0
                } else if str_starts_with(tgt_str, "android", 7) != 0 {
                    target_os = 3
                    emit_mode = 4
                }
            } else if str_starts_with(arg, "--help", 6) != 0 || str_eq_full(arg, "-h") != 0 {
                write(1, "usage: krc [options] <file.kr> [-o output]\n", 43)
                write(1, "       krc <command> <file.kr> [options]\n\n", 42)
                write(1, "default: emit a .krbo fat binary covering all 8 supported targets\n", 66)
                write(1, "(linux/macos/windows/android x x86_64/arm64). The kr runner extracts\n", 69)
                write(1, "and execs the matching slice at startup.\n\n", 42)

                write(1, "output:\n", 8)
                write(1, "  --arch=x86_64|arm64       single-arch binary (no fat-binary wrap)\n", 68)
                write(1, "  --target=linux|macos|windows|android   single-target binary\n", 62)
                write(1, "  --targets=<list>          custom fat binary subset\n", 53)
                write(1, "                              e.g. linux-x64,macos-arm64,win-x64\n", 65)
                write(1, "  --emit=elfexe|macho|pe|android        single-target executable\n", 65)
                write(1, "  --emit=obj                relocatable .o (.obj on Windows)\n", 61)
                write(1, "  --emit=asm                annotated assembly listing\n", 55)
                write(1, "  --emit=ir                 dump SSA IR per function\n", 53)
                write(1, "  -c                        shorthand for --emit=obj\n", 53)
                write(1, "  -o <path>                 output path\n\n", 41)

                write(1, "code generation:\n", 17)
                write(1, "  --ir                      force IR backend (default)\n", 55)
                write(1, "  --legacy                  legacy direct codegen path\n", 55)
                write(1, "  --coalesce                Briggs/George copy coalescing (default on)\n", 71)
                write(1, "  --no-coalesce             disable copy coalescing\n", 52)
                write(1, "  --check-types             type checker (default on)\n", 54)
                write(1, "  --no-check-types          disable type checker\n", 50)
                write(1, "  --O0                      disable IR optimizations (CF/DCE/CSE/LICM)\n", 71)
                write(1, "  --freestanding            no startup code, no libc\n", 53)
                write(1, "  --debug                   runtime safety checks (bounds, null)\n", 65)
                write(1, "  -g                        emit DWARF debug info\n\n", 51)

                write(1, "commands (living compiler):\n", 28)
                write(1, "  check <file.kr>           safety analysis\n", 44)
                write(1, "  lc <file.kr>              propose / classify changes\n", 55)
                write(1, "  fmt <file.kr>             auto-format source\n", 47)
                write(1, "  --list-proposals          list pending proposals\n", 51)
                write(1, "  --promote <name>          accept a proposal\n", 46)
                write(1, "  --deprecate <name>        deprecate an accepted proposal\n", 59)
                write(1, "  --reject <name>           reject a proposal\n", 46)
                write(1, "  --min-fitness <N>         min fitness for --promote\n", 54)
                write(1, "  --ci                      machine-readable check output\n", 58)
                write(1, "  --fix                     apply auto-fixes from check\n", 56)
                write(1, "  --dry-run                 show changes without writing\n\n", 58)

                write(1, "info:\n", 6)
                write(1, "  --version                 show version\n", 41)
                write(1, "  --help, -h                show this help\n", 43)
                exit(0)
            } else if str_starts_with(arg, "--version", 9) != 0 {
                uint64 msg = "krc 2.8.25 (KernRift self-hosted compiler)\n"
                write(1, msg, 42)
                exit(0)
            } else if str_starts_with(arg, "--freestanding", 14) != 0 {
                freestanding = 1
            } else if str_starts_with(arg, "--legacy", 8) != 0 {
                emit_ir_mode = 0
            } else if str_starts_with(arg, "--ir", 4) != 0 {
                emit_ir_mode = 2
            } else if str_starts_with(arg, "--O0", 4) != 0 {
                ir_opt_level = 0
            } else if str_starts_with(arg, "--no-coalesce", 13) != 0 {
                ir_set_coalesce(0)
            } else if str_starts_with(arg, "--coalesce", 10) != 0 {
                ir_set_coalesce(1)
            } else if str_starts_with(arg, "--no-check-types", 16) != 0 {
                check_types_enabled = 0
            } else if str_starts_with(arg, "--check-types", 13) != 0 {
                check_types_enabled = 1
            } else if str_starts_with(arg, "--debug", 7) != 0 {
                debug_mode = 1
            } else if str_starts_with(arg, "-g", 2) != 0 {
                debug_info_mode = 1
            } else if str_starts_with(arg, "--ci", 4) != 0 {
                lc_ci_mode = 1
            } else if str_starts_with(arg, "--fix", 5) != 0 {
                lc_fix_mode = 1
            } else if str_starts_with(arg, "--dry-run", 9) != 0 {
                lc_dry_run = 1
            } else if str_starts_with(arg, "--list-proposals", 16) != 0 {
                lc_list_proposals = 1
                mode = 2
            } else if str_starts_with(arg, "--promote=", 10) != 0 {
                lc_promote_name = arg + 10
                mode = 2
            } else if str_starts_with(arg, "--promote", 9) != 0 {
                i = i + 1
                uint64 pnext_ptr = cli_argv + i * 8
                uint64 pnext_arg = 0
                unsafe { *(pnext_ptr as uint64) -> pnext_arg }
                lc_promote_name = pnext_arg
                mode = 2
            } else if str_starts_with(arg, "--deprecate=", 12) != 0 {
                lc_deprecate_name = arg + 12
                mode = 2
            } else if str_starts_with(arg, "--deprecate", 11) != 0 {
                i = i + 1
                uint64 dnext_ptr = cli_argv + i * 8
                uint64 dnext_arg = 0
                unsafe { *(dnext_ptr as uint64) -> dnext_arg }
                lc_deprecate_name = dnext_arg
                mode = 2
            } else if str_starts_with(arg, "--reject=", 9) != 0 {
                lc_reject_name = arg + 9
                mode = 2
            } else if str_starts_with(arg, "--reject", 8) != 0 {
                i = i + 1
                uint64 rnext_ptr = cli_argv + i * 8
                uint64 rnext_arg = 0
                unsafe { *(rnext_ptr as uint64) -> rnext_arg }
                lc_reject_name = rnext_arg
                mode = 2
            } else if str_starts_with(arg, "--min-fitness=", 14) != 0 {
                lc_min_fitness = parse_uint_arg(arg + 14)
            } else if str_starts_with(arg, "--min-fitness", 13) != 0 {
                // --min-fitness N (next arg)
                i = i + 1
                uint64 next_ptr = cli_argv + i * 8
                uint64 next_arg = 0
                unsafe { *(next_ptr as uint64) -> next_arg }
                lc_min_fitness = parse_uint_arg(next_arg)
            } else if str_starts_with(arg, "check", 5) != 0 {
                mode = 1
            } else if str_starts_with(arg, "lc", 2) != 0 {
                mode = 2
            } else if str_starts_with(arg, "fmt", 3) != 0 {
                mode = 3
            } else {
                input_path = arg
            }
            i = i + 1
        }
    }



    // Auto-set target_os from emit_mode if not explicitly set
    if emit_mode == 1 && target_os == 0 { target_os = 1 }
    if emit_mode == 2 && target_os == 0 { target_os = 2 }
    if emit_mode == 4 && target_os == 0 { target_os = 3 }
    // emit_mode=4 (android): default to arm64 unless --arch was explicitly set
    if emit_mode == 4 && arch_set == 0 { arch = 1 }

    // Derive output name from input if not specified with -o
    if str_eq_full(output_path, "a.krbo") != 0 && input_path != 0 {
        uint64 ilen = str_len(input_path)
        // Strip .kr extension if present, then add appropriate extension
        uint64 base_len = ilen
        if ilen > 3 {
            uint64 dp = input_path + ilen - 3
            uint64 d0 = 0; uint64 d1 = 0; uint64 d2 = 0
            unsafe { *(dp as uint8) -> d0 }
            uint64 dp1 = dp + 1; unsafe { *(dp1 as uint8) -> d1 }
            uint64 dp2 = dp + 2; unsafe { *(dp2 as uint8) -> d2 }
            if d0 == 46 && d1 == 107 && d2 == 114 { base_len = ilen - 3 }
        }
        if emit_mode == 3 {
            // Object file: input.kr → input.o
            uint64 out = alloc(base_len + 3)
            memcpy(out, input_path, base_len)
            uint64 ep = out + base_len
            uint8 e0 = 46; uint8 e1 = 111
            unsafe { *(ep as uint8) = e0 }
            uint64 ep1 = ep + 1; unsafe { *(ep1 as uint8) = e1 }
            uint64 ep2 = ep + 2; uint8 z = 0
            unsafe { *(ep2 as uint8) = z }
            output_path = out
        } else if emit_mode == 2 {
            // PE: input.kr → input.exe
            uint64 out = alloc(base_len + 5)
            memcpy(out, input_path, base_len)
            uint64 ep = out + base_len
            uint8 e0 = 46; uint8 e1 = 101; uint8 e2 = 120; uint8 e3 = 101
            unsafe { *(ep as uint8) = e0 }
            uint64 ep1 = ep + 1; unsafe { *(ep1 as uint8) = e1 }
            uint64 ep2 = ep + 2; unsafe { *(ep2 as uint8) = e2 }
            uint64 ep3 = ep + 3; unsafe { *(ep3 as uint8) = e3 }
            uint64 ep4 = ep + 4; uint8 z = 0
            unsafe { *(ep4 as uint8) = z }
            output_path = out
        } else if arch_set != 0 || emit_set != 0 {
            // Single arch: input.kr → input (no extension, native binary)
            uint64 out = alloc(base_len + 1)
            memcpy(out, input_path, base_len)
            uint64 tp = out + base_len
            uint8 z = 0
            unsafe { *(tp as uint8) = z }
            output_path = out
        } else {
            // Fat binary: input.kr → input.krbo
            uint64 out = alloc(base_len + 6)
            memcpy(out, input_path, base_len)
            uint64 ep = out + base_len
            uint8 e0 = 46; uint8 e1 = 107; uint8 e2 = 114; uint8 e3 = 98; uint8 e4 = 111
            unsafe { *(ep as uint8) = e0 }
            uint64 ep1 = ep + 1; unsafe { *(ep1 as uint8) = e1 }
            uint64 ep2 = ep + 2; unsafe { *(ep2 as uint8) = e2 }
            uint64 ep3 = ep + 3; unsafe { *(ep3 as uint8) = e3 }
            uint64 ep4 = ep + 4; unsafe { *(ep4 as uint8) = e4 }
            uint64 ep5 = ep + 5; uint8 z = 0
            unsafe { *(ep5 as uint8) = z }
            output_path = out
        }
    }

    // --list-proposals doesn't need an input file
    if lc_list_proposals != 0 && input_path == 0 {
        init_proposals()
        load_proposal_overrides()
        list_proposals()
        exit(0)
    }

    // --promote / --deprecate / --reject: governance commands, no input file
    if lc_promote_name != 0 && input_path == 0 {
        init_proposals()
        load_proposal_overrides()
        promote_proposal(lc_promote_name)
        exit(0)
    }
    if lc_deprecate_name != 0 && input_path == 0 {
        init_proposals()
        load_proposal_overrides()
        deprecate_proposal(lc_deprecate_name)
        exit(0)
    }
    if lc_reject_name != 0 && input_path == 0 {
        init_proposals()
        load_proposal_overrides()
        reject_proposal(lc_reject_name)
        exit(0)
    }

    if input_path == 0 {
        if cli_argc > 0 {
            write(2, "krc: no input file\n\n", 20)
            write(2, "usage: krc [options] <file.kr> [-o output]\n", 43)
            write(2, "run 'krc --help' for the full list of options and commands.\n", 60)
            exit(0)
        }
        input_path = "test_input.kr"
    }

    if mode == 1 {
        import_init()
    import_check_file(input_path)
        import_process(input_path)
        uint64 source = import_buf
        uint64 size = import_buf_len
        uint64 max_tok = 262144
        uint64 my_tokens = alloc(max_tok * 16)
        lexer_init(source, size, my_tokens, max_tok)
        uint64 tcount = lexer_run()
        ast_init(262144)
        codegen_init(1048576, source, my_tokens)
        parser_init(my_tokens, tcount)
        uint64 root = parse_module()
        uint64 errors = run_analysis(root)
        if errors > 0 {
            uint8[32] nb
            write(2, "\nkrc: ", 6)
            uint64 nl = fmt_uint(nb, errors)
            write(2, nb, nl)
            write(2, " analysis error(s) found in ", 28)
            write(2, input_path, str_len(input_path))
            write(2, "\n", 1)
            exit(1)
        }
        write(1, "krc check: ", 11)
        write(1, input_path, str_len(input_path))
        write(1, " — OK\n", 6)
        exit(0)
    }

    if mode == 2 {
        // --list-proposals: print the governance-layer proposal registry
        if lc_list_proposals != 0 {
            init_proposals()
            load_proposal_overrides()
            list_proposals()
            exit(0)
        }
        // --fix mode: run the migration engine on the input file
        if lc_fix_mode != 0 {
            run_migration(input_path, lc_dry_run)
            exit(0)
        }
        import_init()
    import_check_file(input_path)
        import_process(input_path)
        uint64 source = import_buf
        uint64 size = import_buf_len
        uint64 max_tok = 262144
        uint64 my_tokens = alloc(max_tok * 16)
        lexer_init(source, size, my_tokens, max_tok)
        uint64 tcount = lexer_run()
        ast_init(262144)
        codegen_init(1048576, source, my_tokens)
        parser_init(my_tokens, tcount)
        uint64 root = parse_module()
        // Run analysis first to populate lock graph
        analysis_init()
        uint64 tel = collect_telemetry(root)
        uint64 patterns = detect_patterns(root, tel)
        uint64 cycles = check_lock_cycles()
        uint64 fitness = compute_fitness(tel, patterns, cycles)
        init_proposals()
        load_proposal_overrides()
        detect_proposals(tel)
        if lc_min_fitness > 0 {
            print_living_report_filtered(tel, patterns, fitness, lc_min_fitness)
        } else {
            print_living_report(tel, patterns, fitness)
        }
        print_firing_proposals()
        if lc_ci_mode != 0 {
            uint64 gate_threshold = lc_min_fitness
            if gate_threshold == 0 { gate_threshold = 50 }
            if lc_check_ci_gate(gate_threshold) != 0 {
                exit(1)
            }
        }
        exit(0)
    }

    if mode == 3 {
        fmt_file(input_path)
        exit(0)
    }

    // Default: produce fat binary unless --arch or --emit specified.
    // On Windows / macOS: default to the host's native format so that
    // `krc hello.kr` just works without flags. The user can still
    // explicitly request a fat binary with `krc hello.kr -o hello.krbo`
    // via --emit=... if they want cross-platform output.
    // --targets=<list> always forces fat-binary emission (custom slice set).
    if target_mask != 0 || (arch_set == 0 && emit_set == 0 && cli_argc > 0) {
        compile_fat(input_path, output_path)
    } else {
        compile(input_path, output_path, arch, emit_mode)
    }
    exit(0)
}
